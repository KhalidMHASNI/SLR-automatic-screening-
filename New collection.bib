@inproceedings{jalleli_audio-visual_2025,
	title = {Audio-{Visual} {Cross}-{Attention} for {Improved} {Deepfake} {Video} {Detection} and {Forgery} {Localization}},
	doi = {10.1109/SMC58881.2025.11342953},
	abstract = {With the emergence of multi-modal generative models, synthesized videos are becoming increasingly realistic, making the detection of deepfakes extremely challenging. While several video deepfake detection models have shown promising performance, their focus has been primarily on the visual modality. To overcome this limitation, we propose a dualstream framework that fuses visual and auditory information via cross-attention computed between embeddings extracted from pre-trained video and audio encoders. Additionally, we design a weakly-supervised forgery localization head that infers frame-level forgery scores from coarse segment-level labels, minimizing the need for fine-grained annotations and allowing for forgery location characterization. In this paper, we describe our preliminary results showing the proposed model outperforming state-of-the-art detectors on both frame-level localization and sequence-level deepfake detection tasks. Ongoing work focuses on investigating the complementarity between the visual and auditory modalities to improve model robustness and explainability.},
	booktitle = {2025 {IEEE} {International} {Conference} on {Systems}, {Man}, and {Cybernetics} ({SMC})},
	author = {Jalleli, Oussama and Zhu, Yi and Falk, Tiago H.},
	month = oct,
	year = {2025},
	keywords = {audio-visual, Computational modeling, crossmodal attention, Deepfake detection, Deepfakes, forgery, Forgery, Fuses, generative AI, Generative AI, Graphics processing units, Location awareness, Robustness, Visualization, Weak supervision},
	pages = {75--79},
}

@inproceedings{p_interpretable_2025,
	title = {Interpretable {Deepfake} {Detection}: {Enhancing} {Real} vs. {Fake} {Face} {Classification} with {Explainable} {AI} and {Transfer} {Learning}},
	doi = {10.1109/ICIIET65921.2025.11378756},
	abstract = {Deepfake detection is a vital challenge in the age of cognitive computing because of its security, misinformation, and identity fraud implications. Article presents an interpretable deepfake detection model built on the DenseNet121 architecture to categorize real and fake faces. The model is trained on a 140,000 images dataset with data augmentation and transfer learning method. Optimized training methods-e.g., early stopping, adaptive learning rate planning, and checkpointing-guarantee effective convergence and overfitting prevention. For added transparency, several Explainable AI (XAI) methods, namely Integrated Gradients, Grad-CAM, Occlusion Sensitivity, Vanilla Gradients, and LIME, are combined to visualize and explain model decisions. These explainability tools demonstrate the network's attention to semantically useful facial areas, building model trustworthiness and diagnostic understanding. Experimental outcomes reveal a 98\% classification accuracy, which surpasses baseline models and verifies the reliability of the proposed approach. This article contributes to the development of explainable, high-accuracy AI systems for deepfake detection, which supports the significance of interpretability in security-critical applications},
	booktitle = {2025 {International} {Conference} on {Intelligent} {Innovations} in {Engineering} and {Technology} ({ICIIET})},
	author = {P, Abinash. and Krishnamoorthy, N. and Vinothkumar, V.},
	month = dec,
	year = {2025},
	keywords = {Adaptation models, Computational modeling, Deepfake Detection, Deepfakes, DenseNet121, Explainable AI, Explainable AI (XAI), Faces, Grad-CAM, Image Classification, Integrated Gradients, Neural Networks, Occlusion Sensitivity, Security, Sensitivity, Technological innovation, Training, Transfer learning, Transfer Learning, Trustworthy AI},
	pages = {1--8},
}

@inproceedings{sharma_deepshield_2025,
	title = {{DeepShield}: {AI}-{Powered} {Deepfake} {Detection}},
	doi = {10.1109/CONIT65521.2025.11167853},
	abstract = {The growing pervasiveness of deepfake technology is enormous in its threats to digital integrity, cybersecurity, and the diffusion of misinformation. Public opinion can be manipulated by deepfake media, identity authentication can be challenged, and digital trust can be harmed. To curb such threats, we introduce DeepShield, a new AI-powered deepfake detection system that combines spatial and temporal analysis for strong forgery detection. Our approach integrates a ResNeXt-based Convolutional Neural Network (CNN) for extracting spatial features and a Long Short-Term Memory (LSTM) network for detecting temporal abnormalities between video frames. DeepShield is trained on benchmark datasets such as FaceForensics++ and DFDC and reaches an accuracy of {\textbackslash}mathbf8 1. 9 7 \% with {\textbackslash}mathbf8 3. 4 \% recall and {\textbackslash}mathbf8 0. 4 \% F1-score, all while having good generalization. Though not surpassing state-of-the-art models in bare accuracy, DeepShield prioritizes scalability, robustness against unseen manipulations, and deployability. We also provide future directions such as transformer-based architecture and multimodal detection, thus positioning DeepShield as a step towards robust real-time video authentication in digital forensics and cybersecurity.},
	booktitle = {2025 5th {International} {Conference} on {Intelligent} {Technologies} ({CONIT})},
	author = {Sharma, Soumya and Gupta, Keshav},
	month = jun,
	year = {2025},
	keywords = {Accuracy, Authentication, Computational modeling, Computer architecture, Convolutional neural networks, Convolutional Neural Networks (CNN), Deepfake detection, Deepfakes, Feature extraction, Long short term memory, Long Short-Term Memory (LSTM), ResNeXt, Robustness, Transformers, Video Authentication},
	pages = {1--7},
}

@inproceedings{mohzary_mobideep_2023,
	title = {{MobiDeep}: {Mobile} {DeepFake} {Detection} through {Machine} {Learning}-based {Corneal}-{Specular} {Backscattering}},
	issn = {2331-9860},
	doi = {10.1109/CCNC51644.2023.10059841},
	abstract = {DeepFake has accomplished notable advancement with the AI-leveraged production and manipulation techniques of fictitious human facial images. Despite many benign and fun applications, the generated fake images can negatively influence the authenticity of online information by originating deception, manipulation, persecution, and seduction, defying societal quality and human rights, which becomes critical security and privacy threat in social networks. Hence, real-time DeepFake detection and limitation technologies on the mobile platform are essential to building a controlled, harmless DeepFake ecosystem. This paper presents a real-time, cloudless, lightweight mobile app for human visual DeepFake detection using machine learning technologies named MobiDeep (Mobile DeepFake Detection through Machine Learning-based Corneal-Specular Backseat-tering). MobiDeep stems from a hypothesis that the existing DeepFake creation methods, including replacement, editing, and synthesis, lack the ensemble with the reflective objects. Focusing on the most reflective area of a human face, corneal-specular backscatter images of eyes, we seek the similarity and consistency with multiple surrounding environment features, including color components, shapes, and textures. We have implemented a cross-platform mobile application to evaluate the performance using various input parameters and lightweight Deep Neural Network (DNN) architectures. The empirical results show that MobiDeep achieves high accuracy (98.7\%) and rapid detection speed (less than 200 ms) in detecting sophisticated DeepFake images within a subsecond.},
	booktitle = {2023 {IEEE} 20th {Consumer} {Communications} \& {Networking} {Conference} ({CCNC})},
	author = {Mohzary, Muhammad and Almalki, Khalid J and Choi, Baek-Young and Song, Sejun},
	month = jan,
	year = {2023},
	keywords = {Corneal-Specular Backscattering, Deep learning, DeepFake, Deepfakes, Focusing, Image color analysis, Neural networks, Shape, Visualization},
	pages = {1104--1109},
}

