	keywords = {Accuracy, Adversarial Resilience, Anomaly Detection, Computational efficiency, Computational Efficiency, Computational modeling, Deep Fake Detection, Deepfakes, Digital Integrity, Feature extraction, Misinformation Prevention, Robustness, Sequential analysis, Social networking (online), Synthetic Media Security, Three-dimensional displays, Transformers},
	pages = {1--7},
}

@inproceedings{s_adversial_2025,
