@inproceedings{supriya_kulkarni_empirical_2025,
	title = {Empirical {Research} on {Facial} {Deepfake} {Detection}: {Taxonomy}, {Challenges}, and {Future} {Directions}},
	doi = {10.1109/ICMNWC66779.2025.11354435},
	abstract = {The rapid development of generative models has led to the rise of deepfakes which are incredibly realistic manipulated media that pose serious dangers to security, privacy, and public trust. This survey specifically demonstrates a detailed assessment of the existing deep fake detection methods that includes neural networks, residual networks, attention methods, transformer algorithms and hybrid methods. Each method is computed based on their strengths, weaknesses, dataset and performance of the benchmark evaluations. Further, the comparative analysis comprises the trade-off between different methods with respect to accuracy, interpretability, computational efficiency and scalability. Thus, the evaluation signifies the existing challenges of generalizability to unseen manipulations and robustness under various conditions such as compression, noise and low-resolution media. Finally, the survey identifies gaps in research, absence of scalable and efficient systems suitable for real-time applications. Then, based on the observed gaps in current approaches and research evidence, the future directions for the deepfake detection systems determines that lightweight hybrid transformer-based approaches that integrate spatial, temporal, and frequency-domain characteristics are required to improve the accuracy, efficiency, and robustness through flexibility for practical deployment in diverse and dynamic deployments.},
	booktitle = {2025 5th {International} {Conference} on {Mobile} {Networks} and {Wireless} {Communications} ({ICMNWC})},
	author = {Supriya Kulkarni, P and Pradeep Kumar, N S},
	month = dec,
	year = {2025},
	keywords = {Accuracy, attention mechanisms, deepfake detection, Deepfakes, hybrid frameworks, Media, neural networks, Neural networks, Robustness, Security, Surveys, Taxonomy, transformer models, Transformers, Wireless communication},
	pages = {1--7},
}

@inproceedings{singh_implementation_2025,
	title = {Implementation of {Machine} {Learning} {Techniques} for {Real}-{Time} {Deep} {Fake} {Voice} {Detection}},
	doi = {10.1109/AIMV66517.2025.11203497},
	abstract = {Growing numbers of audio material made by computers, also called "deep fake voices," are very dangerous to people's privacy, the security of information, and computers. Aiming to correctly identify fake voice changes, this study demonstrates and analyzes real-time machine learning (ML) methods. Specifically, a special dataset with 15,000 audio clips (50 percent real and 50 percent fake) was created and used for testing. Multiple machine learning models could be fully analyzed using features like Mel Frequency Cepstral Coefficients (MFCC), pitch, and spectral difference that were extracted. Random Forest (91.7\%) and Support Vector Machine (SVM) algorithms were beaten by Convolutional Neural Networks (CNN), which got 96.2\% accuracy. Based on real-time application tests, CNN recognition delay was an average of 0.45 seconds per 5-second audio section, proving that it is suitable for use in real-world situations. CNN clearly did better than the other models that were tried, as shown by its positive Area Under Curve (AUC) score of 0.97 in a Receiver Operating Characteristic (ROC) analysis. With precision and memory rates of 95.4\% and 94.8\%, respectively, CNN's better performance and stability are further demonstrated. When compared to high recognition rates, the model had a 3.8\% false-positive rate, showing that it needs to be improved. Results show that CNN-based machine learning models can be useful for fighting deep fake audio risks, which could lead to better real-time security solutions. For better precision and fewer false findings, it is suggested that future study combine multi-modal data analysis with advanced signal processing methods.},
	booktitle = {2025 {International} {Conference} on {Artificial} {Intelligence} and {Machine} {Vision} ({AIMV})},
	author = {Singh, Kaushal and Sanghani, Parag and Shah, Niraj},
	month = aug,
	year = {2025},
	keywords = {Accuracy, CNN, Convolutional neural networks, Cybersecurity, Deep Fake Voice Detection, Deepfakes, Delays, Feature extraction, Internet of Things, Machine Learning, Mel frequency cepstral coefficient, Random forests, Real-Time Analysis, Real-time systems, Support vector machines},
	pages = {1--6},
}

@inproceedings{geethanjali_detectify_2024,
	title = {Detectify : {Image} {Tampering} {Detection} using {Error} {Level} {Analysis} ({ELA}) and {Convolutional} {Neural} {Network} ({CNN})},
	doi = {10.1109/IConSCEPT61884.2024.10627878},
	abstract = {In the evolving digital landscape, the proliferation of manipulated images poses a significant challenge to the authenticity and integrity of visual content. This project investigates cutting-edge image manipulation detection techniques, employing a combination of Error Level Analysis (ELA) and Convolutional Neural Networks (CNN) for robust prediction. Focusing on the widely-used CASIA V2.0 dataset, the study provides a comprehensive evaluation of image manipulation methods. Error Level Analysis is utilized as a forensic tool to identify alterations in the compression levels of manipulated images. By scrutinizing variations in error levels, the project aims to enhance the detection accuracy of manipulated regions within visual content. The CNN model is meticulously crafted and trained using preprocessed ELA images to acquire nuanced features essential for discerning tampering- induced alterations. The proposed hybrid approach, integrating ELA and CNN, establishes a robust framework for detecting image manipulation that is adaptable and efficient. Through the meticulous examination of the CASIA V2.0 dataset, this project contributes to ongoing efforts in combating digital image manipulation. This study serves as a valuable resource for forensic analysts, researchers, and practitioners working towards ensuring the veracity of digital images, offering a nuanced understanding of image manipulation techniques in the contemporary digital era.},
	booktitle = {2024 {International} {Conference} on {Signal} {Processing}, {Computation}, {Electronics}, {Power} and {Telecommunication} ({IConSCEPT})},
	author = {Geethanjali, T M and Darshan, T S and Surya, K and Rahul, H U and Sheety, Ipshika N},
	month = jul,
	year = {2024},
	keywords = {CNN and ELA, Deepfakes, Digital images, Focusing, Forensics, Image coding, Image manipulation detection, image tampering detection, Splicing, Visualization},
	pages = {1--6},
}

@inproceedings{katamneni_mis-avoidd_2023,
	title = {{MIS}-{AVoiDD}: {Modality} {Invariant} and {Specific} {Representation} for {Audio}-{Visual} {Deepfake} {Detection}},
	issn = {1946-0759},
	doi = {10.1109/ICMLA58977.2023.00207},
	abstract = {Deepfakes are synthetic media generated using deep generative algorithms and have posed a severe societal and political threat. Apart from facial manipulation and synthetic voice, recently, a novel kind of deepfakes has emerged with either audio or visual modalities manipulated. In this regard, a new generation of multimodal audio-visual deepfake detectors is being investigated to collectively focus on audio and visual data for multimodal manipulation detection. Existing multimodal (audio-visual) deepfake detectors are often based on the fusion of the audio and visual streams from the video. Existing studies suggest that these multimodal detectors often obtain equivalent performances with unimodal audio and visual deepfake detectors. We conjecture that the heterogeneous nature of the audio and visual signals creates distributional modality gaps and poses a sig-nificant challenge to effective fusion and efficient performance. In this paper, we tackle the problem at the representation level to aid the fusion of audio and visual streams for multimodal deepfake detection. Specifically, we propose the joint use of modality (audio and visual) invariant and specific representations. This ensures that the common patterns and patterns specific to each modality representing pristine or fake content are preserved and fused for multimodal deepfake manipulation detection. Our experimental results on FakeAVCeleb and KoDF audio-visual deepfake datasets suggest the enhanced accuracy of our proposed method over SOTA unimodal and multimodal audio-visual deepfake detectors by 17.8\% and 18.4\%, respectively. Thus, obtaining state-of-the-art performance.},
	booktitle = {2023 {International} {Conference} on {Machine} {Learning} and {Applications} ({ICMLA})},
	author = {Katamneni, Vinaya Sree and Rattani, Ajita},
	month = dec,
	year = {2023},
	keywords = {Audio-visual Deepfake Detection, Deepfakes, Detectors, Feature extraction, Modality Invariant, Modality Specific Features, Representation learning, Streaming media, Streams, Visualization},
	pages = {1371--1378},
}

@inproceedings{pushpalakshmi_daf-net_2025,
	title = {{DAF}-{Net}: {A} {Data}-{Analytics}-{Driven} {Adaptive} {Framework} for {Deepfake} {Detection} {Using} {Hybrid} {Deep} {Learning} {Models}},
	doi = {10.1109/ACROSET66531.2025.11280662},
	abstract = {The emergence of deepfake technology, which is driven by sophisticated Generative Adversarial Networks (GANs), has presented a significant cybersecurity threat. Cybercrimes including identity theft, social engineering, and disinformation now use deepfakes, which are artificially modified videos, pictures, or sounds. Because these synthetic dangers are constantly changing, traditional detection techniques sometimes fall short. The unique multi-modal system DAF-Net (Data-Analytics-Driven Adaptive Framework for Deepfake Detection), which integrates contextual data analytics and deep learning, is proposed in this research. DAF-Net combines a Transformer encoder for temporal inconsistencies, a Convolutional Neural Network (EfficientNet) for spatial features, and Wav2Vec 2.0 for audio-based manipulation detection. Together, these models provide highly accurate deepfake detection across modalities. One of DAF-Net's unique features is its Data Analytics and Visualisation Module, which assigns a Contextual Risk Score and identifies spreading trends using metadata. Tested on datasets like FaceForensics++, DFDC, and ASVspoof 2021, DAF-Net outperformed current techniques with an accuracy of 93.6\% for video and 91.2\% for audio deepfakes. 87\% of high-impact threats have their priorities accurately determined by risk scoring. DAF-Net provides a scalable, intelligent defence solution for practical cybersecurity applications by fusing data analytics and adaptive deep learning.},
	booktitle = {2025 {IEEE} {International} {Conference} on {Advances} in {Computing} {Research} {On} {Science} {Engineering} and {Technology} ({ACROSET})},
	author = {PushpaLakshmi, R.},
	month = sep,
	year = {2025},
	keywords = {Accuracy, Adaptation models, adaptive deep learning, Adaptive systems, Computational modeling, cybersecurity, Data analysis, data analytics, Deep learning, deepfake detection, Deepfakes, Feature extraction, Load modeling, risk scoring, transformer networks, Transformers},
	pages = {1--7},
}

