}

@inproceedings{mundik_towards_2025,
	title = {Towards {Robust} {Deepfake} {Audio} {Detection}: {A} {Hybrid} {CNN}-{Transformer} {Approach} with {XAI}},
	doi = {10.1109/ICONAT66879.2025.11362428},
	abstract = {Deepfakes, realistic media generated by AI, have often been linked to the spread of misinformation and even digital crimes. These synthetic creations can take the form of audio, video, or images. While a lot of research has gone into spotting fake videos and images, audio deepfakes haven't received nearly as much attention. This is especially concerning as voice-generation technology continues to advance rapidly with the growth of AI. In this survey, we explore the latest methods for both creating and detecting deepfakes, with a particular focus on audio. We look at a range of machine learning (ML) and deep learning (DL) techniques that are currently being used in this space. We also propose a hybrid model that combines Convolutional Neural Networks (CNNs) and Transformers, supported by Explainable AI (XAI) tools to make the system more transparent and trustworthy. To make the model even more resilient against sophisticated attacks, we suggest incorporating adversarial training methods like FGSM and PGD.},
	booktitle = {2025 {IEEE} 4th {International} {Conference} for {Advancement} in {Technology} ({ICONAT})},
	author = {Mundik, Mayuresh and Jadhav, Archana and Yerkal, Aditya and Tambe, Kunal and Kamthe, Siddhesh},
	month = sep,
	year = {2025},
	keywords = {Adversarial Training, CNN, Convolutional neural networks, Deepfake Audio (DFA), Deepfakes, Explainable AI, Explainable AI (XAI), Forensics, Machine Learning, Multimodal Detection, Real-time systems, Speech Recognition, Surveys, Synchronization, Time-frequency analysis, Training, Transformers},
	pages = {1--6},
}

@inproceedings{wang_optimization_2025,
	title = {Optimization of {Forged} {Face} {Detection} via {Attention}-based {Bi}-directional {Long} {Short}-{Term} {Memory} {Networks}},
	doi = {10.1109/CBASE67452.2025.11335569},
	abstract = {With the rapid development of DeepFake and other face forgery generation methods, the authenticity of digital media has been severely undermined.Conventional detection approaches that rely solely on static frame-by-frame analysis often fail to capture temporal inconsistencies between adjacent frames. This study aims to develop a real-time, application-oriented deepfake picture detection method based on an attention-enhanced bidirectional long short-term memory network (Bi-LSTMAttention). The proposed method is designed to overcome the limitations of existing techniques in both efficiency and accuracy. The experimental dataset consists of {\textbackslash}mathbf6 0, 0 0 0 facial images, with 30,000 real faces sourced from Celeb-DF and FaceForensics++ datasets, and 30,000 forged faces generated using Midjourney and DeepFake-TIMIT. The results demonstrate that the he proposed attention-based Bi-LSTM method demonstrates superior performance in real-time detection. Compared with BP neural networks, single LSTM, bidirectional LSTM models, Transformer-based models, and EfficientNet, it achieves notable improvements, yielding a Precision of 91.2 \%, a Recall of 88.3 \%, and a mean Average Precision (mAP) of 93.1 \%.},
	booktitle = {2025 4th {International} {Conference} on {Cloud} {Computing}, {Big} {Data} {Application} and {Software} {Engineering} ({CBASE})},
	author = {Wang, Tingting},
	month = oct,
	year = {2025},
	keywords = {Attention Mechanism, BiLSTM, Computational modeling, Data models, Deep Learning, Deepfakes, Face detection, Faces, Fake face recognition, Neural networks, Optimization, Real-time systems, Solid modeling, Transformers},
	pages = {180--184},
}

@inproceedings{talwalkar_design_2024,
	title = {Design and {Analytical} {Performance} of a {Hybrid} {Model} {Using} {Deep} {Learning} {Techniques} for the {Detection} of {Deepfake} {Videos}},
	doi = {10.1109/ICAIQSA64000.2024.10882277},
	abstract = {Recently, it has been possible to develop utilities that can create video face-swaps that are indistinguishable from the real. Recent advancements in deep learning techniques make it possible to synthesize ever-realistic videos. Popularly referred to as deepfakes, this technology has indeed brought a lot of ease and more realistic fakes than the normal ones. In as much as deepfakes are easy to make, their detection is challenging. The study presents a hybrid model that integrates GRU in EfficientNet-B1, InceptionV3, Xception, and DenseNet121. These models were evaluated as pure networks without the GRU layers and as networks with the GRU layers positioned to process temporal information. The GRU, which is a recurrent neural network variant, serves the purpose of adding an extra edge in performance in detecting deepfakes by looking at the temporal aspect of the data. Over the course of the research, there has been an emphasis on standard models and their variation with GRU models in order to understand the role of time-based data. This study enhances constant efforts against deepfakes and will help researchers \& practitioners who develop deepfake detection systems and protect the integrity of the digital media.},
	booktitle = {2024 {International} {Conference} on {Artificial} {Intelligence} and {Quantum} {Computation}-{Based} {Sensor} {Application} ({ICAIQSA})},
	author = {Talwalkar, Karan R and Navale, Kshitij and Ashok, Aditya and Khade, Anindita},
	month = dec,
	year = {2024},
	keywords = {Accuracy, Analytical models, Computer architecture, Data models, Deep learning, Deep-Fake Video Detection, Deepfakes, Densenet 121, Efficientnet-B1, GRU, Inception-v3, Quantum computing, Real-time systems, Recurrent neural networks, Standards, Xception},
	pages = {1--7},
}

@inproceedings{akshaya_hybrid_2025,
	title = {Hybrid {Deepfake} {Video} {Detection} {Using} {Xception} and {LSTM}},
	doi = {10.1109/ICISC65841.2025.11187953},
	abstract = {Deepfakes, generated through Deep Generative Models like GANs, pose significant threats to digital authenticity, privacy, and public trust. In our approach, we integrate the spatial feature extraction capabilities of the Xception CNN with the temporal learning strengths of LSTM networks. We implemented a frame-based video classification pipeline, extracting uniformly sampled frames from real and manipulated videos. These frames underwent extensive data augmentation to improve generalization and prevent overfitting. Each frame was processed using a pre-trained Xception model for deep spatial feature extraction, and the extracted features were sequentially modeled using an LSTM layer to learn temporal dynamics across frames. Our model was trained on a carefully partitioned and augmented dataset, achieving high accuracy on unseen test samples and demonstrating strong generalization across datasets. Additionally, we integrated a real-time prediction module for direct classification of input videos as real or fake with confidence scores. This system contributes to ongoing efforts to counter the misuse of synthetic media by enabling scalable, automated, and real-time deepfake detection across diverse media sources.},
	booktitle = {2025 9th {International} {Conference} on {Inventive} {Systems} and {Control} ({ICISC})},
	author = {Akshaya, Deme and Ram, Dage Sai and Prathiba, Sambari and Jamal, K.},
	month = aug,
	year = {2025},
	keywords = {Convolutional Neural Network (CNN), Convolutional neural networks, Data augmentation, Data Augmentation, Deepfakes, Feature extraction, Generative Adversarial Networks (GANs), Long short term memory, Long Short-Term Memory (LSTM), Media, Overfitting, Pipelines, Privacy, Real-time systems, Real-Time Video Classification, Temporal Modeling, Xception Network},
	pages = {237--244},
}

@inproceedings{jain_anti-spoofing_2025,
	title = {Anti-{Spoofing} {Liveliness} {Detector} for {Face} {Recognition} {System} using {You} {Only} {Looks} {Once} version 8({YOLOv8})},
	doi = {10.1109/ICCCA66364.2025.11325194},
	abstract = {This method fights against bad guys fooling face recognition. Bad guys try sending pretend pictures or videos. They want to trick the system. Face recognition tech is used for mobiles, cameras, and IoT gadgets. If fooled, it is a big problem. This system uses deep learning to stop bad guys. It uses YOLOv8 to spot objects in pictures and videos fast and good. It combines YOLOv8 with deep learning. So it can tell if a face seen is real or fake. It works in live situations. This makes face recognition secure and can be trusted.The application goes through these steps: Capturing Live Video: Frames are recorded using a webcam. A pre-existing model spots faces in these frames. The model also checks how blurry each detected face is. Organizing Face Data: The discovered faces are sorted by whether they're real or fake. Their locations in the frames are noted. This structured data helps train and test machine learning models. Training YOLOv8 Model: The collected face data trains the YOLOv8 face detection model. This offline training finetunes settings to differentiate real and fake faces better. Real Time Face Detection: The trained model processes live video. It spots and labels faces as real or fake based on learned features. Users see these annotated frames with face authenticity feedback. Separately, a blur assessment uses the Laplacian math method. It measures the variance in pixel brightness within each face region. High variance equals clearer facial details. Low variance signals blurriness or lack of sharpness.The system blends advanced object spotting like YOLOv8, deep learning methods, and blur checking tools. It offers a full fix for finding and stopping spoofing attacks in face recognition systems. Tests show it works well and could make face recognition safer and more reliable in real life.},
	booktitle = {2025 {IEEE} 7th {International} {Conference} on {Computing}, {Communication} and {Automation} ({ICCCA})},
	author = {Jain, Neha and Bhardwaj, Priyanka and Verma, Seema and Priyani, Juhi and Dahiya, Kushal},
	month = nov,
	year = {2025},
	keywords = {anti-spoofing, Data models, Deep learning, Detectors, Face detection, Face recognition, Laplace equations, Liveliness Detector, presentation attack, Real-time systems, Training, Webcams, YOLO, You Only Look Once},
	pages = {1--8},
}

@inproceedings{kumarage_general_2025,
	title = {A {General} {Classification} {Framework} for {Detecting} {AI}-{Generated} {Voices}},
	issn = {2837-5424},
	doi = {10.1109/ICAC69156.2025.11361479},
	abstract = {The rapid advancement of deepfake voice synthesis technologies has led to increasing misuse cases, including impersonation, misinformation, and fraud. Although artificial intelligence (AI)-generated voices offer legitimate benefits, their misuse poses growing cybersecurity threats. This paper presents a general classification framework for detecting AI-generated voices across Sinhala, Tamil, and English languages. Publicly available datasets for multilingual deepfake voice detection, particularly in low-resource languages such as Sinhala and Tamil, remain limited, with most existing models focused primarily on English. To address this gap, an acoustic dataset covering Sinhala, Tamil, and English was created using real voice samples either recorded or sourced from public datasets and synthetic samples generated through Text-to-Speech (TTS) and Voice Conversion (VC) techniques, including tools such as Google Translate and Resemble AI. A hybrid CNN-LSTM model was developed to classify voices as real or synthetic. Mel-Frequency Cepstral Coefficients (MFCCs) were extracted and fed into separate CNNLSTM models trained for each language. The proposed system achieved over 95 \% test accuracy across all three languages, demonstrating robust cross-linguistic performance. The findings offer a foundation for scalable, AI-driven deepfake voice detection frameworks adaptable to diverse linguistic and regional contexts.},
	booktitle = {2025 7th {International} {Conference} on {Advancements} in {Computing} ({ICAC})},
	author = {Kumarage, Malki K. and Wijayasekara, Sanika K.},
	month = dec,
	year = {2025},
	keywords = {Accuracy, Adaptation models, AI-Generated Voice Detection, Artificial intelligence, Artificial Intelligence, Audio Deepfake Detection, CNN-LSTM, Deepfakes, Feature extraction, Internet, MFCC, Multilingual, Text to speech, Training, Translation},
	pages = {1--6},
}

@inproceedings{rayat_novel_2025,
	title = {A {Novel} {Multi}-{Layer} {Framework} for {Human} and {AI}-{Voice} {Detection} {Using} {Machine} {Learning} and {Network} {Architecture}},
	issn = {2767-7362},
	doi = {10.1109/SMART66937.2025.11389220},
	abstract = {The rapid advancement in the field of Artificial Intelligence has led to the development of AI-voice systems capable of delivering informative conversations, including factual, general, and even emotionally adaptive responses. However, some individuals have exploited these systems for self-serving purposes. Traditional methods lack the capability to distinguish between human and AI voices, causing a potential leading to an increase in fraudulent and unethical activities, thereby creating an urgent need for a more advanced solution. To address this limitation, we propose our framework that integrates Machine Learning techniques with an adversarial reverse engineering framework equipped with a multi-layered decision architecture incorporating feature extraction and source utility handling. The proposed framework aims to provide real-time edge processing, equipped with adversarial robustness and supporting multilingual capabilities. It handles multiple edge cases such as data cleansing and content moderation by leveraging architectures including convolutional neural networks (abbreviated as CNN), recurrent neural networks (abbreviated as RNN), Transformers, and other specific techniques. The model was evaluated under multiple edge cases, such as content and linguistic variations, adversarial and deceptive inputs, synthetic and contextual channel effects, using publicly accessible datasets such as Standard Speech \& TTS, Fake-or-Real, ASVspoof 2019, and MLAAD. The proposed framework achieved an accuracy of 92.18\% for classifying human and AI voices and report generation and distinctly classified other factors such as an equal error rate (abbreviated as EER) of about 6.8\%, recall of around 93.16\%, and F1-score around 92.84\%, confirming the effectiveness of the proposed innovative solution in both detection accuracy and robustness.},
	booktitle = {2025 14th {International} {Conference} on {System} {Modeling} \& {Advancement} in {Research} {Trends} ({SMART})},
	author = {Rayat, Simar Singh and Thapa, Sujal and Basnet, Raj and Sharma, Vikrant and Dahiya, Susheela and Rathod, Arun Pratap Singh},
	month = nov,
	year = {2025},
	keywords = {Accuracy, Adaptation models, adversarial reverse engineering, Convolutional neural networks, digital forensics, Machine learning, Machine Learning Framework, Multilingual, neural architecture fingerprinting, Real-time systems, Recurrent neural networks, Reverse engineering, Robustness, Transformers, Voice synthesis detection},
	pages = {114--119},
}

@inproceedings{longwei_deep_2025,
	title = {Deep {Fake} {Detection}: {Enhancing} {Content} {Verification} {Using} {CNN}-{LSTM} for {Mitigating} {AI}-{Generated} {Video} {Threats}},
	doi = {10.1109/ICMCTC62214.2025.11196450},
	abstract = {The emergence of Generative Adversarial Networks has dramatically transformed the landscape of synthetic media, enabling the creation of hyper-realistic deep fake videos that are increasingly difficult to distinguish from authentic content. This poses a growing threat, particularly across social media platforms like YouTube, Facebook, and TikTok, where misinformation can spread rapidly and influence public discourse. Traditional video analysis techniques are often inadequate in addressing the sophistication of such forgeries, highlighting the urgent need for robust detection systems. In this study, we present a deep fake detection model that effectively combines the spatial capabilities of a ResNeXt-based convolutional neural network with the temporal sensitivity of a Long Short-Term Memory network. The architecture utilizes 2048-dimensional feature vectors extracted from final pooling layers, with dropout applied to mitigate overfitting, and LSTM layers capturing sequential dependencies between video frames. By tuning the learning rate and extending the architecture with additional layers, our model demonstrated strong performance. Notably, it achieved an accuracy of 84.8\%, with precision of 89.1\% and F1 score of 84.5\%, reflecting its reliability in distinguishing real from fake content. The system also forms the basis of a functional web prototype, offering potential real-world applications in digital forensics, content verification, and online safety. Ultimately, this research supports broader efforts to maintain information integrity and combat the misuse of generative AI technologies.},
	booktitle = {2025 {International} {Conference} on {Metaverse} and {Current} {Trends} in {Computing} ({ICMCTC})},
	author = {Longwei, Xiao and Jhanjhi, Noor Zaman and Saeed, Soobia and Ashfaq, Farzeen and Wicaksana, Fikri Arif and De Wibowo Muhammad Sidik, Aryo},
	month = apr,
	year = {2025},
	keywords = {Accuracy, AI, CNN, Convolutional neural networks, Deep Fake, Deepfakes, Feature extraction, Long short term memory, Reviews, Security, Short-Term Memory Network, Social networking (online), Vectors, Video on demand, Web sites},
	pages = {1--10},
}

@article{liu_real-time_2025,
	title = {Real-{Time} {Video} {Forgery} {Detection} via {Vision}-{WiFi} {Silhouette} {Correspondence}},
	volume = {24},
	issn = {1558-0660},
	doi = {10.1109/TMC.2024.3483550},
	abstract = {For safety guard and crime prevention, video surveillance systems have been pervasively deployed in many security-critical scenarios, such as the residence, retail stores, and banks. However, these systems could be infiltrated by the adversary and the video streams would be modified or replaced, i.e., under the video forgery attack. The prevalence of Internet of Things (IoT) devices and the emergence of Deepfake-like techniques severely emphasize the vulnerability of video surveillance systems under such attacks. To secure existing surveillance systems, in this paper we propose a vision-WiFi cross-modal video forgery detection system, namely WiSil. Leveraging a theoretical model based on the principle of signal propagation, WiSil constructs wave front information of the object in the monitoring area from WiFi signals. With a well-designed deep learning network, WiSil further recovers silhouettes from the wave front information. Based on a Siamese network-based semantic feature extractor, WiSil can eventually determine whether a frame is manipulated by comparing the semantic feature vectors extracted from the video’s silhouette with those extracted from the WiFi’s silhouette. We enhance the basic version of WiSil Fang et al. 2023 by developing a model compression method and a forgery trace localization method. Extensive experiments show that WiSil achieves 95\%++ accuracy in detecting tampered frames.},
	number = {3},
	journal = {IEEE Transactions on Mobile Computing},
	author = {Liu, Jianwei and Fang, Xinyue and Chen, Yike and Yuan, Jiantao and Yu, Guanding and Han, Jinsong},
	month = mar,
	year = {2025},
	keywords = {Accuracy, Cameras, Data preprocessing, deep learning, Feature extraction, Forensics, Forgery, Real-time systems, Streaming media, video forgery detection, Video surveillance, WiFi sensing, Wireless fidelity},
	pages = {1585--1601},
}

@inproceedings{gadde_detecting_2024,
	title = {Detecting {Deepfake} {Images}: {A} {Deep} {Learning} {Approach} with {Streamlit} {Integration}},
	doi = {10.1109/ICSTEM61137.2024.10560646},
	abstract = {According to sophisticated machine learning algorithms, deep fake technology can produce incredibly lifelike fake images and videos that may be exploited for fraud, disinformation, and public opinion manipulation. This has raised serious concerns about the technology. In response to this emerging threat, this research project proposes a deep fake detection system utilizing convolutional neural networks (CNNs) to distinguish between authentic and manipulated media. The project begins with the collection and preprocessing of a diverse dataset containing both real and fake images and videos. The dataset is then used to train a CNN model, consisting of multiple convolutional and pooling layers followed by fully connected layers, to learn discriminative features that can differentiate between genuine and manipulated media. Experimental results demonstrate the effectiveness of the proposed deep fake detection system in accurately identifying fake content with high precision, recall, and accuracy. Additionally, the system is capable of processing both individual images and video streams, enabling real-time detection of deep fake content. Overall, this research contributes to the ongoing efforts to combat the proliferation of deep fake technology by providing a robust and reliable solution for detecting manipulated media, thereby safeguarding the integrity of digital content and mitigating the potential negative consequences of deep fake misuse.},
	booktitle = {2024 {International} {Conference} on {Science} {Technology} {Engineering} and {Management} ({ICSTEM})},
	author = {Gadde, Abhinaya and Kishore, G.D. K. and Talari, Tejaswi and Nunna, Sai Lokesh and Nannapaneni, Reshma Chowdary and Vamsi, K.M.S. Krishna},
	month = apr,
	year = {2024},
	keywords = {Accuracy, Binary Classification, Convolutional Neural Network (CNN), Data Augmentation, Data Preprocessing, Deep Fake Detection, Deepfakes, Dropout Regularization, Early Stopping, Feature Extraction, Image Dataset, Image Input, Max-Pooling, Model Deployment, Model Evaluation, Model Training, Multi-Layer Perceptron (MLP), Neural networks, Real vs. Fake Images, Real-time systems, Serialization, Streaming media, Streamlit Application, TensorFlow, Training, Video Input, Visualization},
	pages = {1--7},
}

@inproceedings{liu_wavelet_2025,
	title = {Wavelet {Scattering} and {Spectral} {Feature} {Fusion} for {Robust} {Voice} {Liveness} {Detection}},
	doi = {10.1109/NTCI67886.2025.11308220},
	abstract = {The growing threat of audio-based spoofing, such as replay, speech synthesis, and voice conversion, has created an urgent demand for reliable voice liveness detection (VLD) in speaker verification and voice assistant systems. We propose a novel VLD method that integrates wavelet scattering transform (WST) with complementary spectral representations, including MEL spectrogram, constant-Q transform (CQT), spectral flatness, and speech energy entropy rate (SEER). These features are fused and evaluated using both lightweight and deep convolutional neural networks: a custom residual CNN, MobileNetV2, ResNet18, and ResNet34. Comprehensive experiments on the ASVspoof 2021 benchmark, covering logical access (LA), physical access (PA), and deepfake (DF) subsets, demonstrate that WST-based fusion consistently outperforms existing approaches. Our ResNet34+WSTCQT model achieves state-of-the-art results, including a perfect 0.000 EER on PA and competitive performance on DF (0.020 EER) and LA (0.041 EER). MobileNetV2 configurations also outperform strong baselines like ECAPA-TDNN and W2V2+LCNN+BLSTM. The results confirm the effectiveness and generalizability of our approach across spoofing types and model sizes. This work provides a scalable, low-latency, and accurate front-end for future real-time audio authentication systems.},
	booktitle = {2025 {International} {Conference} on {New} {Trends} in {Computational} {Intelligence} ({NTCI})},
	author = {Liu, Yanchang and Zhao, Zehao and Lu, Hao and Zhang, Kun and Dong, Jiaqi and Tong, Jinlong},
	month = oct,
	year = {2025},
	keywords = {Anti-spoofing, ASVspoof, Benchmark testing, Convolutional neural networks, Feature extraction, Feature fusion, Real-time systems, Scattering, Spectrogram, Speech synthesis, Transformers, Voice liveness detection, Wavelet domain, Wavelet scattering, Wavelet transforms},
	pages = {531--536},
}

@inproceedings{gupta_deepfake_2024,
	title = {Deepfake {Videos} {Generation} and {Detection}: {A} {Comprehensive} {Survey}},
	volume = {5},
	doi = {10.1109/IC2PCT60090.2024.10486232},
	abstract = {The rapid evolution of deepfake technology in recent years brings forth both promising opportunities and formidable challenges. This research paper conducts a thorough exploration of cutting-edge techniques in deepfake generation and detection, shedding light on the dynamic landscape of this field. Our investigation into deepfake generation includes an in-depth examination of advanced approaches such as CramerGAN, StyleGAN, Progressive Growing GAN (PGGAN), IcGAN, SaGAN, and HifaFace, among others. Each method, from the precision in facial attribute control offered by StyleGAN to the exceptional image quality attained by PGGAN, presents unique capabilities. The paper systematically assesses the effectiveness of ProGAN, Convolutional long short-term memory (LSTM) based residual network (CLRNet), AutoGAN, Octave convolution operation (OctConv), and F3-Net in identifying deepfake content. Beyond these techniques, we also delve into various emerging generation and detection strategies, providing a comprehensive overview of the diverse approaches in the ever-evolving landscape of deepfake technology.},
	booktitle = {2024 {IEEE} {International} {Conference} on {Computing}, {Power} and {Communication} {Technologies} ({IC2PCT})},
	author = {Gupta, Akanksha and Pandey, Dilkeshwar},
	month = feb,
	year = {2024},
	keywords = {attribute manipulation, CNN, Deepfakes, DeepFakes, expression swap, GAN, Generative adversarial networks, identity manipulation, Image quality, Image resolution, Real-time systems, Surveys, Taxonomy},
	pages = {1939--1944},
}

@inproceedings{t_combating_2025,
	title = {Combating {Deepfakes}: {A} {Transformer} - {Obtained} and {Explainable} {Frameworks} for {Robust} {Video} {Integrity} {Verification}},
	doi = {10.1109/ICSCN67106.2025.11308255},
	abstract = {A The fast-growing development of deepfake technology poses serious threats to digital trust, media integrity, and information authenticity. Current detection methodologies may be effective but often struggle with issues of generalization, computational expense, and a lack of interpretability. a novel framework, "Countering Deepfakes: A Transformer-Informed and Explainable Framework, for Robust Video Integrity Verification," which adopts a hybrid convolutional neural network (CNN) and transformer-based architectures to model local spatial aspects and long-range temporal aspects of video information. Additionally, multimodal analysis, through visual and audio consistency checks, significantly contributes to detection reliability. To meet the interpretability challenges, Here applies a gradient-based interpretability methodology to identify facial manipulation regions for forensic overlay. Empirical evaluation of our framework on established benchmark deepfake datasets shows promise for comparably higher accuracy, cross-data-set generalization, and adversarial robustness compared to prior CNN–RNN-based deepfake methodologies. This reduced a computational demands and enabled real-time™ deployment, in a version suitable for digital media forensics, social media engagements, and digital information cybersecurity. Our work extends the state of the art in video integrity detection by offering a robust, interpretable, and scalable solution to counter deepfakes in a rapidly changing digital environment.},
	booktitle = {2025 {International} {Conference} on {Sustainable} {Communication} {Networks} and {Application} ({ICSCN})},
	author = {T, Lavanya and Pandeeswaran, C. and Morin, L. Steffina},
	month = oct,
	year = {2025},
	keywords = {Adversarial Robustness, CNN, Convolutional neural networks, Deepfake Detection, Deepfakes, Explainable AI, Forensics, Green communications, Media, Multimodal Learning, Robustness, Social networking (online), Transformers, Video Integrity Verification, Visualization},
	pages = {1610--1617},
}

@inproceedings{monish_unmasking_2025,
	title = {Unmasking {Deep} {Fake} {Images} with {Intelligent} {Detection}},
	doi = {10.1109/ICISS63372.2025.11076218},
	abstract = {This is a project that deals with the rising threat of deepfake technology, which manipulates media to create very realistic yet misleading content. In the fight against this, we propose a comprehensive deepfake detection system capable of analyzing images. For image analysis, we utilize Convolutional Neural Networks, which are specifically VGG16 and MobileNet, to extract relevant features and classify images as authentic or manipulated. We come up with the development of the web application where it eases the process through the use of uploading the images to be used in analyzing where the real time accurate results regarding classification is available to the users. Last, the system will optimize performance purposes as well. The combination of these techniques will make our system significantly contribute to the detection and mitigation of deepfake content in digital media, empowering users to identify manipulated images and safeguard the integrity of visual information across various platforms.},
	booktitle = {2025 7th {International} {Conference} on {Intelligent} {Sustainable} {Systems} ({ICISS})},
	author = {Monish, Seelam and Varma, Nallaparaju Pranav and Nandini, D. Usha},
	month = mar,
	year = {2025},
	keywords = {Accuracy, CNN, Convolutional neural networks, Deepfakes, Fake, Feature extraction, Image analysis, Media, MobileNet, Prevention and mitigation, Real, Real-time systems, VGG16, Visualization},
	pages = {827--832},
}

@inproceedings{vaghchhipawala_voices_2025,
	title = {Voices of {Deception} - {Detecting} {AI}-{Synthesized} {Speech} {Using} {Spectrotemporal} {Features} and {Hybrid} {Learning} {Models}},
	doi = {10.1109/INDISCON66021.2025.11252158},
	abstract = {With the advent of highly realistic AIsynthesized voice, the risk of deepfake voices has increased immensely, giving rise to grave concerns in domains such as fraud, impersonation, and digital trust. There is a gap in reliable, real-time detection solutions since current detection systems typically fall short when faced with a variety of accents, speaker styles, or complex synthesis approaches. This work proposes a hybrid deepfake voice detection framework that merges both machine learning and deep learning techniques with spectrotemporal features. A tailor-made dataset was collected from three significant sources- actual speech from the Speech Accent Archive, artificially created samples using Google Text-to-Speech, and cloned voices from the DEEP-VOICE dataset. Mel-Frequency Cepstral Coefficients (MFCCs) were utilized to extract relevant features from each audio sample. Two models were created and tested: a Voting Classifier that merges SVM, Random Forest, and Gradient Boosting, and a CNN-LSTM deep learning model that is capable of learning spatial and temporal speech patterns. The two models were accurate and above 95 \% and were incorporated into a user-friendly Gradio web interface to test in real-time. The findings show that combining multiple approaches with robust audio features yields a scalable and efficient solution for AI-generated voice identification. The system is highly suitable for use in security, media authentication, voice-based verification, and fraud prevention online.},
	booktitle = {2025 {IEEE} 6th {India} {Council} {International} {Subsections} {Conference} ({INDISCON})},
	author = {Vaghchhipawala, Kaiwan and Nadkarni, Prathamesh and Pai, Ayush and Trivedi, Aditya and Bollavarapu, Swarnalata},
	month = aug,
	year = {2025},
	keywords = {audio forensics, CNN-LSTM, Deep learning, Deepfake audio, Deepfakes, Feature extraction, Fraud, MFCC, Random forests, real-time detection, Real-time systems, Reliability, Security, Text to speech, Usability, voice synthesis, Voting Classifier},
	pages = {1--6},
}

@inproceedings{badawy_secure_2025,
	title = {Secure and {Efficient} {AI} {Architectures} for {Real}-{Time} {Video} {Forensics}},
	doi = {10.1109/IC-FTAI67960.2025.11384131},
	abstract = {Real-time video manipulation detection and content authentication have emerged as critical challenges in the era of AI-generated media. The proliferation of deepfakes, adversarial attacks, and synthetic video content threatens information integrity and digital trust. In this paper, we propose VIDSEC-Net, a novel hybrid AI framework that integrates transformer-based vision encoders, adversarially trained classifiers, and spatiotemporal consistency models to detect manipulations in compressed, streamed, and archived video data. Unlike existing solutions, VIDSEC-Net is optimized for edge deployment and supports zero-trust environments through embedded cryptographic watermark validation and federated update mechanisms. We begin by formulating the mathematical problem of video tampering as a dynamic multivariate anomaly detection task across temporal frames and motion vectors. Our architecture leverages hierarchical attention across frame sequences, coupled with frequency-domain residual analysis, enabling high-precision detection even under post-processing or compression. The system is validated on multiple benchmark datasets (FaceForensics++, DeepfakeTIMIT, DFDC, and YouTube-Forensics) and demonstrates state-of-the-art performance in accuracy, F1-score, and adversarial robustness. In addition to performance metrics, we analyze VID-SEC-Net's real-time throughput on edge platforms (NVIDIA Jetson, Apple M1, Intel Movidius) and benchmark against transformer-lite and CNN baselines. Ethical implications, including potential misuse and dataset bias, are discussed, and we propose a set of deployment guidelines for privacy-preserving and trustworthy media verification. Our contributions offer a secure, scalable, and explainable AI-based solution for video forensics, setting the foundation for future research in trustaware media processing.},
	booktitle = {2025 {International} {Conference} on {Future} {Telecommunications} and {Artificial} {Intelligence} ({IC}-{FTAI})},
	author = {Badawy, Wael},
	month = nov,
	year = {2025},
	keywords = {adversarial robustness, AI video forensics, Artificial intelligence, cryptographic watermarking, Cryptography, deepfake detection, Deepfakes, edge deployment, ethical AI, Ethics, federated learning, Forensics, Image edge detection, Media, Real-time systems, transformer models, Transformers, Watermarking},
	pages = {1--9},
}

