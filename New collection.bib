}

@inproceedings{talasila_efficientnet_2025,
	title = {{EfficientNet} and {Vision} {Transformer} {Fusion} for {High}-{Precision} {Deepfake} {Image} {Identification}},
	doi = {10.1109/ICMNWC66779.2025.11354178},
	abstract = {The increasing menace of deepfake image content requires strong real-time detection mechanisms to ensure digital trust and avoid misinformation. This paper introduces a hybrid deep learning architecture that combines EfficientNet-B0 and Vision Transformer (ViT) to detect deepfakes with improved spatial and semantic feature extraction. The CNN part extracts fine-grained local textures, while the Transformer captures global relationships, allowing the model to detect subtle manipulations effectively. The outputs of both branches are fused and used as input to a fully connected classifier for binary classification. Experimental results indicate that the model has a high accuracy of 99.9\% during training, with validation accuracy plateauing at 98.52\% and test accuracy at 92.20\%, showing excellent generalization capability of the model. The system is further validated using real-time deployment in the form of a Flask-based web application for live webcam detection. This accurate hybrid model balances performance and precision, bringing a scalable and interpretable approach to the world of deepfake detection.},
	booktitle = {2025 5th {International} {Conference} on {Mobile} {Networks} and {Wireless} {Communications} ({ICMNWC})},
	author = {Talasila, Srinivas and Gurrala, Vijaya Kumar and Matta, Varshini and Musthyala, Madhuri and Balla, Siva Sai},
	month = dec,
	year = {2025},
	keywords = {Accuracy, Analytical models, CNN, Computer vision, deepfake detection, Deepfakes, efficientnet-b0, Feature extraction, Real-time systems, Training, Transformers, vision transformer, Webcams, Wireless communication},
	pages = {1--7},
}

@inproceedings{rs_facetrace_2025,
	title = {{FaceTrace}: {Leveraging} {Motion} {Patterns} for {Deepfake} {Video} {Authentication}},
	doi = {10.1109/APCIT65661.2025.11410621},
	abstract = {This paper presents a deep learning system for deepfake video detection based on a hybrid spatio-temporal model that integrates ResNeXt-50 and Long Short-Term Memory (LSTM) networks. Spatial features are extracted from face regions by a pretrained ResNeXt-50 CNN, while temporal evolution between video frames is modelled by LSTM layers. The system features a web-based interface built with Flask to enable the user to upload videos and dynamically manage the frame sampling rate. The system analyses input videos by cropping and detecting faces, extracting frames, and classifying content as Real or Fake based on temporal face inconsistencies. Prediction confidence scores are produced, and outputs are visualized in frame-wise bounding boxes and heatmaps. Experimental results demonstrate the model's high accuracy of 98.5\% and confidence for real-time deepfake detection. This approach demonstrates the effectiveness of combining convolutional and recurrent neural networks for tackling video-based forgery detection tasks.},
	booktitle = {2025 2nd {Asia} {Pacific} {Conference} on {Innovation} in {Technology} ({APCIT})},
	author = {RS, Ramya and Narayankar, Karuna},
	month = sep,
	year = {2025},
	keywords = {Accuracy, Deepfake Detection, Deepfakes, Face recognition, Face Recognition, Feature extraction, Flask Interface, Forgery, Heating systems, Long Short Term, Long short term memory, Real-time systems, Recurrent neural networks, Spatio-Temporal Learning, Visualization},
	pages = {1--4},
}

@inproceedings{mangalampalli_cnn_2025,
	title = {A {CNN} {Algorithm} {Based} {DeepFake} {Detection} {System}},
	doi = {10.23919/INDIACom66777.2025.11115232},
	abstract = {DeepFake is a technology that has garnered significant attention in the modern world and is often used for unlawful and immoral practices. The consequences and aftereffects of generation and publication of deepfakes in the public domain can tamper the social image of organizations or individuals. The objective of this study is to find a solution to this upcoming societal horror which can ruin lives and stigmatize the affected individuals. This project mainly concentrated on the development of a DeepFake Detection model that leverages a custom Convolutional Neural Network (CNN) to identify facemanipulated images or video content by extracting frames from images or videos. The model achieved high accuracy in demonstration of effectiveness of custom CNN architecture in identification of subtle facial inconsistencies and performed robustly across the dataset which highlighted the capability for generalization and detection of face-manipulated content in images and videos, alike. In essence, this CNN model stands out as a comprehensive solution not only addressing and amending the challenges faced by current systems but also enables people to be alert. This research serves as a foundational step towards the development of robust and scalable solutions to effectively counter DeepFake technology.},
	booktitle = {2025 12th {International} {Conference} on {Computing} for {Sustainable} {Global} {Development} ({INDIACom})},
	author = {Mangalampalli, Swapnil Mohan and Mistry, Meetkumar Jitendrakumar and Pal, Aditya Manoj and Pereira, Janisa},
