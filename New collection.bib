@inproceedings{jayanth_sai_chethan_development_2025,
	title = {Development of {AI}/{ML}-based solution for detection of face-swap based deepfake videos and {AI}-generated videos},
	doi = {10.1109/InC465408.2025.11256330},
	abstract = {The increasing sophistication of deep learning techniques has led to a surge in hyper-realistic deepfake videos and AI-generated media, raising significant concerns about digital security, privacy, and content integrity. Addressing this challenge, we propose an advanced AI/ML-based framework for detecting manipulated media with high precision. Our approach integrates Convolutional Neural Networks (CNNs) for spatial feature extraction, Long Short-Term Memory (LSTM) networks for capturing temporal inconsistencies, and transformer architectures, such as Vision Transformers (ViTs), for enhanced feature extraction. To enhance model robustness, we employ transfer learning and ensemble learning, training on comprehensive datasets such as FaceForensics++, Celeb-DF, and the Deepfake Detection Challenge (DFDC). Our system achieves an accuracy of 95 \% while maintaining a low false positive rate, demonstrating superior generalizability across different compression levels and deepfake creation techniques. Beyond detection, this research has crucial implications for digital forensics, misinformation mitigation, and automated content moderation. Future enhancements will focus on multimodal detection, incorporating audio analysis and efficiency optimizations for real-time applications.},
	booktitle = {2025 {IEEE} {International} {Conference} on {Contemporary} {Computing} and {Communications} ({InC4})},
	author = {Jayanth Sai Chethan, S and Chand, Jayant and Bhakta, Kedarnath and Bhai, Meet Joshi Kamlesh and Piruthiviraj, P},
	month = mar,
	year = {2025},
	keywords = {AI-Generated Video Detection, Computer architecture, Convolutional Neural Network (CNN), Convolutional neural networks, Deepfake Video Detection, Deepfakes, Feature extraction, Long short term memory, Recurrent Neural Network (RNN), Recurrent neural networks, Surges, Training, Transfer learning, Transformers},
	pages = {1--6},
}

@inproceedings{stephy_joy_lightweight_2025,
	title = {Lightweight and {Accurate}: {Deepfake} {Detection} using {Binary} {Neural} {Networks} and {Vision} {Transformer}},
	doi = {10.1109/ICSCC66177.2025.11233324},
	abstract = {The challenge of defending digital media authenticity has become critical because deep learning methods continue to improve their production of realistic forgeries. Current state-of-the-art detection systems require deep architectures together with substantial parameter count but do not work well for real-time or resource-limited situations. This work presents an efficient deepfake detection system based on 1-bit Binary Neural Networks and DWT features together with HOG and ViT backbone features. The detection method draws from DWT frequency-domain and HOG texture-domain features to reveal artifact patterns that synthetic models fail to recognize. Globally distributed modifications require the ViT backbone to detect entire spatial patterns due to its ability to capture distant context. Our proposed system reaches near state-of-the-art or state-of-the-art detection accuracy on the DFDC and OpenForensics datasets using substantially less computational resources than standard full-precision neural networks. The system maintains excellent detection capabilities against complex forgeries because it merges quantized classification with enhanced multi-domain features. The obtained results demonstrate BNN-based quantization as an effective solution for deepfake detectors which enables real-time operation on regular consumer-grade devices.},
	booktitle = {2025 11th {International} {Conference} on {Smart} {Computing} and {Communications} ({ICSCC})},
	author = {Stephy Joy, D and Selvi, R Thirumalai},
	month = jul,
	year = {2025},
	keywords = {Binary Neural Networks (BNNs), Computational modeling, Deepfake detection, Deepfakes, Discrete Wavelet Transform (DWT), Discrete wavelet transforms, Feature extraction, Forgery, Histogram of Oriented Gradients (HOG), Histograms, Neural networks, Real-time systems, Transformers, Transforms, Vision Transformers (ViT)},
	pages = {1--5},
}

@inproceedings{mohamed_hyperparameter_2025,
	title = {Hyperparameter {Optimization} for {Deepfake} {Detection} {Improving} {CNN} and {Transformer} {Performance} {Using} {Bayesian} {Search}},
	doi = {10.1109/ICMI65310.2025.11141060},
	abstract = {We provide an extensive study of hyperparameter optimization for CNN and Transformer models using the deepfake detection problem. We will use Optuna for Hyperparameter Tuning with Bayesian optimization in which we will tune some important parameters (dropout rate, learning rate, optimizer type). Experiments are performed with a real and fake image dataset extracted from video clips. We evaluate the optimized models in terms of accuracy, precision, recall, F1-score, and ROC-AUC metrics. With hyperparameter discovered by bayesian search, the Transformer model presta the best performance where it attained 94\% accuracy and 0.94 AUC compare to optimized CNN for which we get 90\% accuracy, 0.89 AUC. Moreover, we observe that Transformer has a better recall to identify fake videos (96\% vs 83\% for CNN), indicating its robustness in identifying deepfakes. In conclusion, the proposed framework for hyperparameter optimization can be a valuable addition to the growing body of research aimed at developing robust and effective models for deepfake detection.},
	booktitle = {2025 {IEEE} 4th {International} {Conference} on {Computing} and {Machine} {Intelligence} ({ICMI})},
	author = {Mohamed, Khadeja M. and Skaiky, Ahmad Ali and Shukur Ali, Hanan Mahmood and Mohammed, Aymen and Mahdi, Zalzala Ali},
	month = apr,
	year = {2025},
	keywords = {Accuracy, Bayes methods, Bayesian search, CNN, Computer architecture, Deepfake detection, Deepfakes, Hyperparameter optimization, Machine learning, Optimization, Optuna, Real-time systems, Robustness, Transformer, Transformers, Tuning},
	pages = {1--6},
}

@inproceedings{chen_spatio-_2024,
	title = {A {Spatio}- {Temporl} {Deepfake} {Video} {Detection} {Method} {Based} on {TimeSformer}-{CNN}},
	doi = {10.1109/ICDCECE60827.2024.10549278},
	abstract = {In order to improve the accuracy of real-time deepFake video detection, this paper proposes a method based on the EfficientNet-TimeSformer model. Firstly, we use the transfer Xi method to use a pre-trained convolutional network for spatial feature extraction, and introduce a lightweight network for exploration, with an accuracy of 95.26\% and an AUC of 95.52, which is very impressive. At the same time, the trainable parameters of the model are only 5,234,124, which is significantly higher than that of other models. Then, we optimize the model through data augmentation such as pre-training and dataset sizing to accommodate larger image sizes and longer video input sequences, so as to enhance the model's ability to process complex video data. The empirical results show that our model performs well in high-resolution videos and longer video sequences, significantly outperforming the performance of traditional convolutional neural networks, taking into account GPU memory limitations. At the same time, some limitations in the study are noted, such as the failure to test video clips longer than 96 frames and some limitations on the Celeb-DF dataset. Future research directions include in-depth research on the interpretability and generalizability of the model, as well as verifying its performance in a wider range of application scenarios.},
	booktitle = {2024 {Third} {International} {Conference} on {Distributed} {Computing} and {Electrical} {Circuits} and {Electronics} ({ICDCECE})},
	author = {Chen, Zhengxuan and Wang, Shuo and Yan, Deyang and Li, Yushi},
	month = apr,
	year = {2024},
	keywords = {Data models, deepfake, Deepfakes, efficientnet-timesformer network, Graphics processing units, lightweight, real-time detection, Real-time systems, Robustness, Streaming media, Video sequences},
	pages = {1--6},
}

@inproceedings{tauseef_deepfaceguard_2025,
	title = {Deepfaceguard: {A} {Lightweight} {CNN} {Framework} for {Robust} {Face} {Manipulation} {Detection}},
	doi = {10.1109/NMITCON65824.2025.11188219},
	abstract = {The rapid proliferation of deep-fake technology threatens the credibility of digital media, with face-swap deep fakes posing significant detection challenges due to their high visual fidelity. This paper presents Deep Faceguard, a lightweight CNN-based deepfake detection framework optimized for high accuracy, cross-dataset generalization, and real-time edge deployment. Unlike prior models limited to single-dataset performance, Deep Faceguard integrates transfer learning with Efficient Net and XceptionNet backbones, combined with OpenCV-based facial region alignment to enhance artifact localization. The system effectively detects subtle manipulation artifacts such as illumination inconsistencies, blending anomalies, and edge discontinuities. Trained on FaceForensics ++ and DFDC, it achieves 96.5 \% accuracy, 95.8 \% precision, 97.2 \% recall, and a ROC AUC of 0.982, while cross-dataset testing yields 88.2 \% accuracy, indicating robustness to domain shift. Optimized via TensorFlow Lite, Deep Faceguard sustains 45 FPS real-time inference and reduces the model size by 40 \% without accuracy loss, making it suitable for scalable and deployment-ready deepfake detection applications.},
	booktitle = {2025 {Third} {International} {Conference} on {Networks}, {Multimedia} and {Information} {Technology} ({NMITCON})},
	author = {Tauseef, Md. and Viji, Lena Sosa and Fenwick, Janice},
	month = aug,
	year = {2025},
	keywords = {Accuracy, Convolutional Neural Net works (CNNs), Convolutional neural networks, cross-dataset generalization, Deepfake detection, Deepfakes, digital media forensics, edge deployment, face-swap manipulation, Image edge detection, Media, real-time infer ence, Real-time systems, Robustness, TensorFlow Lite, Testing, Transfer learning, Visualization},
	pages = {1--6},
}

@inproceedings{panja_multimodal_2025,
	title = {Multimodal {Framework} for {Deep} {Fake} {Detection} and {Content} {Moderation} {Using} {CNN}, {ViT}, and {Audio}-{Visual} {Analysis}},
	doi = {10.1109/CIACON65473.2025.11189412},
	abstract = {This paper presents a multimodal framework for deepfake detection and content moderation, integrating audio, video, and text analysis to improve detection accuracy and robustness. The framework consists of seven key components: audio extraction, deepfake detection using CNN, audiovisual deepfake detection, metadata and caption extraction, advanced feature extraction using CNN and ViT, text-to-speech transcription in Bengali, and hate speech detection from images. Audio and video features extracted using CNN and ViT are combined to compute a probabilistic score for deepfake detection, while OCR and NLP models analyze transcribed text for hate speech. The system is designed for real-time multimedia analysis, making it suitable for social media content moderation, forensic investigations, and misinformation detection. Experimental evaluations on benchmark datasets such as Celeb-Df, and DFDC demonstrate high detection accuracy, outperforming traditional single-modal approaches. The framework is optimized for scalability and efficiency, enabling large-scale multimedia analysis with minimal latency. By integrating advanced video processing, speech analysis, and text recognition, this work contributes to multimodal AI research, offering a comprehensive and scalable solution for detecting manipulated media and ensuring digital content integrity in real-world applications.},
	booktitle = {2025 {International} {Conference} on {Computing}, {Intelligence}, and {Application} ({CIACON})},
	author = {Panja, Anoushka and Chakravorty, Debamalya and Das, Arijit and Saha, Diganta},
	month = jul,
	year = {2025},
	keywords = {Accuracy, Bengali speech-to-text, CNN, Content moderation, Deep fake detection, Deepfakes, Feature extraction, Multimedia systems, Multimodal analysis, OCR, Optical character recognition, Robustness, Speech to text, Streaming media, Text recognition, Transformers, Vision Transformers},
	pages = {1--5},
}

@inproceedings{vardhini_deep_2025,
	title = {Deep {Guard}: {A} {Multi}-{Modal} {Ensemble} {Deep} {Learning} {Framework} for {Real}-{Time} {Deepfake} {Detection} and {Proactive} {Content} {Authentication}},
	doi = {10.1109/ICAAIC64647.2025.11330928},
	abstract = {The availability of high-tech deepfake tools creates new challenges to the integrity of digital content, and it is necessary to establish a detection and mitigation framework capable of handling more sophisticated technology. This research proposes a multi-level architecture of deepfake detection and mitigation that incorporates the most current Machine Learning (ML) models with the new forensic methods. The proposed approach plans a four-stage detection pipeline: preprocessing and feature extraction with MobileNetV3 and EfficientNet-B4 to analyze spatial information, a fusion-based classifier using ensemble classification combining XceptionNet, ResNet-50, and vision transformers, and mitigation by completing an adversarial training using GANs. The preprocessing step uses noise reduction and state-of-the-art algorithms of face alignment to normalize the input data. Feature extraction is a hybrid application that employs both computer vision methods and Deep Learning (DL) that extract low-level artifact features and high-level semantic features. The proposed DeepGuard employs the strategy of a weighted ensemble, which uses the results of several hyper-specific models to reach a higher precision level. Moreover, the mitigation phase uses preventative-like watermarking with strong steganographic practices and reactive-like filtering of content-based tracking. Experimental validations on Celeb-DF datasets have shown that it compares to the performance of other existing methods in that the proposed method achieves a detection accuracy of 98.8\% with minimized false positives.},
	booktitle = {2025 4th {International} {Conference} on {Applied} {Artificial} {Intelligence} and {Computing} ({ICAAIC})},
	author = {Vardhini, Kondra Megha Nandi and Parthipan, V},
	month = dec,
	year = {2025},
	keywords = {Accuracy, Computer vision, Deep learning, Deepfake Detection, Deepfakes, Ensemble Learning, Feature extraction, Pipelines, Prevention and mitigation, Real-Time Analysis, Real-time systems, Transformers, Watermarking},
	pages = {353--359},
}

@inproceedings{ali_dual-filter_2025,
	title = {Dual-{Filter} {Based} {Deepfake} {Detection} {Using} {CNN} and {Vision} {Transformer}},
	issn = {2831-3844},
	doi = {10.1109/ICSPIS67605.2025.11318378},
	abstract = {This study introduces a novel deepfake detection framework that leverages Laplacian and Hessian image filters as a dual-channel input, shifting the focus from raw RGB pixels to structural and texture-level inconsistencies often hidden to the human eye. By emphasizing edges and fine-grained anomalies, the approach enhances the interpretability of learned features while reducing reliance on superficial color patterns. Two architectures are explored: a custom Convolutional Neural Network (CNN), which captures localized edge irregularities, and a Vision Transformer (ViT), adapted to process filtered dual-channel representations through its attention-driven mechanism. Both models were trained and tested under identical conditions, ensuring a fair evaluation. The CNN achieved a strong accuracy of approximately 77\%, though it struggled in cases of subtle manipulations, while the ViT delivered superior performance with nearly 80\% accuracy, showing greater resilience against ambiguous forgeries. By combining explainable filter-based preprocessing with advanced transformer-based learning, this study offers a pathway toward detection methods that remain robust even as manipulation techniques continue to evolve.},
	booktitle = {2025 8th {International} {Conference} on {Signal} {Processing} and {Information} {Security} ({ICSPIS})},
	author = {Ali, Aashna and M, Ankitha and Vanamala, H R},
	month = nov,
	year = {2025},
	keywords = {Accuracy, Computer vision, convolutional neural networks, Convolutional neural networks, Deepfake detection, Deepfakes, dual-channel input, Filters, Hessian filter, Image Forensics, Laplace equations, Laplacian filter, Three-dimensional displays, Topology, Transformers, Video sequences, vision transformer},
	pages = {1--6},
}

@inproceedings{anitha_robust_2025,
	title = {A {Robust} {Deepfake} {Detection} {Framework} {Using} {AV}-{CATNet} for {Audio}-{Visual} {Consistency} and {Temporal} {Attention} in {Secure} {Social} {Media} {Authentication}},
	doi = {10.1109/ICERECT65215.2025.11378357},
	abstract = {The swift evolution of deepfakes with significant implications on the credibility of multimedia content in social media provides us with a stern challenge. Current detection strategies are typically inadequate in modeling cross-modal inconsistency and temporal information. To this end, we introduce AV-CATNet (Audio-Visual Cross-Attentional Transformer Network), which is an innovative deepfake detection system that utilizes cross-modal attention to synchronize lip movement with audio and temporal self-attention to detect sequence anomalies. AV-CATNet proposes the Fake Consistency Score (FCS), a transparent metric measuring the synchronization of audio and visual streams throughout history, making the model more transparent. In contrast to existing CNN, RNN, or late-fusion AV models, AV-CATNet reaches up to 97\% accuracy on standard datasets such as DFDC, FakeAVCeleb, and FaceForensics++. It has an end-to-end attention-based fusion mechanism without the requirement for handcrafted features or post-processing. Designed to be optimized for real-time execution and edge deployment, AV-CATNet is a robust and scalable platform for content authentication, multimedia forensics, and deepfake defense in high-throughput social media scenarios.},
	booktitle = {2025 5th {International} {Conference} on {Emerging} {Research} in {Electronics}, {Computer} {Science} and {Technology} ({ICERECT})},
	author = {Anitha, G. and V, Aakash Saran and Loganathan, Nadish and R K, Arul Saravanan},
	month = sep,
	year = {2025},
	keywords = {Accuracy, audio-visual consistency, Authentication, AV-CATNet, Benchmark testing, content authentication, cross-modal learning, Deepfake detection, Deepfakes, fake consistency score(FCS), Forensics, multimedia forensics, real-time detection, Real-time systems, social media safety, Social networking (online), Synchronization, temporal attention, transformer networks, Transformers, Visualization},
	pages = {1--6},
}

