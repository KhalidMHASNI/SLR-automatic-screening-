@inproceedings{sato_artificial_2025,
	title = {Artificial {Intelligence} {Synthetic} {Image} {Detection} {Using} {Ensemble} {Convolutional} {Neural} {Network} {Model}},
	doi = {10.1109/ICORIS67789.2025.11296123},
	abstract = {Artificial intelligence has advanced rapidly in recent years, particularly in image generation, producing highly realistic synthetic images that are difficult to distinguish from their real counterparts. While such technology has practical benefits, it also poses risks, including the spread of misinformation and identity theft. This study addresses these concerns by proposing an ensemble Convolutional Neural Network (CNN) model for synthetic image detection. Unlike individual CNNs, the ensemble approach integrates multiple feature extraction techniques to improve robustness and accuracy. Using the CIFAKE dataset of real and AI-generated images, the ensemble CNN achieved superior performance compared to single architectures. Experimental results show that the ensemble model reached an accuracy of 98.04\%, with a precision of 98\% and ROC-AUC of 0.998, outperforming ResNet (96.15\%), RegNet (97.05\%), and DenseNet (97.48\%). These findings highlight the effectiveness of ensemble learning in identifying AI-generated content and underscore its potential for strengthening digital security and safeguarding social media integrity through real-time detection systems.},
	booktitle = {2025 7th {International} {Conference} on {Cybernetics} and {Intelligent} {System} ({ICORIS})},
	author = {Sato, Tohru Djunaedi and Kharis Wijaya Wong, Yoel and Arlinton, Theona and Jabar, Bakti Amirul and Moniaga, Jurike V.},
	month = sep,
	year = {2025},
	keywords = {Accuracy, Artificial Intelligence, Convolutional neural networks, Deepfakes, Digital Security, Ensemble CNN, Ensemble learning, Generative AI, Robustness, Security, Synthetic Image, Testing, Training, Visualization},
	pages = {1--6},
}

@inproceedings{tufchi_advanced_2024,
