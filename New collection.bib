	keywords = {Adaptation models, CNN and LSTM, Deepfake detection, Deepfakes, DNN, Feature extraction, Long short term memory, ML, Real-time systems, Robustness, Social networking (online), Training, Transformers, Visualization},
	pages = {1616--1622},
}

@inproceedings{thatipamula_deepfake_2025,
	title = {Deepfake {Hunter}: {A} {Multimodal} {Detection} {Framework}},
	issn = {2831-5022},
	doi = {10.1109/PuneCon67554.2025.11378295},
	abstract = {Deepfakes represent a growing challenge in digital forensics, as they generate highly convincing synthetic audiovisual content using deep learning models. While these technologies have legitimate applications in media production and accessibility, their misuse for misinformation, identity manipulation, and privacy breaches raises serious concerns. This work introduces Deepfake Hunter, a systems-engineered multimodal detection framework designed to ensure reliability, interpretability, and scalable deployment. The proposed architecture integrates three complementary modules: (1) a visual encoder based on XceptionNet to extract spatial inconsistencies, (2) an audio encoder utilizing InceptionResNetV2 on Constant-Q Transform (CQT) spectrograms for spectral analysis, and (3) an attention- driven recurrent unit to capture temporal coherence. The system emphasizes modular interfaces between preprocessing, feature extraction, fusion, and classification layers, supporting deployment across both cloud and edge environments. Experiments on benchmark datasets Face Forensics++, CelebDF, DFDC, and Fake AV Cele demonstrate that Deepfake Hunter achieves superior accuracy and robustness compared with unimodal detectors, highlighting its potential as a dependable framework for real- world multimedia authenticity verification.},
	booktitle = {2025 {IEEE} {Pune} {Section} {International} {Conference} ({PuneCon})},
	author = {Thatipamula, Ajay and Patidar, Mukesh and Gandi, Mukesh and Nandayala, Lila Shankar Naidu and Kommula, Datta Sai Krishna and Dontha, Vishnu Vardhan},
	month = dec,
	year = {2025},
	keywords = {Benchmark testing, CNN, CQT, Deepfake detection, Deepfakes, Faces, Feature extraction, GRU, InceptionResNetV2, multimodal fusion, Resistance, RNN, Robustness, Spectral analysis, Spectrogram, Transforms, Visualization, XceptionNet},
	pages = {1--6},
}

@inproceedings{t_m_detecting_2025,
	title = {Detecting {Deepfakes} using {ConvNeXt} and {TimeSformer}},
	doi = {10.1109/GCAT66372.2025.11368376},
	abstract = {Deepfakes, synthetic media generated using deep learning, pose serious threats to privacy, security, and public trust. Hence, suitable detection methods are required to combat them. This project aims to tackle the limitations of current methods by presenting a deep learning-based approach to detect deepfakes. Leveraging transfer learning, a pre-trained ConvNext model performs feature extraction to discern subtle, spatial artifacts within individual frames. In parallel, a TimeSformer model is employed to analyze video clips, enabling the detection of temporal inconsistencies and motion artifacts that single-frame methods miss. To provide a conclusive video verdict, clip-level predictions are aggregated, while Gradient-weighted Class Activation Mapping (Grad-CAM) and LIME (Local Interpretable Model-agnostic Explanations) visualizations are used to visualize the model's decision process for transparency. We enhance generalization by training on diverse datasets and fine-tuning with augmented examples. Moreover, MediaPipe framework is used for high-speed face extraction to reduce the prediction time for real-time applications. This solution contributes to the development of powerful systems for detecting manipulated media.},
	booktitle = {2025 {IEEE} 6th {Global} {Conference} for {Advancement} in {Technology} ({GCAT})},
	author = {T M, Rajesh and Dhangi, Shravankumar},
	month = oct,
	year = {2025},
	keywords = {Accuracy, ConvNext, Deep learning, Deep Learning, Deepfake Detection, Deepfakes, Explainable AI (XAI), Faces, Media, Predictive models, Real-time Detection, Real-time systems, Temporal Analysis, TimeSformer, Transfer learning, Transfer Learning, Transformers, Vision Transformer, Visualization},
	pages = {1--6},
}

@inproceedings{dash_optimizing_2025,
	title = {Optimizing the {Biometric} {Authentication} {Scheme} to {Detect} the {Deepfake} in {Real} {Time} {Using} {GAN}},
	doi = {10.1109/ICWITE64848.2025.11307102},
	abstract = {In today's technology, the impact of deepfake in society is huge and major cause of security concern. So many people have been affected with mental disorder as well as social reputation. Further, few people make suicide without informing the same to cybercrime personals. The proliferation of deepfake technologies poses significant threats to digital authenticity. Several systems use machine learning and deep learning to combat deepfakes, including CNNs for spatial analysis and RNNs or LSTMs for temporal inconsistencies. Methods like audio-visual mismatches, forensic pixel analysis, and pre-trained models such as XceptionNet and Capsule Networks show promise but face challenges like slow processing, limited dataset diversity, and susceptibility to adversarial attacks. This work introduces an advanced system optimized to identify deepfake manipulations by utilizing Generative Adversarial Networks (GANs). The model is designed to strengthen biometric authentication by distinguishing genuine and fake identities through enhanced image and video analysis techniques. By leveraging the adversarial architecture of GANs, the system learns to detect subtle anomalies that indicate deepfake artifacts. The solution integrates seamlessly into existing security frameworks, providing real-time processing and a user-friendly interface for immediate verification. Extensive testing and feedback will refine the system's accuracy and robustness. The ultimate goal is to ensure secure and reliable authentication systems that can effectively mitigate deepfake-related threats, validated through metrics like detection rate, processing speed, and resilience to adversarial attacks.},
	booktitle = {2025 {IEEE} {International} {Conference} for {Women} in {Innovation}, {Technology} \& {Entrepreneurship} ({ICWITE})},
	author = {Dash, Manoranjan and Reddy, A Mallikarjuna and Pulapa, Deekshitha and Kodakandla, Varshini and Gavini, Kavya},
	month = sep,
	year = {2025},
	keywords = {Analytical models, Biological system modeling, Biometric authentication, Biometric Authentication, Deepfake Detection, Deepfakes, Generative adversarial networks, Generative Adversarial Networks, Real-Time, Real-time systems, Resilience, Robustness, Security, Testing},
	pages = {1--6},
}

@inproceedings{pradeepan_lightweight_2025,
	title = {A {Lightweight} {Deep} {Learning} {Framework} for {Real}-time {Detection} of {Deepfake} {Medical} {Images}},
	doi = {10.1109/AMATHE65477.2025.11081304},
	abstract = {Medical images require authentic verification for accurate diagnosis and treatment planning. The increasing availability of image manipulation tools poses significant challenges and threats to medical imaging. This paper presents a lightweight, deep-learning-based framework for the detection of deepfake medical images. The proposed model integrates the MobileNetV2 architecture with an efficient channel attention (ECA) module to enhance performance. The ECA module was integrated after the expansion layers of the MobileNetV2 network to improve the feature extraction by adjusting the channel-wise representations. This enhanced the ability of the proposed model to capture fine-grained details and subtle inconsistencies. The suggested method was assessed using the CT-GAN benchmark dataset. Results from the experiments showed that this proposed method achieved an accuracy of 99.81 and a precision of 99.80. These results demonstrate that the proposed model can easily detect small modifications in the medical images. The lightweight design makes the proposed approach suitable for real-world medical image analysis and ensures the authenticity of medical images.},
	booktitle = {2025 {International} {Conference} on {Advances} in {Modern} {Age} {Technologies} for {Health} and {Engineering} {Science} ({AMATHE})},
	author = {Pradeepan, P and Gladston Raj, S and George, Juby},
	month = apr,
	year = {2025},
	keywords = {Accuracy, Computational efficiency, Computer architecture, Deep learning, Deepfakes, Efficient Channel Attention (ECA), Lightweight Deep Learning, Medical Deepfake Detection, Medical diagnostic imaging, Medical imaging, Real-time systems, Reliability, Security, Training},
	pages = {1--6},
}

@inproceedings{v_hybrid_2025,
	title = {A {Hybrid} {EfficientNet}-{TSM} {Framework} for {Deepfake} {Detection} in {Digital} {Media} {Content}},
	doi = {10.1109/ICSCN67106.2025.11308434},
	abstract = {Deepfakes are an increasing concern for privacy, trust and security of digital media since they make it possible to create high-fidelity but fake content. We propose a Hybrid EfficientNet-Temporal Shift Module TSM framework which can learn spatial and temporal features to improve the detection of deepfakes in images and videos. EfficientNet is able to capture subtle visual artifacts in manipulated images, while TSM captures motion inconsistencies across video frames in a lightweight and efficient way. We also use Grad-CAM to enhance interpretability by visualizing regions of an image or video that contributed to a classification decision and shows how the model is processing manipulated content. Our experiments demonstrate that our framework achieves higher accuracy, scalability, and robustness than traditional CNN–RNN methods, while supporting forensic use through its efficiency, interpretability, and ability to strengthen trust in digital media to promote user trust.},
	booktitle = {2025 {International} {Conference} on {Sustainable} {Communication} {Networks} and {Application} ({ICSCN})},
	author = {V, Pooja S and D, Keerthika and Subbalakshmi, S. and Sangeetha, V.},
