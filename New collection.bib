@inproceedings{k_hybrid-cnn_2025,
	title = {Hybrid-{CNN} {Classifier} for {Fake} {News} {Detection}: a {Multimodal} {Defense} {Against} {Digital} {Misinformation}},
	doi = {10.1109/ICNSoC66817.2025.00024},
	abstract = {The widespread circulation of false information through digital media presents a significant challenge to public confidence, societal harmony, and informed decision-making. To tackle this issue, this work proposes a dual-input fake news detection framework that leverages both textual and imagebased analysis for improved performance and trustworthiness. Central to the system is a Hybrid-CNN model that extracts features from text using convolutional layers and subsequently classifies them using Support Vector Machines (SVM) and Naive Bayes algorithms, enhancing classification precision. Alongside, a Transformer-based image analysis module is incorporated to detect manipulated or deceptive visuals frequently used in misleading content. These components operate independently, enabling accurate assessment of both text and images, thereby ensuring adaptability across content types. Offered as an online application, the platform allows users to verify the credibility of news through text or image submissions in real time. By analyzing both linguistic patterns and visual elements, the system achieves higher accuracy in identifying misinformation. Experimental results highlight the effectiveness of the proposed solution, which provides a resilient and scalable approach to addressing the proliferation of fake news in the current digital ecosystem.},
	booktitle = {2025 {Second} {International} {Conference} on {Networks} and {Soft} {Computing} ({ICNSoC})},
	author = {K, Sekar and Vijayaraghavan, Jayashrinidhi and G, Shruthi and S, Sri Balaji and S, Ranjith Kumar and P, Subhash},
	month = jun,
	year = {2025},
	keywords = {Accuracy, CNN, Fake news, Feature extraction, Misinformation detection, Naive Bayes classifier, Naive Bayes methods, Real-time systems, Support vector machines, SVM, Training, Transformer-based models, Transformers, Videos, Visualization},
	pages = {1--6},
}

@inproceedings{srikanth_hybrid_2025,
	title = {A {Hybrid} {Intelligence} {Framework} for {EmotionAware} {Deepfake} {Detection} and {Misinformation} {Risk} {Reduction}},
	doi = {10.1109/ICEAMST67459.2025.11335615},
	abstract = {The development of deepfakes has accelerated to increase the rates of misinformation, emotional control, and loss of digital trust. The current detection systems mainly aim at seeing or hearing something incongruent and overlook the emotional aspect that compounds psychological and social damage. To fill this gap, a Hybrid Intelligence Framework of Emotion-Aware Deepfake Detection and Misinformation Risk Reduction based on deep learning, affective computing, and explainable AI is proposed in this study. The framework is a combination of spectral spatial forensic, linguistic sentiment, and physiological emotion characteristics via a transformerdirected multimodal fusion network. The hybrid CNN BiLSTM framework structures spatial forgery localizations and emotional pathway dynamics, which are optimized through adaptive gradient control and attention-guided calibration. The experimental performance on multimodal deepfake datasets shows that the system detects correctly 96.4\% with 0.97 AUC and a false emotional trigger rate is reduced by 21 percent over the state-of-the-art systems, which were correspondingly statistically significant ({\textbackslash}mathbfpłt0.05). The proposed model increases interpretability, stronghold, and ethical online management through the detection of emotionally manipulative synthetic media and the measurement of the risk of misinformation, which provides a starting point to acquire emotion-stable and reliable AI systems.},
	booktitle = {2025 {Third} {International} {Conference} on {Emerging} {Applications} of {Material} {Science} and {Technology} ({ICEAMST})},
	author = {Srikanth, M. and Niharika, Vatala and Govardhani, Koppisetti and Lallisri, Peddireddi and Nandini, Vegesna and Kumar, Jmsv Ravi},
	month = nov,
	year = {2025},
	keywords = {Bidirectional long short term memory, Deep learning, Deepfake Detection, Deepfakes, Emotion-Aware AI, Explainable AI, Explainable Deep Learning, Hybrid Intelligence, Misinformation Risk, Quantization (signal), Real-time systems, Resilience, Robustness, Social networking (online), Transformer Fusion, Transformers},
	pages = {1084--1090},
}

@inproceedings{p_deepfakeshield_2026,
	title = {{DeepFakeShield}: {AI}-{Based} {Detection} of {Deepfake} {Videos} and {Synthetic} {Media}},
	doi = {10.1109/IITCEE67948.2026.11394363},
	abstract = {The advancement of deep generative models has enabled the creation of highly realistic manipulated videos, commonly referred to as deepfakes, which pose unprecedented threats to digital security, media credibility, and public trust. As these synthetic media artifacts become more convincing, traditional detection methods are proving inadequate, creating an urgent need for advanced and explainable AI-driven approaches. With generative models producing increasingly realistic manipulations, conventional detection methods are no longer sufficient. To address this challenge, we introduce DeepFakeShield, an AI-based detection framework that integrates deep learning architectures with explainability mechanisms for reliable and transparent identification of manipulated videos. Unlike conventional binary classifiers, DeepFakeShield places strong emphasis on interpretability, ensuring that outputs can be justified and trusted in legal, investigative, and journalistic contexts. By focusing on the temporal coherence of lip movements, spatial consistency of facial features, and detection of low-level artifacts, the framework provides a multi-layered defense against both lowquality and highly sophisticated deepfake attacks. Furthermore, its modular design supports adaptability across various media formats and deployment environments, ranging from digital forensic laboratories to real-time social media monitoring pipelines. The inclusion of explainability mechanisms not only improves accountability but also empowers human analysts to verify AI decisions, thereby bridging the gap between automation and expert validation. Extensive evaluations demonstrate that the system achieves high accuracy in distinguishing authentic videos from manipulated ones while maintaining computational efficiency suitable for large-scale deployment. With its modular architecture and explainabilitydriven design, DeepFakeShield provides not only automated detection but also transparent reasoning, enabling effective defense against synthetic media and contributing to the preservation of content authenticity in an era of AI-driven misinformation.},
	booktitle = {2026 {International} {Conference} on {Intelligent} and {Innovative} {Technologies} in {Computing}, {Electrical} and {Electronics} ({IITCEE})},
	author = {P, Kumar and Ramya, S. Thanga and Paul, T Sam and S, Senthil Pandi},
	month = jan,
	year = {2026},
	keywords = {Accuracy, Authentication, Autoencoder, Autoencoders, Benchmark testing, Computer architecture, DeepFake Detection, Deepfakes, Digital forensics, Digital Forensics, Explainable AI, Facial Landmark Tracking, Grad-CAM, Media Authentication, Pipelines, Real-time systems, Spatiotemporal CNN, Spatiotemporal phenomena, Synthetic Media},
	pages = {1--6},
}

@inproceedings{datta_real-time_2021,
	title = {Real-{Time} {Face} {Swapping} {System} using {OpenCV}},
	doi = {10.1109/ICIRCA51532.2021.9545010},
	abstract = {Face swapping has been a thriving genre of work which primarily is associated with the replacement or substitution of one referral face on the face of the other person, be it by means of still images or in real time. This paper exhibits the research on Real-Time Face Swapping algorithm, using the reference image of the user and henceforth considering it as our input image instead of using a data set thereby working on a real time model by the use of the python open-source model of Computer Vision i.e., OpenCV. The input image facial features and attributes are extracted and are replaced to make the final resulting output through our model. The training of the model starts with learning the facial alignments and features to be able to recognize a face and extract its features before swapping it. Now, heading over to the process of image warping by the dissociation and partitioning of the user's face and its background. To increase the precision of the model, in the second part of parsing the face is performed to cancel out other features of the live image, hence the output is obtained. In this research, it was tried to bring accuracy and precision to the model by improving the condition of the image, editing out borders, and training it to a bunch of data for face recognition and correction. On analyzing it delivers the most subtle outputs alongside performing the tasks with the process including the analysis of our image and its output too. The model delivered is to improve the conditions of security, privacy, image capture, and entertainment purposes.},
	booktitle = {2021 {Third} {International} {Conference} on {Inventive} {Research} in {Computing} {Applications} ({ICIRCA})},
	author = {Datta, Aabir and Yadav, Om Krishna and Singh, Yukti and S, Sountharrajan and M, Karthiga and E, Suganya},
	month = sep,
	year = {2021},
	keywords = {Adaptation models, Computational modeling, Computer Vision, Face arrangement, Face recognition, Face substitution, Face Swapping, Feature extraction, Image color analysis, Masking, Real time system, Real-time systems, Training, Warping},
	pages = {1081--1086},
}

@inproceedings{swathi_enhanced_2025,
