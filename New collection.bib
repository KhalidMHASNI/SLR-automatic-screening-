@inproceedings{j_flexible_2025,
	title = {Flexible {Multi}-{Modality} {Deepfake} {Identification} with {Dynamic} {Learning} and {Cross}-{Modality} {Inconsistency}},
	doi = {10.1109/ICAECA63854.2025.11012276},
	abstract = {Rapid advances in generative models, that produce hyper-realistic modifications of photos and videos, have contributed to deepfake detection more difficult. Current detection approaches are very costly, making real-time detection difficult, and they often suffer with generalization, particularly when faced with unknown deepfake techniques. An Adaptive Multi-Modality Framework is proposed, presenting a unique set of methods for reliable and effective deepfake detection in order to overcome these drawbacks. The framework incorporates Self-Supervised Patch-Based Learning for smooth detection of localized manipulations, Dynamic Discriminator Learning (DDL) in adaptively evolve against new deepfake generation techniques, and Cross-Modality Inconsistency Scoring (CMIS) to detect anomalies across spatial, temporal, and audio-visual domains. The Inconsistency Score (IS), a novel metric that measures the probability of modified material, unifies these elements. This method allows for real-time application, improves detection accuracy, and guarantees flexibility in response to new threats. The investigations reveal that the proposed method has the potential to transform fake identification techniques by surpassing state-of-the-art techniques.},
	booktitle = {2025 3rd {International} {Conference} on {Advancements} in {Electrical}, {Electronics}, {Communication}, {Computing} and {Automation} ({ICAECA})},
	author = {J, Edwin Joel and P, Kalyana Kumar and M, Mohamed Silar and J, Rohan},
	month = apr,
	year = {2025},
	keywords = {Accuracy, Adaptive Deepfake Detection, Cross-Modality Inconsistency Scoring, Deepfakes, Dynamic Discriminator Learning, Real-time systems, Reliability, Security, Self-supervised learning, Standards, Telecommunication computing, Training, Transforms},
	pages = {1--6},
}

@inproceedings{nayak_lightweight_2025,
	title = {Lightweight and {Efficient} {Deepfake} {Detection} {Using} {Transfer}-{Learned} {MobileNetV2}},
	doi = {10.1109/CCPIS65231.2025.11234268},
	abstract = {Deepfakes, produced through advanced generative models, threaten the authenticity of digital media. This study presents a lightweight deepfake detection framework utilising transfer-learned MobileNetV2, designed for efficient deployment on resource-constrained platforms. The model is trained on a Kaggle-sourced dataset of pre-cropped facial frames, incorporating extensive data augmentation and fine-tuning to enhance generalisation. Compared with other compact networks, including ResNet18 and MesoNet, MobileNetV2 achieves superior performance with a test accuracy of 98.23\%, while maintaining a compact architecture ( 3.4M parameters) suitable for real-time inference. These results underline MobileNetV2’s effectiveness for scalable and edge-based deepfake detection, with future improvements aimed at temporal consistency and adversarial robustness.},
	booktitle = {2025 2nd {International} {Conference} on {Circuits}, {Power} and {Intelligent} {Systems} ({CCPIS})},
	author = {Nayak, Debasish and Prasad Mishra, Bhabani Shankar and Champati Rai, Satyananda},
