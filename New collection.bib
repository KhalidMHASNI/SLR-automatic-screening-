@inproceedings{li_multimodal_2025,
	title = {Multimodal {DeepFake} {Detection} via {Audio}-{Visual} {Feature} {Fusion} and {Temporal} {Attention}},
	doi = {10.1109/ICBAIE66852.2025.11326621},
	abstract = {With the rapid development of AI-generated content, DeepFake videos have become increasingly realistic, posing significant challenges to the authenticity of information dissemination and the security of personal identity. As a result, detecting DeepFake videos has emerged as a critical task in the field of digital media forensics. Despite extensive research efforts, existing methods still face two major limitations: (i) insufficient capacity in modeling long-range temporal dependencies, which hinders the detection of complex dynamic inconsistencies; and (ii) reliance on a single modality, making it difficult to fully exploit the complementary information between audio and visual streams. To address these issues, we propose a novel multimodal DeepFake detection framework that jointly leverages audio and visual information for video detection. Specifically, we employ a visual Transformer with temporal self-attention to model dynamic inconsistencies across sampled video frames, and adopt an audio encoder to extract discriminative features from Mel-spectrogram representations. The extracted visual and audio features are then globally aggregated and fused through a lightweight classification head. Extensive experiments demonstrate that our approach effectively captures cross-modal forgery cues and achieves strong generalization capability across diverse and challenging Deep-Fake scenarios.},
	booktitle = {2025 6th {International} {Conference} on {Big} {Data}, {Artificial} {Intelligence} and {Internet} of {Things} {Engineering} ({ICBAIE})},
	author = {Li, Xiang and Ma, Zeyu and Zhang, Zhizhong and Chen, Mingang},
	month = oct,
	year = {2025},
	keywords = {Audio-visual fusion, DeepFake detection, DeepFake video, Deepfakes, Feature extraction, Forgery, Generative AI, Internet of Things, Learning (artificial intelligence), Media, Multimodal learning, Security, Transformers, Visualization},
	pages = {390--393},
}

@inproceedings{abdul_ameer_impact_2025,
	title = {The {Impact} of {Data} {Augmentation} on {Deepfake} {Detection}: {A} {Comparative} {Study} of {CNN} and {Transformer} {Models}},
	doi = {10.1109/ICMI65310.2025.11141228},
	abstract = {As AI becomes increasingly prevalent in our daily lives, the rise of deepfake technology presents a significant challenge for digital forensics and security, necessitating the development of robust detection models to help distinguish between real and fake media. In this work, We study the effect of data augmentation on deepfake classification performance using CNN-based and Transformer based networks. XceptionNet, ResNet-50, EfficientNet-B3, ViT-B/16, and ConvNeXt-Small are evaluated on the Deepfake Detection Challenge (DFDC) dataset and augmentation operations consist of rotating, color jitter, Gaussian noise and random erasing. The results also indicate that CNN-based models exceed the performance of Transformer-based architectures, as XceptionNet achieves an accuracy score of 94\% and an F1-score of 0.94, while ViT-B/16 performs poorly, achieving an accuracy of 82\%. These show that augmentation helps improve robustness for CNN models, while Transformer models show a less effective performance in this setup. The paper offered guidance on optimizing data preprocessing approaches for deepfake identification and proposed further investigation of hybrid CNN-Transformer architectures that could empower models to be more effective in detecting fake images.},
	booktitle = {2025 {IEEE} 4th {International} {Conference} on {Computing} and {Machine} {Intelligence} ({ICMI})},
	author = {Abdul Ameer, Noor Hayder and Al-Taee, Mustafa and Hussain, Abadal Salam T. and Hussian, Ahmed and Ali, Haider},
	month = apr,
	year = {2025},
	keywords = {Accuracy, Computational modeling, Data augmentation, Data Augmentation, Data models, Deepfake Detection, Deepfake Detection Challenge (DFDC), Deepfakes, Hybrid CNNTransformer Models, Real-time systems, ResNet-50, Robustness, Security, Training, Transformers, Vision Transformers, XceptionNet},
	pages = {1--6},
}

@inproceedings{shetty_fauxfind_2025,
	title = {{FauxFind}: {Deep} {Learning}-{Based} {Deepfake} {Detection} {System} using {Transfer} {Learning} and {CNN}},
	doi = {10.1109/ICETI4T63625.2025.11132179},
	abstract = {The recent breakthrough in deepfake technology has resulted in concerns for the authenticity of visual information present on the internet. In response to this grave problem, we propose a novel approach for deepfake image detection through the MesoNet algorithm. MesoNet is a type of CNN that has demonstrated its effectiveness in detecting faint manifestations of deepfake manipulations. In MesoNet, the mechanism of transfer learning is adopted to fine-tune a pre-trained model over a well-curated dataset consisting of real and deepfake images and thus learn very subtle patterns characteristic of artificial alterations. The performance of the proposed technique was rigorously tested on a range of datasets through extensive testing to show improved accuracy in identifying deepfake images with reduced false positives. In summary, the research findings indicate that the MesoNet algorithm could be used in detecting deepfake photos, serving as a powerful tool for preventing the spread of misinformation and preserving the integrity of visual content on digital platforms.},
	booktitle = {2025 {International} {Conference} on {Emerging} {Trends} in {Industry} 4.0 {Technologies} ({ICETI4T})},
	author = {Shetty, Dhruv and Patil, Pranjal and Ambre, Purva and Shahane, Prachi},
	month = jun,
	year = {2025},
	keywords = {Accuracy, Convolutional Neural Network (CNN), Convolutional neural networks, Deepfake Detection, Deepfakes, Feature extraction, Focusing, Fourth Industrial Revolution, Market research, MesoNet Algorithm, Testing, Transfer learning, Transfer Learning, Visualization},
	pages = {1--6},
}

@inproceedings{gaikawad_robust_2025,
	title = {A {Robust} and {Lightweight} {CNN}-{Transformer} {Model} for {Audio} {Deepfake} {Detection} in {Indian} {Languages}},
	issn = {2643-8615},
	doi = {10.1109/ISPCC66872.2025.11039572},
	abstract = {The proliferation of audio deepfake technology poses significant threats to digital security, particularly in multilingual contexts such as India, where diverse languages are widely used. This paper presents a robust and lightweight CNN-Transformer hybrid model designed for audio deepfake detection in major Indian languages, including Marathi, Hindi, Tamil, Telugu, Malayalam, and Kannada. The proposed model addresses two critical challenges in deepfake detection: domain generalization and computational efficiency. By integrating multiple feature types—Mel spectrograms, LFCC, and Wav2Vec—and leveraging Convolutional Neural Networks (CNNs) for spatial feature extraction, Transformer layers with multi-scale attention for temporal dependencies, and a spectral-temporal gating mechanism for feature fusion, the model achieves superior performance across diverse audio environments, including low-quality and noisy data. Additionally, the model is optimized for edge devices using pretraining, quantization, knowledge distillation, and pruning, ensuring real-time performance with minimal accuracy loss. Evaluated on a novel dataset of nearly 10,000 samples per language, alongside ASVspoof 2021 and in-the-wild datasets, the model achieves a test accuracy of 98.07\% (validation accuracy of 98.62\%) with precision and recall scores of 0.98 and 0.98 on the test set, respectively. The study also analyzes trade-offs between model size, inference speed, and detection accuracy, offering insights into practical deployment. This work advances audio forensics by providing a scalable, efficient, and language-agnostic solution to counter audio deepfakes in resource-constrained settings.},
	booktitle = {2025 7th {International} {Conference} on {Signal} {Processing}, {Computing} and {Control} ({ISPCC})},
	author = {Gaikawad, Manish and Ghosh, Soma},
	month = mar,
	year = {2025},
	keywords = {Accuracy, Audio Deepfake Detection, CNN-Transformer Hybrid Model, Computational modeling, Deepfakes, Domain Generalization, Edge Device Optimization, Feature extraction, Indian Languages, Multilingual, Multilingual Datasets, Performance evaluation, Quantization (signal), Real-time systems, Security, Transformers},
	pages = {382--387},
}

@inproceedings{m_attention-guided_2025,
	title = {Attention-{Guided} {Hybrid} {Deepfake} {Detection} {Model} {Using} {VGG}-19, {Optical} {Flow}, and {Face} {Embeddings}},
	doi = {10.1109/ICWITE64848.2025.11407434},
	abstract = {The authenticity of deepfake content makes verification of authentic media extremely difficult because trust in information has completely vanished. A deepfake detection method combines style and content features through attention enhancement according to this study. Style features based on VGG-19 network and Gram matrices analyze face texture faults while FaceNet generates content features through optical flow and face embeddings. The MLP system uses attention modules to process tampered regions following a combination step of features. Research tests utilize FaceForensics++ DFS as well as DFDC and Celeb-DF benchmarks to establish high precision rates and generalization abilities. The real-time detection systems for deepfakes can use this method because it demonstrates both scalability for attack protection and automatic interpretation capabilities for detection purposes.},
	booktitle = {2025 {IEEE} {International} {Conference} for {Women} in {Innovation}, {Technology} \& {Entrepreneurship} ({ICWITE})},
	author = {M, Bhavya and M S, Nithesh Kumar and Singh, Abhinav and Verma, Saurabh and Shetti, Tejas M and B S, Sudarsh},
	month = sep,
	year = {2025},
	keywords = {ArcFace, Attention Mechanism, Deepfake Detection, Deepfakes, FaceNet, Faces, Feature extraction, Feature Fusion, Gram Matrix, Hybrid Deepfake Model, Media, Optical flow, Optical Flow, Real-time systems, Scalability, Semantics, Style-Content Analysis, Ultraviolet sources, VGG-19, Visualization},
	pages = {1--5},
}

@inproceedings{hirpara_deepfake_2025,
	title = {Deepfake {Detection}: {Demodulate} {Synthetic} {Videos} {Using} {Deep} {Learning} {Models}},
	doi = {10.23919/INDIACom66777.2025.11115707},
	abstract = {A deepfake detection system that uses machine learning (ML) and deep learning (DL) models to detect manipulated videos and images is presented in the study. Being aware of such synthetic content is crucial considering the emergence of deepfake technology, which might alter photos, videos, and audio for malevolent objectives including fraud, extortion, and disinformation. Deepfake technology has been applied to solve various real-time problems but is also exploited for unethical and illegal purposes. As a result, developing research and detection models is crucial to prevent its misuse. We proposed a CNN-LSTM hybrid model for analysis of cropped images to improve the performance of fake video detection. The suggested method focuses on identifying fake videos using the Celeb-DF dataset, which consists of 1203 videos (795 fake, 408 real). Moreover, the benefits and drawbacks of the various deepfake detection techniques are examined. The paper indicates potential improvements in model accuracy through more datasets and improved architectures, and it emphasizes the significance of sophisticated detection techniques to mitigate the negative consequences of deepfakes. With cropped video frames and deep learning techniques, the model's accuracy increased from 79.06\% with the original dataset to {\textbackslash}mathbf8 6. 8 2 \% with cropped videos.},
	booktitle = {2025 12th {International} {Conference} on {Computing} for {Sustainable} {Global} {Development} ({INDIACom})},
	author = {Hirpara, Priyanshu and Valangar, Hardi and Kachhadiya, Vishwa and Chauhan, Uttam},
	month = apr,
	year = {2025},
	keywords = {Accuracy, Analytical models, Artificial Intelligence, CNN-LSTM, Computational modeling, Computer architecture, Deep learning, Deep Learning, Deepfake Detection, Deepfakes, Face Manipulation, Faces, Fraud, Real-time systems},
	pages = {01--06},
}

@inproceedings{susmi_enhancing_2025,
	title = {Enhancing {DeepFake} {Classification} {Performance} {Using} a {CNN} and {XceptionNet}-{Based} {Pipeline}},
	doi = {10.1109/COMPAS67506.2025.11381636},
	abstract = {Deepfake technology can create a video or image that looks real but in reality it is fake.It is a real threat to our society and our digital security. The popularity of generative models like generative adversarial networks (GANs) has made it easier to produce content that we can not differentiate between fake media and authentic media. To combat this, the study introduces a dual-model deepfake detection system that combines a custom lightweight convolutional neural network (CNN) with a transfer learning-based XceptionNet. This framework is trained and tested on the 140K Real and Fake Faces dataset, which contains an similar number of real and synthetic images. The custom CNN is built from scratch, featuring optimized convolutional layers, ReLU activations, max-pooling, and dense layers with dropout for regularization. The XceptionNet model is finetuned with additional dense layers for binary classification. Both models follow the same pre-processing steps and are trained with the Adam optimizer using binary cross-entropy loss. The CNN achieves an impressive 97\% accuracy, while XceptionNet reaches 91\%, highlighting their strong performance and ability to generalize. Metrics like precision, recall and F1-score verify the reliability of both methods. The research suggest that despite limited data and resources, deepfake detection is feasible by utilizing efficient architectures and training techniques. This framework gives a scalable and resource efficient solution for real world deepfake forensics, particularly in environments with limited computational capacity. Future work will investigate ensemble models and real-time detection implementations.},
	booktitle = {2025 {IEEE} 2nd {International} {Conference} on {Computing}, {Applications} and {Systems} ({COMPAS})},
	author = {Susmi, Nishat Tasnim and Chandra Chanda, Manob and Hosain, Md. Sarwar and Rifat Hossen, Md. and Hossain, Md. Anwar and Fazal Mohammad Zainul Abadin, Abul},
	month = oct,
	year = {2025},
	keywords = {Accuracy, CNN, Computational modeling, Computer architecture, Convolutional neural networks, deepfake detection, Deepfakes, Faces, image forgery, Measurement, Media, Real-time systems, transfer learning, Transfer learning, XceptionNet},
	pages = {1--6},
}

@inproceedings{b_truthlens_2025,
	title = {{TruthLens}: {A} {Serverless} {Deepfake} {Detection} {Platform} {Leveraging} {MesoNet} and {AWS} {Cloud} {Services}},
	issn = {2767-1097},
	doi = {10.1109/CSITSS67709.2025.11294340},
	abstract = {Advancements in deepfake technology have escalated challenges in verifying digital media authenticity, posing risks to information integrity and public trust. This paper presents TruthLens, a scalable and efficient deepfake detection platform designed to identify manipulated visual content in real-time. The system leverages a lightweight CNN architecture, optimized for detecting subtle manipulation artifacts, and integrates it with a user-friendly web interface and serverless cloud infrastructure. The methodology involves curating a balanced dataset of real and fake images, applying data augmentation to intensify model robustness, and training the CNN to distinguish authentic from manipulated content. The platform employs a modular design, with a React-based frontend for seamless user interaction, a Flask API for real-time inference, and AWS services Lambda for computation, S3 for hosting, and DynamoDB for analytics to ensure scalability and cost-efficiency. Evaluation on diverse test set demonstrates the system's effectiveness in accurately classifying media, with low false positives to maintain user trust. Qualitative analysis confirms its ability to detect common deepfake artifacts, such as unnatural facial features. TruthLens advances digital forensics by offering a practical, accessible solution for media verification, with future enhancements planned for video support, explainable AI visualizations, and resilience against adversarial attacks. This work contributes to combating digital misinformation, supporting applications in journalism, content moderation, and digital security.},
	booktitle = {2025 9th {International} {Conference} on {Computational} {System} and {Information} {Technology} for {Sustainable} {Solutions} ({CSITSS})},
	author = {B, Sahana and B, Sadhana and G S, Sharvani and Agarwal, Harshit and Bansal, Priyansh},
	month = nov,
	year = {2025},
	keywords = {AWS, Convolutional neural networks, Convolutional Neural Networks, Deepfake Detection, Deepfakes, Digital forensics, Digital Forensics, Media Verification, Real-time systems, Scalability, Security, Serverless computing, Serverless Computing, Service-oriented architecture, Training, Visualization},
	pages = {1--5},
}

@inproceedings{deshpande_binary_2025,
	title = {A {Binary} {Classification} {Model} for {Real}-{Time} {Deepfake} {Voice} {Detection} {Using} {CNN}-{BiLSTM} and {Feature}-{Based} {Ensemble} {Learning}},
	doi = {10.1109/I2ITCON65200.2025.11210489},
	abstract = {The proliferation of AI-driven voice synthesis technologies has introduced unprecedented risks to digital trust, particularly in cybersecurity, legal forensics, and authentication systems. This research proposes a dual-path binary classification model that combines deep learning (CNN-BiLSTM on melspectrograms) with traditional machine learning (wav2vec and MLP on LibROSA features) in an ensemble framework. Trained on 800 labeled samples (400 human, 400 cloned), also used various methods such as data augmentation, which was used to create around 7000 instances, the proposed system achieved 99.16 percent accuracy. A real-time Streamlit-based interface demonstrates its deployability. The results are statistically validated through five-fold cross-validation and confidence intervals. This work bridges spatial-temporal spectrogram learning with featurelevel interpretability to offer a scalable solution for AI-cloned voice detection.},
	booktitle = {2025 {International} {Conference} on {Information}, {Implementation}, and {Innovation} in {Technology} ({I2ITCON})},
	author = {Deshpande, Jui Madhav and Jadhav, Omkar Hindurao and Dalvi, Aaditya Sandeep and Sid, Shreekumar Santosh and Sarpate, Dikshendra Daulat},
	month = jul,
	year = {2025},
	keywords = {Accuracy, Analytical models, CNNBiLSTM, Deep learning, Deepfake detection, Deepfakes, ensemble model, Feature extraction, Forensics, MLP, real-time classification, Real-time systems, Signal Processing, Spectrogram, spectrogram analysis, Technological innovation, Usability, voice forensics, wav2vec},
	pages = {1--6},
}

@inproceedings{sakthivel_towards_2025,
	title = {Towards {Tamper}-{Resistant} {Digital} {Media}: {An} {AI} and {Blockchain} {Approach} for {Deepfake} {Detection}},
	doi = {10.1109/ICECA66444.2025.11382545},
	abstract = {Deepfake technology poses severe risks to digital security and content authenticity due to advancements in generative models. Traditional detection methods rely on either visual or auditory cues, making them vulnerable to evolving forgery techniques and lacking secure validation. This study proposes a multimodal deepfake detection framework integrating Artificial Intelligence (AI) and Blockchain for tamper-resistant verification. The system employs MTCNN and InceptionResNetV1 for visual forgery detection, and a CNN model on mel-spectrograms for audio deepfake identification. SHA-256 hashing and blockchain storage ensure the immutability and traceability of detection results. Experimental evaluation demonstrates that the proposed model achieves a detection accuracy of 93\%, outperforming conventional CNN and hybrid CNN-LSTM systems in precision, recall, and F1-score. The framework provides a secure, scalable, and decentralized solution to detect synthetic media while preserving integrity and transparency, contributing to safer digital media ecosystems and reliable content authentication.},
	booktitle = {2025 9th {International} {Conference} on {Electronics}, {Communication} and {Aerospace} {Technology} ({ICECA})},
	author = {Sakthivel, K and N, Harine and G, Chandra Mohan},
	month = nov,
	year = {2025},
	keywords = {AI, Artificial intelligence, Authentication, Biological system modeling, Blockchain, Blockchains, CNN, Deepfake Detection, Deepfakes, Forgery, Journalism, LSTM, Media, MFCC, Multimodal Analysis, Real-time systems, SHA-256, Visualization},
	pages = {495--500},
}

@inproceedings{s_r_deepfakeguard_2025,
	title = {{DeepFakeGuard}: {Real}-{Time} {Deepfake} {Video} {Detection} {Leveraging} {Celeb}-{DF} {Dataset} and {CNN}-{LSTM} {Framework}},
	doi = {10.1109/ICOECA66273.2025.00133},
	abstract = {Deepfake technology has significantly eroded the veracity of digital media across the world, raising concerns of misinformation and media manipulation. To counteract this, we have developed DeepFakeGuard, a powerful deepfake detection system with robust deep learning algorithms present on the web. The system works to identify deepfake videos by checking each subsequent frame for irregularities, for instance, unbalanced lip movements, abrupt light changes, or unnatural cuts. DeepFakeGuard has been pre-trained on a wide variety of datasets primarily focused on the Celeb-DF dataset with high-quality and challenging-to-detect deepfake content. This provides the system with flexibility and precision for multiple applications such as short-form broadcast, high-definition video streams, and live streams. The initial step was preprocessing of data meticulously with focus on neatness and elimination of data noise to ensure the model works at its best. We then employed the latest deep learning architectures, a combination of Convolutional Neural Networks (CNNs) and Recurrent Neural Networks (RNNs), to detect the slightest disparities between subsequent frames. Our models have been exhaustively tested to identify tampered content from real media at high accuracy levels. The web-based system provides real-time detection of deepfake, with the ability to upload media files to be detected in real-time. In addition, its robust backend infrastructure for processing video prevents disruption in smooth processing, making DeepFakeGuard deployable on a wide variety of environments such as content moderation, digital forensics, and media verification. The result of our work is evidence of how DeepFakeGuard can enhance digital media security through effective deepfake content detection.},
	booktitle = {2025 5th {International} {Conference} on {Expert} {Clouds} and {Applications} ({ICOECA})},
	author = {S R, Viknesh and M, Praveen Kumar and V N G, Ajey Suthan and G, Sivakarthi},
	month = mar,
	year = {2025},
	keywords = {Accuracy, Celeb-DF dataset, Convolutional neural networks, Convolutional Neural Networks (CNNs), Deep learning, Deep learning algorithms, Deepfake detection, Deepfakes, Lips, Long short term memory, Media, Real-time detection, Real-time systems, Recurrent neural networks, Recurrent Neural Networks (RNNs), Robustness},
	pages = {744--750},
}

@inproceedings{jambula_securing_2025,
	title = {Securing {Reality}: {AI}-{Driven} {Detection} of {Deepfakes} and {Counterfeit} {Currency}},
	issn = {2831-4565},
	doi = {10.1109/iSAI-NLP66160.2025.11320726},
	abstract = {The rapid growth of AI-generated media and high-resolution printing has intensified the dual threats of deepfake content and counterfeit currency, eroding public trust and financial security. This paper presents two complementary detection frameworks. For deepfakes, a spatial-temporal CNN-LSTM pipeline captures frame-level artifacts and sequence dynamics, enabling robust video analysis. For counterfeit currency, a multi-stage rule-based system combines HSV-based segmentation, geometric validation, and feature-wise scoring of security elements (e.g., Gandhi portrait, watermark, micro-lettering, and security thread). Evaluated on real and synthetic video/image datasets, the CNN-LSTM model attains a validation accuracy of 91.25 \%, while the currency system correctly flags 95 \% of forged notes (19/20), highlighting resilience to high-quality reproductions. Both frameworks are designed for real-time operation and emphasize explainability through structured outputs and feature-level confidence reporting. The results demonstrate that integrating deep learning with rule-based verification delivers scalable, transparent, and accurate defenses against modern media and financial forgeries, offering a practical foundation for deployment in security-critical workflows.},
	booktitle = {2025 20th {International} {Joint} {Symposium} on {Artificial} {Intelligence} and {Natural} {Language} {Processing} ({iSAI}-{NLP})},
	author = {Jambula, Nithin and Reddy, Nalla Krishna and Pandey, Kshama and M, Mahesh},
	month = nov,
	year = {2025},
	keywords = {Accuracy, AI in security, computer vision, convolutional neural networks, Convolutional neural networks, counterfeit note identification, Currencies, Deepfake detection, Deepfakes, fraud prevention, Long short-term memory networks, machine learning, Media, Prevention and mitigation, Printing, Real-time systems, Resilience, Watermarking},
	pages = {1--6},
}

@inproceedings{kundu_convolutional_2025,
	title = {Convolutional {Neural} {Networks} for {Robust} {Deepfake} {Detection} in {Digital} {Photography}},
	doi = {10.1109/ICOCT64433.2025.11118479},
	abstract = {The rapid advancement of deepfake technology, driven by AI and deep learning, has revolutionized media creation but poses significant threats to privacy, cybersecurity, and public trust. This study explores Convolutional Neural Networks (CNNs) as a primary approach for deepfake detection, integrating hybrid frameworks with transformer-based models. The proposed methodology employs a multi-attentional CNN framework alongside a Conditional Encoder-Decoder GAN (CED-DCGAN) to analyze spatial and temporal inconsistencies in manipulated media. Extensive experiments were conducted on benchmark datasets such as FaceForensics++, CelebA-HQ, and the DeepFake Detection Challenge (DFDC) to evaluate detection efficacy. The results demonstrate that the hybrid model achieves a remarkable accuracy of 98.23\%, surpassing traditional CNN-based and semi-supervised GAN models. Additionally, adversarial training enhances robustness against attack scenarios, maintaining 89.7\% accuracy. Despite challenges in computational efficiency, the findings contribute to the development of scalable deepfake detection systems, reinforcing digital media integrity and trust. The future research should focus on optimizing real-time applicability and enhancing explainability for practical deployment.},
	booktitle = {2025 {International} {Conference} on {Computing} {Technologies} ({ICOCT})},
	author = {Kundu, Saikat and Bera, Akas and Neogi, Suman Kumar and Jaiswal, Niraj and Ghosh, Papri and Das, Subhram and Mondal, Md. Ashifuddin},
	month = jun,
	year = {2025},
	keywords = {Accuracy, CNNs, Computational modeling, Convolutional neural networks, Deepfake detection, Deepfakes, digital media forensics, digital trust, Generative adversarial networks, machine learning, Media, Real-time systems, Robustness, Training, Transformers},
	pages = {1--5},
}

@inproceedings{cyril_deepguard_2025,
	title = {{DeepGuard}: {A} {Hybrid} {CNN}-{LSTM} {Framework} for {Robust} {Deepfake} {Video} {Detection} with {Spatiotemporal} {Analysis}},
	doi = {10.1109/ICSCDS65426.2025.11166809},
	abstract = {Deepfake technology has developed very quickly, allowing highly realistic artificial media to be created that causes serious risks to privacy, security, and disinformation. This paper introduces a deep learning method for identifying deepfake videos by applying a hybrid Convolutional Neural Network (CNN) and Long Short-Term Memory (LSTM) model. The proposed model takes advantage of spatial information learned by a CNN (Xception backbone) and temporal relationships learned by an LSTM in order to label videos as real or fake. The model was trained on the FaceForensics++ dataset and evaluated on the Celeb-DF dataset with an accuracy of 82\%. A web application was also implemented for real-time deepfake detection. The outcome proves the efficacy of the suggested architecture in detecting manipulated videos with challenges and future enhancements},
	booktitle = {2025 3rd {International} {Conference} on {Sustainable} {Computing} and {Data} {Communication} {Systems} ({ICSCDS})},
	author = {Cyril, Madda Anthony and Prakash Sunkavalli, Jaya and Prasanth, Dodla},
