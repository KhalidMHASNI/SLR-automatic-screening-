	pages = {1--6},
}

@inproceedings{s_detection_2025,
	title = {Detection of {Deepfake} {Videos} {Created} {Through} {Face} {Swapping} {Techniques}},
	doi = {10.1109/ICITEICS64870.2025.11341147},
	abstract = {The increasing prevalence of deepfake technology particularly its ability to alter facial identities in videos and images using artificial intelligence—has raised serious concerns about the reliability of visual content, especially in journalism and media reporting. This project aims to build an advanced deep learning system capable of detecting face-based deepfake manipulations specifically for use in news forensics. The proposed solution leverages Convolutional Neural Networks (CNNs) to analyse facial patterns and identify irregularities indicative of tampered or synthetically generated content. Using datasets such as FaceForensics++, the model will be trained to recognize both authentic and manipulated videos, with a focus on overcoming challenges such as video compression and adversarial inputs that often escape detection by traditional methods. Ethical concerns, including user privacy and responsible implementation, will be addressed to ensure the technology is used in a socially responsible manner. Furthermore, the system will incorporate advanced preprocessing techniques, data augmentation strategies, and adversarial training to improve robustness and generalization. In addition to enhancing detection performance, the project also aims to raise awareness about the dangers of deepfake technology in the news industry and support efforts to safeguard digital media integrity.},
	booktitle = {2025 {IEEE} 2nd {International} {Conference} on {Information} {Technology}, {Electronics} and {Intelligent} {Communication} {Systems} ({ICITEICS})},
	author = {S, Shruthi. and R, Manjunath},
	month = aug,
	year = {2025},
	keywords = {Auditory media, Deep learning, Deepfake, Deepfake detection, Deepfakes, Face recognition, Media, Real-time systems, Robustness, Social networking (online), Textual media, Training, Video compression, Visual media, Visualization},
	pages = {1--9},
}

@inproceedings{kashyap_lightweight_2025,
	title = {Lightweight {Deepfake} {Detection} for {Real}-{World} {Augmented} {Images} in {Social} {Media}},
	issn = {2831-4565},
	doi = {10.1109/iSAI-NLP66160.2025.11320721},
	abstract = {Deepfake detection continues to face significant challenges when dealing with unfamiliar identities, emerging manipulation techniques, and degraded visual quality, which become even more critical in real-world scenarios such as social media, where images and videos are frequently compressed and distorted by noise. Existing methods rely heavily on large labeled datasets but still struggle to generalize effectively across unseen domains. To address this, we propose a lightweight deepfake detection framework specifically designed for augmented images common on social media and optimized for real-time use on edge devices. Our approach integrates global facial representations with localized texture cues through a dual-stream network model, enabling robustness under distortions while maintaining low computational overhead. We systematically evaluate the framework under varying levels of augmentation, including compression, noise, and blurring, and benchmark it against state-of-the-art detectors. Results demonstrate that our model achieves competitive accuracy with significantly reduced complexity, while GradCAM visualizations across different augmentation conditions provide interpretability by revealing how distortions affect the model's attention toward manipulated regions, thereby offering actionable insights for improving robustness.},
	booktitle = {2025 20th {International} {Joint} {Symposium} on {Artificial} {Intelligence} and {Natural} {Language} {Processing} ({iSAI}-{NLP})},
	author = {Kashyap, Aryan and {Mehak} and Sarkar, Sobhan and Pramanik, Anima},
	month = nov,
	year = {2025},
	keywords = {Benchmark testing, Computational modeling, data augmentation, Data models, Deepfake detection, Deepfakes, Distortion, dual-stream models, Grad-CAM, Image coding, Image edge detection, lightweight networks, model benchmarking, Noise, robustness, Robustness, Social networking (online)},
	pages = {1--6},
}

@inproceedings{s_survey_2025,
	title = {A {Survey} on {Deepfake} {Detection} {Techniques} for {Watermarking} and {Digital} {Forensics} {Using} {Deep} {Learning}},
	doi = {10.1109/CISES66934.2025.11265509},
	abstract = {The rapid development of deepfake technology has introduced new challenges to content authenticity, especially in legal and forensic domains where the integrity of digital media is paramount. Deep fakes have further complicated watermarking efforts, making it difficult to assert media ownership or validate tamper resistance. This survey aims to examine and categorize existing deepfake detection techniques from a deep learning perspective, with an emphasis on their integration into digital watermarking and forensic applications. A comprehensive literature review is conducted to explore deep learning-based detection methods such as CNNs, RNNs, attention mechanisms, and facial geometry models. The study also investigates how these techniques can support robust watermarking strategies and forensic traceability. The review reveals that hybrid architectures such as ResNet-Swish-BiLSTM and spatiotemporal attention networks achieve high accuracy in detecting manipulated media. Additionally, deep learning is shown to enhance the effectiveness of watermarking and forensic workflows by enabling tamper detection, content attribution, and source verification. Deep learning-driven deepfake detection offers promising solutions not only for real-time content authentication but also for long-term forensic verification and digital watermarking. Future work should focus on building integrated frameworks that combine detection, provenance tracking, and legal admissibility.},
	booktitle = {2025 {International} {Conference} on {Intelligent} and {Secure} {Engineering} {Solutions} ({CISES})},
	author = {S, Suhasini T and Sharma, Manisha and Mishra, Deviprasad},
	month = aug,
