	pages = {2071--2076},
}

@inproceedings{pacaldo_hybrid_2025,
	title = {Hybrid {DeepFake} {Detection} {Using} {Xception} and {XGBoost} with {Bayesian} {Optimization}},
	doi = {10.1109/IDAP68205.2025.11222293},
	abstract = {Deepfakes pose a significant challenge to media integrity by generating highly realistic manipulated videos that are difficult to detect with conventional methods. This study proposes a hybrid deepfake detection framework that integrates spatial feature extraction from video frames using a pre-trained Xception convolutional neural network and classification via an XGBoost model fine-tuned through Bayesian Optimization. The approach employs a memory-efficient streamed pipeline to process keyframes from the DeepFake Detection (DFD) dataset, achieving 92.5\% accuracy, perfect recall for fake videos, and competitive performance against state-of-the-art baselines including MesoNet, EfficientNet-B7, and Vision Transformer. Comparative experiments and an ablation study demonstrate the benefits of combining deep CNN-based feature extraction with optimized gradient boosting for real-time, scalable, and interpretable deepfake detection. This work highlights the potential of hybrid architectures to address the growing challenge of manipulated media in security-critical contexts.},
	booktitle = {2025 9th {International} {Artificial} {Intelligence} and {Data} {Processing} {Symposium} ({IDAP})},
	author = {Pacaldo, Paolo L. and Matias, Junrie B. and Jayoma, Jaymer M. and Abalorio, Cristopher C. and Gonzales, Clark Justine and Dalaorao, Gleen A.},
	month = sep,
	year = {2025},
	keywords = {Bayes methods, Bayesian Optimization, Data models, Data processing, deepfake detection, Deepfakes, Feature extraction, hybrid model, Media, Optimization, Pipelines, Real-time systems, Transformers, video classification, Xception, XGBoost},
	pages = {1--4},
}

@inproceedings{more_deepfake_2025,
	title = {{DeepFake} {Detection} {Using} {EfficientNetB3} and {RestNet18}},
	doi = {10.1109/ICITEICS64870.2025.11340838},
	abstract = {DeepFake videos-AI-generated content that convincingly simulates human faces and speech-pose serious threats to digital media integrity and public trust. To address the growing need for reliable DeepFake detection, this paper proposes a spatio-temporal framework that integrates both visual appearance and motion dynamics. Our method employs adaptive keyframe selection, face alignment, dense optical flow via RAFT, and supervised contrastive learning to capture temporal inconsistencies between real and manipulated content. We evaluate two deep convolutional neural networks: EfficientNet-B3 and ResNet18. While EfficientNet-B3 demonstrates strong classification accuracy and generalization across video manipulations, ResNet18 underperforms, particularly under motion distortions. Comparative results highlight the value of using richer architectures with motion-aware representations for robust forgery detection. Our study presents an effective, interpretable, and computationally feasible framework for DeepFake detection, suitable for both forensic analysis and future real-time deployment.},
	booktitle = {2025 {IEEE} 2nd {International} {Conference} on {Information} {Technology}, {Electronics} and {Intelligent} {Communication} {Systems} ({ICITEICS})},
	author = {More, Prajwal and D, Evangeline and M, Sinthuja},
	month = aug,
	year = {2025},
	keywords = {CNN, Contrastive learning, Contrastive Learning, Convolutional neural networks, DeepFake Detection, Deepfakes, FaceForensics++, Faces, Media, Optical distortion, Optical flow, Optical Flow, RAFT, Real-time systems, Reliability, Spatio-Temporal, Visualization},
	pages = {1--6},
}

@inproceedings{anandhasivam_enhancing_2024,
	title = {Enhancing {Deepfake} {Detection} {Through} {Hybrid} {MobileNet}-{LSTM} {Model} with {Real}-{Time} {Image} and {Video} {Analysis}},
	doi = {10.1109/ICUIS64676.2024.10867159},
	abstract = {The race to crush information integrity and public trust is being won by one thing: deepfakes, AI manipulated media. The goal is to enhance the Deepfake detection using MobileNet V3 and LSTM network. MobileNet's lightweight CNN architecture is able to induce the visual features in an image by an image and in a video and can pick up the slight visual clues of textures and facial structure. Some temporal inconsistencies that cannot be seen by image base methods are then analyzed using an LSTM network. The hybrid model is trained on real and deepfake media datasets, and is thus adaptable to emerging deepfake techniques. This has a user face interface to analyze the real time and fly media to get the analysis and analysis score and visual feedback of the identified artifacts. Unique to this system is its versatility for images and videos, and its real time capability, making it a suitable choice for practical use in social media, journalism, and law enforcement combating the spread of misinformation with a guarantee of digital media authenticity},
	booktitle = {2024 4th {International} {Conference} on {Ubiquitous} {Computing} and {Intelligent} {Information} {Systems} ({ICUIS})},
