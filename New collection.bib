@inproceedings{ghodake_hybrid_2025,
	title = {Hybrid {Deepfake} {Detection} {System}: {Leveraging} {AlexNet} and {LSTM} {Networks} for {Enhanced} {Video} {Authentication}},
	doi = {10.1109/ESIC64052.2025.10962665},
	abstract = {The rapid proliferation of deepfake technology has presented significant challenges in ensuring the authenticity of digital media, posing security risks in various domains, including social media, politics, and corporate communications. This paper proposes a hybrid deepfake detection system that integrates AlexNet, a powerful convolutional neural network (CNN), and Long Short-Term Memory (LSTM) networks to enhance video authentication. The proposed system lever-ages AlexNet's strong capabilities in feature extraction to analyze spatial features within video frames, while LSTM networks process temporal sequences, capturing the dependencies across frames in video streams. By combining these models, our approach delivers an effective deepfake detection system that is robust to subtle manipulations and capable of identifying deepfakes with high precision. Experiments were conducted on publicly available datasets to evaluate the performance of the hybrid model against standalone models and other baseline approaches. The results indicate significant improvements in detection accuracy, with the hybrid system achieving a higher recall and precision rate compared to traditional CNN and RNN-based methods. Furthermore, the proposed system demonstrated resilience against a wide range of deepfake techniques, including facial reenactment and voice synchronization. This work highlights the importance of combining spatial and temporal analysis for reliable video authentication, paving the way for advanced deepfake mitigation strategies in both public and private sectors. The integration of AlexNet and LSTM networks offers a scalable solution for real-time video analysis, providing critical support in com-bating the spread of disinformation and enhancing trust in digital media.},
	booktitle = {2025 {International} {Conference} on {Emerging} {Systems} and {Intelligent} {Computing} ({ESIC})},
	author = {Ghodake, Abhijit Bapurao and Yewale, Durgesh Bajirao and Katariya, Tejal Dilip and Khobare, Bhakti Sahebrao and Shidore, Ashvini S.},
	month = feb,
	year = {2025},
	keywords = {Accuracy, AlexNet, Authentication, Convolutional neural networks, Deepfake detection, Deepfakes, Feature extraction, hybrid model, Location awareness, Long short term memory, LSTM networks, Real-time systems, Reliability, Streaming media, video authentication},
	pages = {283--287},
}

@inproceedings{patil_exposeai_2025,
	title = {{ExposeAI}: {A} {Lightweight}, {Multimodal}, and {Explainable} {Framework} for {Efficient} {Deepfake} {Detection}},
	doi = {10.1109/AISummit66170.2025.11411250},
	abstract = {Deepfakes are a big concern because they make it impossible for people to believe what they see online. How can we know what's true anymore when anybody can make phony films that look authentic with just a smartphone app? That's why we created ExposeAI, a program that helps regular people find deepfakes without having to know a lot about computers. ExposeAI employs a cutting-edge AI technique called Vision Transformer (ViT-Base). You may think of it as a digital detective that is really adept at finding the little, almost imperceptible signs that something is phony. We trained our system with thousands of pictures from the Celeb-DF v1 dataset, and then we put it to the test with videos from the harder Celeb-DF v2 dataset. What were the results? It worked quite well, showing that it can handle both movies and pictures. But here's what makes ExposeAI different: it doesn't just tell you "this is fake" and leave you wondering why. Instead, it uses simple visual heatmaps to show you precisely what gave it away. These bright overlays show the parts of a picture or video that appear suspect. It might be anything strange about the eyes, the skin texture, or the lighting that people usually overlook. This openness isn't simply a good feature - it's vital. When individuals understand how the technology works and can see the proof for themselves, they're more inclined to trust and really utilize the tool. The creators built ExposeAI to put the power back in consumers' hands, giving them the confidence to question what they see online and make educated judgments regarding digital material validity.},
	booktitle = {2025 2nd {Global} {AI} {Summit} - {International} {Conference} on {Artificial} {Intelligence} and {Emerging} {Technology} ({AI} {Summit})},
	author = {Patil, Abhijit and Fatakdawala, Zainuddin and Hundare, Vedant and Doshi, Harsh},
	month = nov,
	year = {2025},
	keywords = {Deepfake Detection, Deepfakes, Digital Media Forensics, Explainable AI, Explainable AI (XAI), Lightweight CNN, Media, Metadata, Motion pictures, Multimodal Analysis, Planning, Real-time systems, Skin, Steganalysis, Transformers, Visualization},
	pages = {1074--1079},
}

@inproceedings{om_prakash_ai-powered_2025,
	title = {{AI}-{Powered} {Facial} {Analysis}: {Real} or {Fake} {Image} {Detection}, {Age} {Group} {Classification}, {Grooming} {Analysis} and {Emotion} {Recognition}},
	doi = {10.1109/RMKMATE64874.2025.11042624},
	abstract = {The development of deepfake technology has made it extremely difficult to tell the difference between real and altered facial photos, which presents significant privacy and security risks. This project offers a multifaceted deep learning-driven solution that can classify age, identify emotions, and conduct grooming analysis in addition to detecting deepfake photos. The method achieves 93.91\% success rate in deepfake identification using a model built on CNN that was trained on datasets of real and fake faces. Furthermore, an OpenCV-Caffe model categorizes people into various age groups, a Vision Transformer (ViT)-based beard recognition model achieves 99.9\% accuracy, and an Xception-based emotion detection method reaches 98.65\% accuracy. Users can input photographs, evaluate several faces, and generate a detailed report on age distribution, feelings beard presence and real/fake categorization using the system's real-time Streamlit user interface. This AI-powered solution addresses the growing worries about digital verification of identity and distorted media by offering a safe, effective and automated method of facial analysis.},
	booktitle = {2025 2nd {International} {Conference} on {Research} {Methodologies} in {Knowledge} {Management}, {Artificial} {Intelligence} and {Telecommunication} {Engineering} ({RMKMATE})},
	author = {Om Prakash, P.G. and Tadi, Yoga Sairam Srihari and Karumajji, Kyathisree},
	month = may,
	year = {2025},
	keywords = {Accuracy, Age Classification, Computer vision, Deepfake Detection, Deepfakes, Emotion recognition, Emotion Recognition, Faces, Facial Analysis, Grooming Detection and Vision Transformer, Real-time systems, Resilience, Security, Streaming media, Transformers},
	pages = {1--7},
}

@inproceedings{hemalatha_deepfake_2025,
	title = {Deepfake {Detection} {Using} {Live} {Facial} {Analysis} for {Secure} {Folder} {Access} via {Web} {Interface}},
	doi = {10.1109/ICAAIC64647.2025.11330628},
	abstract = {This study presents a web-based secure access system that employs real-time facial analysis combined with deepfake detection to control access to private folders. The proposed framework leverages a hybrid deep learning model that integrates Convolutional Neural Networks (CNNs) for extracting spatial facial features with Long Short-Term Memory (LSTM) networks, supported by Multi-task Cascaded Convolutional Networks (MTCNN), for capturing temporal consistency and detecting subtle artifacts indicative of synthetic media. This dual-architecture approach enables the system to effectively distinguish between genuine live facial inputs and deepfake forgeries in real time. A comprehensive dataset containing both real and synthetically generated facial sequences was utilized for model training and evaluation. Experimental results demonstrate that the hybrid CNN-LSTM/MTCNN model achieved an accuracy of 94.2\%, significantly surpassing traditional CNN-only approaches, which attained 89\% accuracy. Statistical analysis using an Independent Samples t-test confirmed the improvement's significance, with a p-value {\textless} 0.000, indicating strong reliability of the performance gain. The system's design allows seamless integration into a browser-based interface, enabling immediate access decision-making without manual verification. This approach enhances biometric authentication security by mitigating spoofing attempts, including advanced AI-driven facial forgeries. Consequently, the proposed method offers robust protection against identity theft, presenting a scalable and practical solution for secure folder access in sensitive digital environments.},
	booktitle = {2025 4th {International} {Conference} on {Applied} {Artificial} {Intelligence} and {Computing} ({ICAAIC})},
	author = {Hemalatha, S. and Sivasundaram, Malatthi and P, Nithya and K, Kalaivendhan and K, Jestin M and T, Giri},
	month = dec,
	year = {2025},
	keywords = {Access Control, Accuracy, Convolutional neural networks, Convolutional Neural Networks, Deepfake Detection, Deepfakes, Face recognition, Facial Recognition, Feature extraction, Forgery, Live Face Analysis, Long short term memory, LSTM, Manuals, Real-time systems, Reliability, Secure Folder Access, Web-Based Security},
	pages = {342--347},
}

@inproceedings{c_comparative_2025,
	title = {Comparative {Analysis} of {Deep} {Learning} {Architectures} for {Robust} {Deepfake} {Detection} using {Transfer} {Learning}},
	doi = {10.1109/ICACRS67045.2025.11324347},
	abstract = {The technology of deepfakes poses significant threats to the digital security, the authenticity of media and population trust by creating very believable manipulated facial images and videos. With the advancement of the generative models, the existing detection techniques have been less useful, and they require robust and generalizable solutions. The paper provides a comparative study of the most notable deep learning models such as VGG19, ResNet50, XceptionNet and EfficientNet using transfer learning to successfully detect deepfakes. On a benchmark dataset (e.g. FaceForensics++ and Celeb-DF) a fine-tuning of each model is conducted using pre-trained ImageNet weights and subjected to multiple manipulation conditions. Detailed performance evaluations based on accuracy, precision, recall, F1-score and AUC metrics indicate that XceptionNet has better performance compared to the other models because it has depthwise separable convolutions and EfficientNet has a good balance between detection accuracy and efficiency. The analysis highlights the unique merits and shortcomings of each architecture and gives important observations towards the design of next generation scalable and real-time multimedia forensic systems.},
	booktitle = {2025 4th {International} {Conference} on {Automation}, {Computing} and {Renewable} {Systems} ({ICACRS})},
	author = {C, Thilagavathi and S, Harshivpranav R and C, Kishor and S, Muthuprakash and G, Vasanth},
	month = dec,
	year = {2025},
	keywords = {Accuracy, Convolutional Neural Networks, Deepfake Detection, Deepfakes, Explainability, Forensics, Multimedia Forensics, Next generation networking, Performance evaluation, Real-time systems, Renewable energy sources, Residual neural networks, Security, Transfer learning, Transfer Learning},
	pages = {1221--1227},
}

@inproceedings{rahman_chowdhury_deepfake_2025,
	title = {Deepfake {Detection} in {MIS}: {Leveraging} {DenseNet} and {Multi}-{Scale} {Information} for {Enhanced} {Digital} {Forensics}},
	doi = {10.1109/COMPAS67506.2025.11381812},
	abstract = {The artificially created media produced with the aid of artificial intelligence (AI), commonly referred to as deepfakes, are posing a serious challenge to the integrity of Management Information Systems (MIS). To achieve this, the paper proposes a new deep learning (DL) model, DGAF-Net (DenseNet + Gabor Attention Fusion Network), to enhance the accuracy of detecting such manipulated content. DGAF-Net incorporates DenseNet121, which is used to extract semantic features with the Gabor filter as a texture feature to generate this information through a Gated Attention Fusion Mechanism (GAFM). The pair of branches in this organization enables the successful detection of both local and global facial image anomalies, particularly in realistic scenarios with compression and noise. When tested on the FaceForensics++ dataset, the model attains a better accuracy of 88.33\%, which is better than current baselines, such as Vision Transformer (ViT-B16) and Swin Transformer + CNN fusion models. The findings demonstrate the validity, scalability, efficiency, and generality of DGAF-Net as a solution for real-time MIS digital forensics, as well as a scalable approach to deepfake methods that are becoming increasingly advanced.},
	booktitle = {2025 {IEEE} 2nd {International} {Conference} on {Computing}, {Applications} and {Systems} ({COMPAS})},
	author = {Rahman Chowdhury, Md Anisur and Rabbi Ahmed, Khandakar and Robin, Shahriar Alam and Nesar, Shah Tawkir and Salam, Towfika and Ahsan, Md. Naimul and Ansari, Md Eahia},
	month = oct,
	year = {2025},
	keywords = {Accuracy, Computational modeling, Deepfake Detection, Deepfakes, DenseNet121, Digital forensics, Digital Forensics, FaceForensics++, Feature extraction, Gabor filters, Gabor Filters, Gated Attention Fusion, Hybrid Deep Learning, Logic gates, Media, MIS, Multi-Scale Analysis, Semantics, Transformers, Vision Trans-former},
	pages = {1--6},
}

@inproceedings{singh_deepfake_2025,
	title = {Deepfake {Forensics} {Leveraging} {MobileNetV2} for {High} {Precision} {Detection}},
	doi = {10.1109/MECON67253.2025.11277038},
	abstract = {This Deepfake technology has emerged as a powerful tool for generating synthetic media, leveraging advancements in artificial intelligence and deep learning to create highly realistic fake images and videos. While deepfakes offer potential benefits in fields such as entertainment, media production, and virtual reality, they also present serious threats, including misinformation, identity fraud, and privacy violations. The ability to detect deepfake content accurately and efficiently is critical in safeguarding digital authenticity and preventing misuse. This research focuses on the development of deepfake detection models using Convolutional Neural Networks (CNNs) and MobileNetV2. Three primary detection methods— handcrafted feature analysis, machine learning-based classification, and artifact detection—were implemented and evaluated. A dataset consisting of 20,000 images, equally split between real and fake, was used for model training and testing, and optimized using dropout regularization, learning rate tuning, and early stopping. The CNN model achieved an accuracy of 90\%, while an optimized MobileNetV2 Subtraction model improved detection accuracy to 97\% by reducing overfitting and refining hyperparameters. The study underscores the importance of robust deepfake detection frameworks, particularly in an era where manipulated content is becoming increasingly difficult to differentiate from real media. Future enhancements will explore real-time detection solutions and adversarial training techniques to further improve detection accuracy and resilience.},
	booktitle = {2025 {Multimedia} {University} {Engineering} {Conference} ({MECON})},
	author = {Singh, Pallavi and Sasikumar, S. and Geddam, Ratna Sekhar and Tharun, K and Kavitha, M. and Bhuvaneswari, Thangavel},
	month = jul,
	year = {2025},
	keywords = {Accuracy, artificial intelligence, Computational modeling, Convolutional neural networks, Convolutional Neural Networks (CNN), Deep learning, Deepfake detection, Deepfakes, Feature extraction, misinformation, MobileNetV2, Real-time systems, Solid modeling, Testing, Training},
	pages = {1--6},
}

@inproceedings{purohit_ggmddc_2024,
	title = {{GGMDDC}: {An} {Audio} {Deepfake} {Detection} {Multilingual} {Dataset}},
	issn = {2640-0103},
	doi = {10.1109/APSIPAASC63619.2025.10848580},
	abstract = {Audio Deepfake Detection (ADD) is of critical concern due to its social relevance. The development of ADD solution faces the limitation of the low diversity of language resources and is restricted to a limited number of speakers. However, there is a need for a more reliable ADD system due to advancements in deepfake audio generation by the attackers. Most of the existing datasets for ADD task are limited to a language count, so their usage remains limited to restricted number of speakers. Also, in most of the existing datasets for ADD, the number of issue of some speakers’ real and deepfake exists, and others are unavailable. In this study, we implemented a configuring version of Generative Adversarial Networks (GANs), namely, High Fidelity-GAN, to create dataset, GAN-Guideded Multilingual Deepfake Detection Corpus(GGMDDC). We achieved Mean Openion Score (MOS) of 4.52 for the proposed system, which proved to be better than MOS of the existing systems.},
	booktitle = {2024 {Asia} {Pacific} {Signal} and {Information} {Processing} {Association} {Annual} {Summit} and {Conference} ({APSIPA} {ASC})},
