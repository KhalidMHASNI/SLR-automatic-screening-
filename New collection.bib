@inproceedings{le_lightweight_2025,
	title = {Lightweight {Audio}-{Visual} {Networks} for {Real}-{Time} {Lip}-{Sync} {DeepFake} {Detection}},
	doi = {10.1109/ICMT67823.2025.11298774},
	abstract = {Lip-sync DeepFakes, which manipulate lip movements to match tampered audio while preserving visual identity, pose significant challenges to digital content integrity due to their subtle temporal inconsistencies. Traditional detection methods focusing on spatial artifacts are often ineffective against these forgeries, while recent temporal correlation models, despite their accuracy, are computationally intensive and impractical for resource-constrained devices. This paper proposes a lightweight, real-time framework for lip-sync DeepFake detection, leveraging compact neural networks, temporal attention mechanisms, and knowledge distillation. Utilizing ShuffleNetV2x0.5 as the backbone, our model incorporates audio-visual temporal modeling and human-inspired perceptual cues, such as lip-speech synchronization, to achieve robust detection. Knowledge distillation transfers insights from a high-capacity teacher model to ensure high accuracy with a model size of only 18 MB and an inference speed of 20 FPS on standard CPUs, optimized for edge device deployment. Evaluated on the AVLIP and FakeAVCeleb datasets, our approach achieves 93.50\% average precision on AVLIP and 99.23\% average precision on FakeAVCeleb, rivaling state-of-the-art models while enabling real-time performance on edge devices. This framework is well-suited for applications like mobile video authentication, livestream monitoring, and content moderation, addressing the growing need for efficient and scalable DeepFake detection solutions.},
	booktitle = {2025 28th {International} {Conference} on {Mechatronics} {Technology} ({ICMT})},
	author = {Le, Quoc-Dat and Tran, Vu-Hoang and Nguyen, Viet-Dat},
	month = nov,
	year = {2025},
	keywords = {AudioVisual Synchronization, Computational modeling, Correlation, DeepFake Detection, Deepfakes, Forgery, Image edge detection, Lip-Sync Forgery, Lips, Monitoring, Real-time systems, Standards, Synchronization},
	pages = {102--107},
}

@inproceedings{kalpana_deepfake_2025,
	title = {Deepfake {Detection}: {A} {Hybrid} {Approach} {Integrating} {EfficientNetB4}, {Attention} {Mechanisms}, and {Vision} {Transformers}},
	doi = {10.1109/ICSIT65336.2025.11295016},
	abstract = {The rapid advancement of deepfake technologies poses significant threats to digital security, misinformation mitigation, and privacy preservation. Existing detection methods often struggle with generalization across diverse datasets and manipulation techniques. This paper proposes a hybrid deepfake detection framework that integrates EfficientNetB4, attention mechanisms, and Vision Transformers (ViTs) to enhance detection accuracy and robustness. For preprocessing, the proposed framework employs Fast Fourier Transform (FFT) and Local Binary Patterns (LBP) to derive distinctive features capturing both spatial and frequency domain information. EfficientNetB4 serves as the backbone for efficient hierarchical feature extraction, while attention mechanisms localize suspicious regions and ViTs model global contextual relationships. An ensemble strategy consolidates predictions across components. Evaluations on FaceForensics++, DFDC, and COCOFake datasets demonstrate superior performance, achieving 92.4\% accuracy, 0.912 F1-score, and 0.751 AUC on FaceForensics++. Comparative analysis shows improvements over XceptionNet (89.3\% vs. 92.4\% accuracy) and MesoNet (85.1\% vs. 92.4\%). Ablation studies confirm critical contributions from FFT (89.1 \% {\textbackslash}rightarrow 92.4 \% accuracy) and attention mechanisms (88.3 \% {\textbackslash}rightarrow 92.4 \%). The framework exhibits cross-dataset generalization with 89.7\% accuracy on DFDC and 87.4\% on COCOFake. This work advances robust deepfake detection through synergistic integration of convolutional networks, attention, and transformer architectures, providing an effective solution against evolving synthetic media threats.},
	booktitle = {2025 {International} {Conference} on {Sustainability}, {Innovation} \& {Technology} ({ICSIT})},
	author = {{Kalpana} and Singh, Kaushik and Kumar, Krish and Prajapati, Yogendra Narayan and Mishra, Kriti},
	month = aug,
	year = {2025},
	keywords = {Accuracy, Attention Mechanism, Attention mechanisms, COCOFake, Computer vision, Context modeling, Deepfake Detection, Deepfakes, DFDC, EfficientNetB4, Ensemble Learning, FaceForensics++, Fast Fourier Transform, Fast Fourier transforms, Image Preprocessing, Local Binary Pattern, Robustness, Security, Technological innovation, Transformers, Vision Transformer},
	pages = {1--7},
}

@inproceedings{karunarathna_video-centric_2025,
	title = {Video-{Centric} {Deepfake} {Detection}: {Leveraging} {Audio} and {Spatio}-{Temporal} {Features} for {Improved} {Accuracy}},
	issn = {2837-5424},
	doi = {10.1109/ICAC69156.2025.11361488},
	abstract = {Detecting deepfakes has become a critical challenge as a result of the growth of complex manipulated media and the potential to spread false information, erode public trust, and damage reputations. This paper presents a novel solution for deepfake detection by implementing a video-centric framework that leverages spatio-temporal features, with audio as a secondary modality to enhance robustness and accuracy. The proposed framework employs an R(2+1)D convolutional neural network to extract frame-based spatio-temporal patterns, and Mel-frequency Cepstral Coefficients (MFCCs) encoded using an LSTM network to produce audio features. These embeddings are combined using a late fusion strategy, followed by encoder freezing and fine-tuning the classifier layer to reduce prediction bias. Evaluated on FakeAVCeleb, CREMA-D, and Meta's Casual Conversations datasets, the model achieved 96.69\% test accuracy and a 0.9909 AVC-ROC score. These results demonstrate the system's robustness in detecting subtle and synchronized manipulated content. The proposed method contributes to improving the reliability of media authenticity in fields such as law, journalism, and cybersecurity. Although some current methods report slightly higher benchmark scores, our framework focuses on bias mitigation, robustness, and reproducibility for practical application.},
	booktitle = {2025 7th {International} {Conference} on {Advancements} in {Computing} ({ICAC})},
	author = {Karunarathna, Rasandi},
	month = dec,
	year = {2025},
	keywords = {Accuracy, audio-visual fusion, Convolutional neural networks, deepfake detection, Deepfakes, Feature extraction, Long short term memory, LSTM, Oral communication, Prevention and mitigation, R(2+1)D CNN, Reproducibility of results, Robustness, spatio-temporal features, Synchronization},
	pages = {1--5},
}

@inproceedings{yadav_ai-based_2025,
	title = {{AI}-{Based} {Image} {Forgery} {Detection} ({AI}-{IFD})},
	issn = {2769-2884},
	doi = {10.1109/ICRITO66076.2025.11241973},
	abstract = {Digital image manipulation has reached unprecedented sophistication with the advent of generative adversarial networks (GANs) and diffusion models, creating significant challenges for digital forensics and media verification. This paper presents AI-IFD (AI-based Image Forgery Detection), a novel multi-domain ensemble framework that combines spatial, frequency, and error-level analysis through attention-guided fusion mechanisms. Our approach integrates ResNet-50, VGG-16, EfficientNet-B0, and a custom JPEG-aware convolutional neural network using Bayesian-optimized soft weighting strategies. Enhanced with a four-layer Vision Transformer (ViT) neck for global context modeling, the system achieves robust detection capabilities while maintaining real-time processing speeds. Comprehensive evaluation on FaceForensics++, DFDC, CelebDF, and a custom 38k-image dataset demonstrates superior performance with {\textbackslash}text9 0. 8 \% accuracy, {\textbackslash}text0. 9 5 2 AUC-ROC, and {\textbackslash}text1 8. 1 m s inference time on 224 {\textbackslash}times 224 images. The framework exhibits exceptional adversarial robustness, maintaining 72.3 \% accuracy under FGSM attacks and 55.6 \% under PGD attacks, representing significant improvements over existing approaches. These results validate multi-domain fusion coupled with attention mechanisms as a promising direction for real-time, adversary-aware image forgery detection.},
	booktitle = {2025 12th {International} {Conference} on {Reliability}, {Infocom} {Technologies} and {Optimization} ({Trends} and {Future} {Directions}) ({ICRITO})},
	author = {Yadav, Nitu and Sheoran, Savita},
	month = sep,
	year = {2025},
	keywords = {Accuracy, adversarial robustness, attention mechanisms, Bayes methods, computer vision, Computer vision, deepfake detection, digital forensics, Digital forensics, ensemble learning, Forgery, Image forgery detection, Media, Real-time systems, Robustness, Training, Transformers},
	pages = {1--7},
}

