	doi = {10.1109/ICECONF65644.2025.11379633},
	abstract = {There is a need to apply spoofing and malicious attack-resistant biometric authentication solutions to protect financial information retained in online banking systems. This paper presents a scheme for efficient voice authentication that utilizes a blend of CapsNets and CNNs. The scheme efficiently extracts speaker-specific audio patterns and spatial hierarchies using Mel-spectrogram representations, as opposed to sequential models. A proprietary dataset of over 15,000 utterances collected in a multitude of contexts is used for training and validation. An adversarial voiceprint perturbation module and an anti-spoofing branch are incorporated within the model in order to recognize manipulated or forged voice inputs. Experimental results outperform the LSTM and x-vector baselines in terms of improved spoof resistance, with an accuracy of 97.83\%, an equal error rate of 1.78\%, and a detection accuracy of 96.91\%. The method is apt for use in mobile banking applications due to its real-time voice authentication speed and security.},
	booktitle = {2025 2nd {International} {Conference} on {Artificial} {Intelligence} and {Knowledge} {Discovery} in {Concurrent} {Engineering} ({ICECONF})},
