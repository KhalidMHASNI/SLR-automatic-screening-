	pages = {1989--1995},
}

@inproceedings{sunitha_lightweight_2025,
	title = {Lightweight {Vision} {Transformer} for {Deepfake} {Image} {Detection} in {Messaging} {Apps}},
	doi = {10.1109/ICECMSN68058.2025.11383514},
	abstract = {The rapid advancement of deepfake generation techniques has posed a huge challenge to the security of digital communication and above all, the messaging apps where the content can be manipulated and distributed in a split second. Existing detection methods, which mostly rely on Convolutional Neural Networks (CNNs), have a set of limitations to their adaptability, computational efficiency, and resistance against the evolving forgery methods. This paper suggests a Lightweight Vision Transformer (L-ViT) that would be a streamlined solution dedicated to the deepfake detection task in constrained resource solutions. The model uses adaptive multi-scale receptive fields with self-attention to identify local and global discrepancies in manipulated media at relatively no parameter reduction and low computational complexity. The L-ViT is trained on augmented datasets and with transfer learning, boasts better results than CNN baselines as well as similar accuracy compared to full-scale Vision Transformers with an accuracy of 94.1\% and 0.97 AUC-ROC on benchmark datasets. Tests of robustness against benign transformations which include resizing, compression and noise verify the robustness of the model with slight performances. The identified approach is accurate, flexible, and effectively finds the right balance that enables edge devices to detect deepfake threats in real-time communication networks.},
	booktitle = {2025 5th {International} {Conference} on {Evolutionary} {Computing} and {Mobile} {Sustainable} {Networks} ({ICECMSN})},
	author = {Sunitha, G. and Mahapatro, Prabhash and Madhavi, Juturu Bindu and Thanuja, Mandlukose and Jagadish, Dyvamdinne and Depuru, SivaKumar},
	month = nov,
	year = {2025},
	keywords = {Accuracy, Computer vision, Convolutional neural networks, Deepfake Detection, Deepfakes, Efficient SelfAttention, Image edge detection, Lightweight Vision Transformer (L-ViT), Noise, Performance evaluation, Real-time systems, Robustness, Transformers, Vision Transformer, Xception},
	pages = {662--667},
}

@inproceedings{kavuturu_hybrid_2025,
	title = {A {Hybrid} {SNN} {Model} for {Detection} of {Face}-{Swap} {Deep} {Fake} {Videos}},
	doi = {10.1109/ICFT66708.2025.11336395},
	abstract = {In this research, a novel technique to differentiate face swap deepfakes in videos is proposed using the Hybrid CNN-SNN model, referred to as “A Hybrid SNN model for Face-Swap Deepfake Detection”. The objective is to improve spatial and temporal detection of face-swapped manipulations using a dual neural architecture. Spatial feature extraction is performed by the CNN (Convolutional Neural Network) component, leveraging variability in facial texture, light, and expression. Temporal analysis is executed by the SNN (Spiking Neural Network) component, identifying abnormalities such as unnatural blinking patterns and head movements. The model was trained on the Face Forensics++ dataset consisting of 1000 labeled samples for both real and fake data. With a training loss of 0.3 and validation loss of 0.6, the model achieved training accuracy of 90\% and validation accuracy of 80\%, demonstrating promising results. These results indicate strong performance, particularly in capturing subtle temporal artifacts. However, they also highlight limitations such as high computational cost, limited generalizability to newer deepfake techniques, and challenges in real-time deployment on edge devices. The proposed method shows potential for forensic and security applications, especially in low-resource environments where SNNs perform well with temporal data since they inherent energy efficiency and low-latency temporal processing to the approach. Future work will focus on enhancing model robustness and generalization by diversifying datasets and optimizing for deployment on robotics and IoT.},
	booktitle = {2025 {International} {Conference} on {Future} {Technologies} ({ICFT})},
	author = {Kavuturu, Blessy and Patil, Arpita Umesh and Movaliya, Meet and T, Padmavathy},
	month = nov,
	year = {2025},
	keywords = {Accuracy, Analytical models, CNN, Computational modeling, Convolutional neural networks, Deepfake, Deepfakes, Face-swap detection, Faces, Forensics, Hybrid model, Performance evaluation, Real-time deployment, Real-time systems, SNN, Spatial analysis, Temporal analysis, Training, Video analysis},
	pages = {1--7},
}

@inproceedings{v_deepfake_2025,
	title = {Deepfake {Detection}: {Bi}-{LSTM} {Framework} with {MobileNetV2}},
	doi = {10.1109/ICETCE66848.2025.11388101},
	abstract = {The combination of state-of-the-art deep learning technology which produces deepfakes causes major trust issues that affect people's ability to believe in digital materials. Most established detection methods analyze complete video frames even though they contain considerable useless background information. Such detection techniques perform worse while using more computational resources which makes them unpractical for real-time processing under resource-limited conditions. The proposed framework operates in real-time to detect deepfake changes specifically in facial areas because this is where the most likely fake modifications take place. The first step of the model uses Haar Cascade Classifiers to detect faces and separate them from the video frames. The facial regions undergo processing via MobileNetV2 to accomplish spatial feature extraction. A Bidirectional Long Short-Term Memory (Bi-LSTM) network serves as part of the model to detect temporal inconsistencies found between video sequences because they act as synthetic content indicators. The model uses an attention mechanism to improve understanding and channel its analysis toward essential temporal video segments. The system assessment on Celeb-DF (v2) yielded 95.55 \% accuracy along with 89 \% F1-score, 82 \% precision and 97 \% recall. The system demonstrates high efficiency for differentiating between genuine and fake video footage. The model demonstrates optimized performance with minimal processing requirements which enables its real-time use in digital forensic probes as well as media authentication checks and safeguarding applications during security operations. This study suggests an efficient approach to counter the dangeroud deepfake threats through the combination of facial area extraction and deep learning spatial interpretation and sequence-level time research. The proposed system delivers high precision in detection and maintains sufficient lightness to work effectively in mobile and edge computational platforms.},
	booktitle = {2025 8th {International} {Conference} on {Emerging} {Technologies} in {Computer} {Engineering}: {Advances} in {Computing}, {Healthcare} and {Smart} {Systems} ({ICETCE})},
	author = {V, Premanand and S, Akil and S, Aniruth Narayanan},
	month = nov,
	year = {2025},
	keywords = {Adaptation models, Computational modeling, Computer architecture, Convolutional neural networks, Convolutional Neural Networks (CNN), Deep learning, Deepfake detection, Deepfakes, Digital forensics, Feature extraction, LSTM, Media, MobileNetV2, Optical Flow, Real-time systems, Transfer Learning Data Augmentation},
	pages = {44--50},
}

@inproceedings{ameer_cnn_2025,
	title = {{CNN} vs. {Transformer}-{Based} {Models} for {Deepfake} {Detection}: {A} {Comparative} {Analysis}},
	doi = {10.1109/ICMI65310.2025.11141105},
	abstract = {As deepfake technology has rapidly progressed, it has become a concern for media authenticity, cybersecurity, and digital forensics. In this work, we compare and contrast CNNs and Transformer-based architectures for deepfake detection. Compare 5 models (XceptionNet, ResNet-50, EfficientNet-B3, Vision Transformer (ViT-B/16), ConvNeXt-Small) + Deepfake Detection Challenge. Our study shows that both XceptionNet and ResNet-50 performed better than the existing model by reaching about 96\% accuracy, where XceptionNet is best in precision (0.98) and ResNet-50 is best in recall (0.97). On the other hand, EfficientNet-B3 and ViT-B/16 reach an accuracy of 93 \% and 90\%, respectively, emphasizing the tradeoff between CNN's efficiency and Transformer's feature extraction. ConvNeXt-Small is the one performing the worst, at 85 \% accuracy, suggesting that the modern approaches of CNN-Transformer hybrids are not the best for deepfake detection. These findings imply that CNN architectures represent the most efficient paradigm for deepfake detection and can be further enhanced by techniques such as ensemble learning and adversarial training. Future work will explore the robustness of the model against adversarial deepfakes and real-time detection efficiencies.},
	booktitle = {2025 {IEEE} 4th {International} {Conference} on {Computing} and {Machine} {Intelligence} ({ICMI})},
	author = {Ameer, Noor Hayder Abdul and Al-Taee, Mustafa and Hussain, Abadal Salam T. and Hussian, Ahmed and Ali, Haider},
	month = apr,
	year = {2025},
	keywords = {Accuracy, AdamW Optimizer, Analytical models, Autonomous Driving, Computational modeling, Data models, Deepfakes, Feature extraction, Hyperparameter Cosine Annealing, Real-time systems, Regularization Techniques, Robustness, Training, Transformers, Yolov9},
	pages = {1--5},
}

@inproceedings{zhang_deepfake_2021,
	title = {Deepfake {Detection} {Based} on {Incompatibility} {Between} {Multiple} {Modes}},
	doi = {10.1109/ICITES53477.2021.9637096},
	abstract = {We propose a multi-modal detection for deepfake videos, called the Incompatibility Between Multiple Modes (IBMM) detection. The detection algorithm can detect whether the video is real or fake, and may be embedded in the monitoring equipment in the future. The model adopts EfficientNet and simple 3D-CNN, and it identifies deepfake videos through three modes. In the facial motion mode and lip motion mode, we use the EfficientNet for feature learning. This network uses a series of fixed scaling coefficients to scale the dimensions of the network uniformly and achieves good results in learning image features. In the audio mode, we adopt 3D-CNN network to train the hot coding diagram of audio data. Besides, for a single mode, we use the cross-entropy loss to calculate the irrationality of the mode. For different modes, the contrastive loss is used to calculate the incongruity between the modes, such as incompatibility between lips and voice. Experimental results show that, compared with other existing fake detection methods, the method presented in this paper has higher accuracy (95.87\%) on DFDC datasets. And compared with the existing methods, the accuracy increases by 5.21\%.},
	booktitle = {2021 {International} {Conference} on {Intelligent} {Technology} and {Embedded} {Systems} ({ICITES})},
	author = {Zhang, Yuxin and Zhan, Jinyu and Jiang, Wei and Fan, Zhufeng},
	month = oct,
	year = {2021},
	keywords = {Deepfake detection, Efficientnet\_b3, Indexes, Lips, Market research, multimodal learning, Representation learning, Statistical analysis, Synchronization, Training},
	pages = {1--7},
}

@inproceedings{jadhav_unmasking_2024,
	title = {Unmasking the {Illusion}: {A} {Novel} {Approach} for {Detecting} {Deep} {Fakes} using {Video} {Vision} {Transformer} {Architecture}},
	doi = {10.1109/ACOIT62457.2024.10939366},
	abstract = {Deepfakes are fake images, videos, audio, and text content that appear to be real. They are now easier than ever to create because of different AI tools. They aregenerally legal and have legitimate applications in many areas, but now a days they are commonly used for exploitation. Anyone can use deepfake tools to create fakevideos or images that spread misinformation, harass andintimidate others, and ultimately ruin people’s lives. Facial mapping technologies are used by Cyber criminals to create an accurate facial symmetry data set. They swapthe face of a person on to the face of another person. To tackle this problems, we propose this Deepfake Detection System. Key feature of our model is to classify the given input video into real or fake class. Our model will detect weather the given video is real one or is generated (manipulated) by deepfake generation techniques. Existing methodology related to deepfake detection involves various techniques. Currently, existing detection systems are using Convolutional Neural Networks (CNN) as a backbone, artificial neural networks (ANN), Recurrent Neural Network (RNN) algorithms. Each having its own benefits, drawbacks and related accuracy.We are trying to integrate two of these techniques i.e, Convolutional Neural Network and Vision Transformer. Basic aim to integrate or merge two techniques is to modify or increase the accuracy of model.},
	booktitle = {2024 {Asian} {Conference} on {Intelligent} {Technologies} ({ACOIT})},
	author = {Jadhav, Archana and Narale, Dhaval and Kore, Rokdeshwar and Shisode, Ujjwal and Kulange, Abhijeet},
	month = sep,
