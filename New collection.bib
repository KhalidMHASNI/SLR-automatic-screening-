	keywords = {Convolution Neural Networks (CNN), Convolutional neural networks, Deep Fake Detection, Deep learning, Deep Learning, Deepfakes, Faces, Fake and Real Images \& Videos, Feature extraction, Long short term memory, Long Short-Term Memory (LSTM), Media, Neural networks, Residual neural networks, Security},
