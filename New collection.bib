	keywords = {Accuracy, adversarial audio, Artificial intelligence, Authentication, CapsNet, capsule routing, CNN, Immune system, Online banking, Real-time systems, Routing, speaker verification, Speech recognition, Speech synthesis, spoof detection, Training, voice authentication, Voice biometrics},
	pages = {1--8},
}

@inproceedings{autade_ai_2025,
