@inproceedings{fathima_nuska_ai_2025,
	title = {{AI} {Generated} {Audio} {Detection} {Using} {Acoustic} {Audio} {Features}},
	issn = {2831-3399},
	doi = {10.1109/ICITR69413.2025.11353634},
	abstract = {The rapid advancement of artificial intelligence in text-to-speech technologies has led to highly realistic AI generated voices, raising concerns about audio deepfakes and their potential misuse in misinformation and identity fraud. This study presents a deep learning-based approach for detecting AI-generated audio by analyzing key acoustic features. A balanced dataset was collected using human speech from the CREMA-D dataset and AI generated audio from advanced TTS systems. Features such as 12 Mel Frequency Cepstral Coefficients, pitch, zero- crossing rate, spectral centroid, and spectral bandwidth were extracted. A Convolutional Neural Network was trained on these features, achieving 98\% accuracy in distinguishing human from AI-generated audio. The model captures subtle differences in tone, pitch, and frequency patterns, offering a scalable and effective solution for AI generated speech detection. This research advances audio forensics and supports practical applications in media verification, voice authentication, and legal investigations.},
	booktitle = {2025 10th {International} {Conference} on {Information} {Technology} {Research} ({ICITR})},
	author = {Fathima Nuska, Mohamed Fayik and Firdhous, Mohamed Fazil Mohamed},
