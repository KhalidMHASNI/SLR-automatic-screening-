	issn = {2473-7674},
	doi = {10.1109/ICCCNT61001.2024.10724156},
	abstract = {Fake news that is propagated in this era is a very important issue. It has widespread effects on denorphising the public trust, transmitting wrong or false information, damaging the stability of society as whole. These type of news are shared easily in a short time, which is seen in the social media platforms. There can be misinformation and manipulation of a massive number of people. To address this issue, we primarily focused on the fake news detections with deep learning models. In this work we investigate using five most image models which are Swin, ConvNeXt, VGG-19, BEiT and ResNet-50, which can be helpful in linear or non-linear ways for fake news detections, it can be a feature extraction process also, which might help in improving the detection performances of anti-fake news detectors and it also can be helpful to see the data easily and introduce experiments that might improve the robustness. Here, we are reporting this methodology to detect the fake news using these five image models for extracting the features and feeding the extracted features into the multi-layer perceptron (MLP) to classify the given news is either real as fake or not. We performed experiments using the IFND dataset and tested our multi-faceted feature extraction strategy which has proven to be effective. Each model has its own potential and it makes a difference in itself, producing it’s unique manufactured model and it could represents it’s own diverse visually rich representations which can be very useful in discriminating fake news. To show the proof of concept, improving the impicity of discriminating towards detecting fake news by using different image models, we extensively performed a comparison analysis for the state-of-the-art image models. By these extensive analysis, we attained the test accuracy of 88.66\% on using Convnext-Tiny architecture and 91\% F1 score while using the swin transformer architecture. The extensive analysis provides the relative advantages and disadvantages of the image models. This work gives a solid and powerful approach to tackle the spreading of fake news and sets a new benchmark to the research community in future research related to fake news detection. The work demonstrates the robust and effective fake news detection methods for precise information diffusion.},
	booktitle = {2024 15th {International} {Conference} on {Computing} {Communication} and {Networking} {Technologies} ({ICCCNT})},
	author = {Tufchi, Shivani and Yadav, Ashima and Ahmed, Tanveer},
	month = jun,
	year = {2024},
	keywords = {Accuracy, Analytical models, BEiT, CNN, Convnext, Fake news, Feature extraction, IFND, Image, Real-time systems, Resistance, ResNet50, Robustness, Solids, Stability analysis, Transformers, VGG-19, Vision Transformer},
	pages = {1--7},
}

@inproceedings{arumugam_capsnetcnn_2025,
