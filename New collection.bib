	year = {2025},
	keywords = {Accuracy, Audio Forensics, Auto-Tune Detection, Bidirectional long short term memory, Bidirectional Long Short-Term Memory (BiLSTM), Computational modeling, Computer architecture, Convolutional neural networks, Convolutional Neural Networks (CNNs), Deepfake Audio Detection, Deepfakes, Forensics, Mel frequency cepstral coefficient, Neural networks, Real-time systems},
	pages = {1--6},
}

@inproceedings{soudan_comparative_2025,
	title = {Comparative {Study} of {Swin} and {Dilated} {Neighborhood}-{Attention} {Transformers} for {Deep}-{Fake} {Forensics}},
	issn = {2521-1641},
	doi = {10.1109/UBMK67458.2025.11206970},
	abstract = {The proliferation of facial deepfakes poses an escalating threat to digital trust. While transformer backbones consistently outperform convolutional networks in forgery detection, there remains no consensus on which hierarchical design best balances accuracy and efficiency. This work presents the first systematic comparison of two leading architectures—the Swin Transformer and the Dilated Neighborhood Attention Transformer (DiNAT)—evaluated under a controlled 20-epoch fine-tuning schedule with frozen backbones on two benchmarks: OpenForensics and a frame-level split of FaceForensics++. On this schedule, Swin–Large achieves 91.8\% accuracy (0.918 F1) on FaceForensics++ and 89.1\% accuracy on OpenForensics, outperforming the best DiNAT variant by 8.6 and 2.6 percentage points in F1, respectively. DiNAT reduces floating-point operations by approximately 12\% and decreases inference latency by 3 ms (around 10\% faster on a T4 GPU), demonstrating its efficiency advantage. These results highlight the trade-off between accuracy and computational efficiency, and offer insight into architecture selection for deepfake forensics.},
	booktitle = {2025 10th {International} {Conference} on {Computer} {Science} and {Engineering} ({UBMK})},
	author = {Soudan, Masa and Damash, Abduallah},
	month = sep,
	year = {2025},
	keywords = {Accuracy, Computational modeling, Deepfake detection, Deepfakes, DiNAT, Forensics, Forgery, Neighborhood Attention, Real-time systems, Schedules, Swin, Systematics, Transfer learning, Transfer Learning, Transformers, Vision Transformer},
	pages = {981--986},
}

@inproceedings{duraimurugan_multimodal_2025,
	title = {A {Multimodal} {Deep} {Fake} {Detection} {Framework} for {Robust} and {Efficient} {Synthetic} {Media} {Identification}},
	doi = {10.1109/I2ITCON65200.2025.11210532},
	abstract = {The fast pace of deep fake technology poses digital integrity risks by facilitating hyper-realistic synthetic media, resulting in misinformation, identity theft, and security violations. Current detection systems lack robustness, generalization, and real-time efficiency and frequently fail against adversarial attacks. This paper presents a multimodal deep fake detection framework that combines spatial, temporal, and sequential analysis through cutting-edge deep learning methods. The model utilizes adaptive preprocessing, multi-scale feature representation, and temporal self-attention mechanisms to improve detection accuracy and robustness. Hybrid architecture integrating EfficientNetV2, a lightweight 3D CNN, and Bi-LSTM with Transformer layers provides better anomaly detection along with computational efficiency. The proposed approach provides improved accuracy in detecting subtle deep fake artifacts, better robustness against changing forgery attacks, and optimized efficiency for realworld applications. Experimental results prove to be better than current alternatives, further enhancing trust in digital content and boosting defences against synthetic media threats.},
	booktitle = {2025 {International} {Conference} on {Information}, {Implementation}, and {Innovation} in {Technology} ({I2ITCON})},
	author = {Duraimurugan, N and Kumar, P and Jayaprakash, R},
