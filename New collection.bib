	pages = {351--356},
}

@inproceedings{zafar_temporalformer_2025,
	title = {{TemporalFormer}: {Enhanced} {EfficientFormer} for {Real}-{Time} {Deepfake} {Detection} on {Edge} {Devices}},
	issn = {2766-2101},
	doi = {10.1109/CONECCT65861.2025.11306439},
	abstract = {The rapid proliferation of deepfake videos, forged multimedia, tampered contents across social media and other communication platforms poses significant challenges to digital security and information authenticity, necessitating effective detection mechanisms, particularly on mobile platforms. Deepfake videos increasingly undermine digital trust, but most detection methods depend on resource-heavy cloud systems, unsuitable for real-time use on edge devices. We present TemporalFormer, an enhanced EfficientFormerV2 model, optimized for fast and accurate deepfake detection directly on mobile and edge platforms. TemporalFormer analyzes video streams by extracting 30 equidistant frames from a 6 -second window by capturing a frame from live screen at 200 ms intervals and processing a batch of 30 frames in single prediction. This enables real-time processing of dynamic content like video calls, social media feeds, and video conferences. This lightweight framework integrates EfficientFormerV2’s feature extraction with positional encoding and a 1D CNN layer to model temporal dependencies, achieving an inference time of 20 ms per batch. Trained and tested on Celeb-df(v2), TemporalFormer attains an accuracy of 93.2 \% and an AUC of 0.90, while demonstrating robust generalization with an AUC of 0.87 on the FaceForensics++ dataset during crosscorpora analysis, surpassing baselines such as Xception and EfficientNet-B0 in both performance and efficiency. By offering a scalable, offline solution, TemporalFormer enables robust, ondevice video forensics for resource-constrained environments.},
	booktitle = {2025 {IEEE} {International} {Conference} on {Electronics}, {Computing} and {Communication} {Technologies} ({CONECCT})},
	author = {Zafar, Aarif and Singh, Kartik and Manav, Udit and Panda, Rajesh Kumar and Sahni, Nikhil and Nair, Renju Chirakarotu},
	month = jul,
	year = {2025},
	keywords = {Accuracy, Computer vision, Deepfakes, Edge computing, Encoding, Feeds, Forensics, Image edge detection, Mobile computing, Performance evaluation, Real-time systems, Social networking (online), Temporal difference learning, Video Analysis, Vision transformers},
	pages = {1--6},
	annote = {11th International Conference on Electronics Computing and Communication Technologies-CONECCT-Annual, INDIA, JUL 10-13, 2025},
}

@inproceedings{sunil_frequency_2025,
	title = {A {Frequency} {Aware} {Attention} {Driven} {Deepfake} {Detection} {Framework} {Using} {YOLOv8}},
	doi = {10.1109/ICONAT66879.2025.11362738},
	abstract = {The rapid advancement of generative adversarial networks (GANs) has resulted in an increase in the development of extremely realistic deepfake content., posing serious threats to digital media integrity and public trust. In response to the limitations of spatial domain only analysis in existing detection methods, this paper introduces a novel framework that integrates a Frequency Aware Attention mechanism into the YOLOv8 architecture for robust and efficient deepfake image detection. The proposed model jointly leverages spatial and frequency domain cues to enhance feature discrimination, enabling it to capture subtle inconsistencies introduced during image synthesis. By incorporating frequency aware attention modules, the framework directs the model's focus toward high frequency artifacts and manipulation traces often overlooked by traditional detectors. YOLOv8 ensures real time detection capabilities with high precision, making the system suitable for deployment in practical surveillance and content moderation scenarios. Experimental evaluations conducted on OpenForensics dataset demonstratethat our approach outperforms previous baseline models with a state-of-the-art accuracy of 98.74 \% while keeping inference time low. This research underscores the value of combining frequency insights with attention driven architectures for effective deepfake detection.},
	booktitle = {2025 {IEEE} 4th {International} {Conference} for {Advancement} in {Technology} ({ICONAT})},
	author = {Sunil, Reshma and Mer, Parita and Parmar, Parth},
	month = sep,
	year = {2025},
	keywords = {CNN, DCT, Deepfake Detection, Deepfakes, Feature extraction, Feature Fusion, Frequency Aware Attention, Frequency-domain analysis, GANs, High frequency, Image forensics, Image Forensics, Image synthesis, Media, Real-time systems, RealTime Detection, Spatial Frequency Feature, Surveillance, Wavelet Transform, Wavelet transforms, YOLOv8},
	pages = {1--8},
}

@inproceedings{haider_enhancing_2025,
	title = {Enhancing {Deepfake} {Detection} with {CBAM}-{Integrated} {CNN} {Models}},
	doi = {10.1109/ICICI65870.2025.11069856},
	abstract = {The proliferation of deepfake content poses a growing threat to public trust, digital security, and information integrity. This paper presents a novel deepfake detection approach based on a Convolutional Neural Network enhanced with a Convolutional Block Attention Module (CBAM-CNN). Unlike traditional models that rely on broad visual cues or handcrafted features, the proposed architecture leverages attention mechanisms to selectively amplify manipulation-specific signals in both spatial and channel dimensions. We evaluate our model on a reduced version of the OpenForen-sics dataset, which includes high-resolution, diverse manipulations created through a GAN-based face-swapping pipeline with refined blending masks. The proposed CBAM-CNN achieves an AUC of 0.958 and an overall accuracy of 89\%, outperforming baseline CNN architectures in precision and consistency. By reducing false positives and adapting effectively to complex facial forgeries, our approach demonstrates strong generalization and reliability across unseen test samples. This work contributes to the advancement of secure AI applications and digital media forensics by offering an interpretable, efficient, and scalable solution for deepfake detection.},
	booktitle = {2025 3rd {International} {Conference} on {Inventive} {Computing} and {Informatics} ({ICICI})},
	author = {Haider, Mohammad Izhar and Singh, Upasna},
	month = jun,
