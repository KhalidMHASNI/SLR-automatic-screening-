	keywords = {Asia, Audio Deepfake Detection, Cultural differences, Deepfakes, Faces, Generative adversarial networks, HiFi-GAN, Information processing, Mel Spectrogram, Multilingual, Multilingual Deepfakes, Reliability},
	pages = {1--6},
}

@inproceedings{sunil_audiolyt_2025,
	title = {Audiolyt: {A} {Lightweight} {Real}-{Time} {Framework} for {Deepfake} and {Auto}-{Tuned} {Audio} {Detection}},
	doi = {10.1109/NetACT65906.2025.11187839},
	abstract = {The increasing prevalence of synthetic and autotuned speech has introduced significant challenges in audio authenticity verification. This paper presents Audiolyt, a lightweight, real-time framework for detecting deepfake and auto-tuned audio samples. Leveraging handcrafted audio features such as MFCC, Chroma, and Spectral Contrast, and a densely connected neural network (DNN), Audiolyt achieves a classification accuracy of {\textbackslash}mathbf8 6. 8 3 \%. The system is trained on a composite dataset combining ASVspoof 2019, SceneFake, and custom-generated autotuned samples using legacy songs and Audacity. Audiolyt is deployed as a web application using Flask and Render, offering real-time inference with minimal latency. Experimental results show that the DNN model outperforms CNN and BiLSTM-based architectures while maintaining low computational overhead, making Audiolyt suitable for deployment in constrained or embedded environments.},
	booktitle = {2025 {International} {Conference} on {Networks} \& {Advances} in {Computational} {Technologies} ({NetACT})},
	author = {Sunil, K.S. and M, Gourinandhan and M, Gourinathan and Mohan, Hitha S and Roy, Rona},
