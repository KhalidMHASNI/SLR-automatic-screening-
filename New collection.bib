@inproceedings{l_s_leveraging_2025,
	title = {Leveraging {3D} {CNNs} for {Robust} {Detection} of {GAN}-{Generated} {Medical} {Image} {Forgeries}},
	doi = {10.1109/ICSCC66177.2025.11233624},
	abstract = {Medical images play a pivotal role in today’s health sector. With the advancement of technologies, clinical images from imaging devices are communicated to doctors or radiologists in real time via the Internet. However, this makes clinical images susceptible to tampering attacks. With the emergence of adversarial network architectures, generating deepfake content has become facile. Malicious actors may manipulate medical images to make false insurance claims, provide incorrect diagnoses, or even endanger someone’s life. Adversarial network poses a serious threat as they blur the line between authentic and manipulated images, making it difficult for doctors to discern the real from the fake. This paper proposes an efficient a nd robust 3D CNN model that helps the healthcare sector to distinguish real and tampered medical images. The proposed architecture performed well with a remarkable accuracy of {\textbackslash}mathbf9 2. 7 7 \%, {\textbackslash}mathbf9 3. 7 8 \% precision, and 92.60 \% F1 score. Furthermore, this 3D CNN model performs well when compared to the existing model. This study reveals that tampering with medical images using adversarial networks can be detected utilizing 3DCNNs.},
	booktitle = {2025 11th {International} {Conference} on {Smart} {Computing} and {Communications} ({ICSCC})},
	author = {L S, Sandhya and Ramanujan, Ajeesh},
	month = jul,
	year = {2025},
	keywords = {3D-CNN, Accuracy, Computer architecture, Deepfakes, Forgery, GAN, Medical Deepfakes, Medical diagnostic imaging, Medical image forgery detection, Medical services, Network architecture, Real-time systems, Solid modeling, Three-dimensional displays},
	pages = {1--7},
}

@inproceedings{madival_sajjan_advancements_2025,
	title = {Advancements in {Fake} {News} {Detection}: {A} {Review} of {Machine} {Learning} and {Deep} {Learning} {Approaches}},
	doi = {10.1109/ICFT66708.2025.11336485},
	abstract = {The rapid proliferation of fake news on digital platforms has emerged as a global challenge, influencing elections, shaping public perception, and undermining trust in media. The review synthesizes 40 peer-reviewed studies on fake news detection (FND) published between 2017 and 2025. Studies were selected through a systematic search of IEEE Xplore, ACM Digital Library, Scopus, and SpringerLink using pre-defined keywords. Early research focused on traditional ML techniques and propagation-based models, while recent advances incorporate hybrid architectures, transformers, graph neural networks, and multimodal frameworks. The review is organized thematically into six categories: graph- and propagation-aware models, transformer- and embedding-based classifiers, hybrid and ensemble approaches, traditional ML and multilingual methods, comparative and explainable frameworks, and dataset and taxonomy developments. Key findings highlight improvements in scalability, semantic understanding, and contextual modeling, with state-of-the-art accuracies exceeding 95-99\% on benchmark datasets such as LIAR, FakeNewsNet, and GossipCop. Despite these advances, persistent challenges remain, including multilingual generalizability, dataset bias, real-time adaptability, and vulnerabilities to AI-generated misinformation. This review contributes by identifying research gaps and proposing future directions, including multilingual benchmarks, explainable AI, vision-language transformers, and privacy-preserving detection methods.},
	booktitle = {2025 {International} {Conference} on {Future} {Technologies} ({ICFT})},
	author = {Madival Sajjan, Sagar and Kishan Chavan, Manik},
	month = nov,
	year = {2025},
	keywords = {Adaptation models, Benchmark testing, Context modeling, Deep learning, Deep Learning, Fake news, Fake News Detection, Graph Neural Networks, Machine Learning, Multilingual, Reviews, Scalability, Semantics, Transformers},
	pages = {1--8},
}

@inproceedings{skaiky_ai-driven_2025,
	title = {{AI}-{Driven} {Adaptive} {Learning} {Systems}: {Personalizing} {Education} {Through} {Dynamic} {Difficulty} {Adjustment}},
	doi = {10.1109/ICMI65310.2025.11141264},
	abstract = {AI is currently transforming educational practices in the field through personalized learning experiences by dynamically adapting the learning process. This paper presents an 'AI-Powered Adaptive Learning System' capable of adjusting the difficulty of educational content in real time according to student performance. For this purpose we simulate two cohorts of learners, one a control receiving only instructional material, while the other uses the adaptive systemto examine the effects of using a dynamic difficulty adjustment system to improve learning. Synthetic pre-test/post-test data were generated and statistical analysis showed that when an adaptive system was used, student performance was significantly enhanced, with the experimental cohort showing significantly greater improvements than the control cohort ({\textbackslash}mathrmp{\textless}0.0001). These initial results underscore the potential of AI-driven personalized learning systems to modulate challenge optimally, promoting learner engagement and effectiveness. Finally, in ongoing work, we validate these results in real-world experiments, and explore how the framework can be extended to accommodate a variety of other learning modalities.},
	booktitle = {2025 {IEEE} 4th {International} {Conference} on {Computing} and {Machine} {Intelligence} ({ICMI})},
	author = {Skaiky, Ahmad ali and Ali, Hanan Mahmood Shukur and Mohammed, Aymen and Mahdi, Zalzala Ali},
	month = apr,
	year = {2025},
	keywords = {Adaptation models, Adaptive learning, Adaptive systems, Bayesian search, CNN, Deepfake detection, Hyperparameter optimization, Learning systems, Machine intelligence, Machine learning, Optuna, Real-time systems, Statistical analysis, Synthetic data, Transformer, Transformers},
	pages = {1--5},
}

@inproceedings{baird_trueear_2025,
	title = {{TrueEar}: {A} {Lightweight} and {Accurate} {Fake} {Voice} {Detector} for {Mobile} {Devices}},
	doi = {10.1109/CBMI66578.2025.11339332},
	abstract = {Recent advances in generative artificial intelligence have enabled the creation of highly realistic synthetic voices which raises a series of new security concerns. These include the spread of fake audio on social media and social engineering attacks using cloned voices of family members in phone calls. State-of-the-art fake voice detectors rely on large-scale deep neural networks such as transformer models, making them resource-intensive and less accessible to everyday users. In this work, we propose TrueEar, the first lightweight fake voice detector of its kind. TrueEar is over 1000 times smaller than latest detectors, yet it achieves up to 99 \% accuracy. Built on a newly designed compact architecture, TrueEar is optimized for mobile platforms and can be easily deployed as an app to help users verify the authenticity of incoming calls or online audio. We have conducted extensive experiments on iOS devices to demonstrate the efficiency and effectiveness of our solution.},
	booktitle = {2025 {International} {Conference} on {Content}-{Based} {Multimedia} {Indexing} ({CBMI})},
	author = {Baird, Cameron and Li, Ke and Lin, Dan},
	month = oct,
	year = {2025},
	keywords = {Accuracy, Deep Learning, Detectors, Impersonation Attacks, In-ternet Security, Mobile handsets, Performance evaluation, Pipelines, Security, Social networking (online), Speech processing, Speech Processing, Transformers, Weapons},
	pages = {1--8},
}

@inproceedings{suthanthiradevi_leveraging_2024,
	title = {Leveraging {Deep} {Learning} {Models} for {Machine}-{Generated} {Text} {Detection} {Using} {Transformer}-{Based} {Models}},
	doi = {10.1109/ICSES63760.2024.10910837},
	abstract = {GPT is a large language model (LLM) derived from natural language processing that can generate a human-like text using machine learning. However, these models raise questions about authenticity and reliability of material, particularly in fields such as journalism, social media, and academia, despite their usefulness for automating text-based tasks. Detecting machine-generated text is thus an important difficulty in ensuring content integrity. This study investigates the use of huge language models as a technique for recognizing machine-generated material. The author proposes a comprehensive detection model by evaluating the language patterns, syntactic structures, and stylistic traits that separate AI-generated literature from human writing. In addition, this research investigate the possibilities of fine-tuning models designed expressly for text identification tasks and evaluate their performance using LLM - Detect AI Generated Text datasets. In digital ecosystems, LLMs are effective at detecting AI-generated text, providing a novel approach for content moderation, academic integrity checks, and synthetic media detection. An increasingly AI-powered future will require a model that can discriminate between human and machine-generated writing in real-time. According to experimental findings, the CNN architecture's design combined with the use of DistilBERT embeddings allows for the effective and efficient classification of AI generated text data, achieving an exceptional 98\% accuracy rate.},
	booktitle = {2024 {International} {Conference} on {Innovative} {Computing}, {Intelligent} {Communication} and {Smart} {Electrical} {Systems} ({ICSES})},
	author = {Suthanthiradevi, P. and Revathy, G and Rejini, K. and Lakshmi.V, Muthu},
	month = dec,
	year = {2024},
	keywords = {Accuracy, Biological system modeling, Deep learning, Deepfakes, Large language models, Large Language models, Machine generated text, Natural language processing, Social networking (online), Text detection, Transformers, Transformers and BERT, Writing},
	pages = {1--6},
}

@inproceedings{javiya_adaptive_2025,
	title = {Adaptive {DCGAN} and {VGG16}-based transfer learning for effective deepfake detection},
	volume = {2025},
	doi = {10.1049/icp.2025.1711},
	abstract = {Digital content generation technology evolved quickly which established deepfakes as a significant technological discovery. The manipulation capabilities of visual content by deepfakes create substantial threats for both digital security systems and information sharing integrity which occurs on social platforms. The developed deepfake detection framework unites a VGG16-based transfer learning model with an adaptive variant of DCGAN. The system benefitting from pretrained network characteristic extraction capabilities detect synthetic content efficiently with precision. A combination of optimized DCGAN architecture with VGG16 model pre-updating results in a system that reaches 97\% accurate results within 50 epochs which decreases detection time compared to Lite-CNN solutions. The model exhibits elevated detection performance through extensive testing that validates both its accuracy and speed rate in operations. Secure content verification systems experience advancement through this research as it resolves the present digital market's requirement for effective real-time detection solutions against deepfakes.},
	booktitle = {Parul {University} {International} {Conference} on {Engineering} and {Technology} 2025 ({PiCET} 2025)},
	author = {Javiya, Deepa and Jethava, Gordhan and Parmar, Himani},
	month = may,
	year = {2025},
	pages = {1771--1777},
}

@inproceedings{rao_alleshwaram_pothole_2025,
	title = {Pothole {Detection} using {Deep} {Learning}},
	doi = {10.1109/ICCMC65190.2025.11140736},
	abstract = {Road infrastructure plays a crucial role in ensuring connectivity, economic development, and public safety. However, the presence of potholes remains a major challenge, leading to vehicle damage, accidents, and costly repairs. Traditional methods of road inspection are labor-intensive and time-consuming, highlighting the need for automation. This proposed work presents a deep learning-based pothole detection system using the ResNet50 model, a powerful Convolutional Neural Network (CNN) known for its accuracy in image classification tasks. By employing transfer learning and preprocessing techniques, the model is trained to distinguish between damaged and undamaged road surfaces. We built an automated pothole-detection pipeline around a ResNet-50 backbone fine-tuned with transfer learning. The model processes road frames at 224 × 224 pixels, learns discriminative edge and texture cues, and labels each image as "damaged" or "sound." A balanced set of pothole and plain-road photos from open repositories fed the training loop. On held-out images the system kept accuracy above ninety percent and delivered high precision, which limits false alarms on smooth asphalt. A lightweight Flask dashboard renders the predictions instantly and can run from a dashboard camera or curb-side node. This outcome shows that deep networks can flag defects in real time, giving maintenance teams clear, location-tagged alerts while cutting inspection labor. The system not only enhances the efficiency of road monitoring but also contributes to the development of safer and smarter transportation infrastructure. This AI-powered approach can significantly reduce manual inspection efforts and aid municipal authorities in timely maintenance and repair.},
	booktitle = {2025 8th {International} {Conference} on {Computing} {Methodologies} and {Communication} ({ICCMC})},
	author = {Rao Alleshwaram, Venu Gopal and Kumar C, Sandeep and Reddy P, Chenna Kesava and Butchi Raju, K. and Anitha, Vulugundam and Rao, A. Veema},
	month = jul,
	year = {2025},
	keywords = {Accuracy, Cameras, CNN, Deep Learning, Image Classification, Inspection, Maintenance engineering, Pipelines, Pothole Detection, Residual neural networks, ResNet50, Road Safety, Roads, Smart Infrastructure, Training, Transfer learning, Transfer Learning, Urban areas},
	pages = {2031--2037},
}

@inproceedings{liu_fakefacediscriminator_2024,
	title = {{FakeFaceDiscriminator}: {Discrimination} of {AI}-{Synthesized} {Fake} {Faces}},
	doi = {10.1109/SIN63213.2024.10871737},
	abstract = {In recent years, the rapid improvement of deep learning technologies, particularly Generative Adversarial Net-works, has led to the proliferation of high-quality synthetic facial images and videos, commonly known as deepfakes. This study aims to evaluate and compare the performance of three prominent deep learning models - ResN et, EfficientNet, and Xception - in detecting synthetic faces. Using the Deepfake Detection Challenge and FaceForensics++ datasets, we system-atically assess each model's capability to handle diverse and challenging scenarios, including blurred and dark images. Data augmentation techniques, such as random blurring, brightness adjustment, and contrast enhancement, were employed to im-prove the models' robustness. Additionally, we applied model- specific optimizations, including the integration of Squeeze-and- Excitation blocks in Res Net, compound scaling in EfficientNet, and multi-scale feature fusion in Xception. These enhancements significantly improved the models' accuracy and resilience against low-quality synthetic data. Our results indicate that EfficientNet and Xception outperform ResNet in both general and adverse conditions, with EfficientNet excelling in high-resolution image processing and Xception showing superior performance in fine- grained feature extraction. Furthermore, the introduction of pre- trained weights, multitask learning frameworks, and dynamic learning rate adjustments during training contributed to the models' enhanced performance.},
	booktitle = {2024 17th {International} {Conference} on {Security} of {Information} and {Networks} ({SIN})},
	author = {Liu, Xufeng and Vu, Quoc Hoan and Singh, Priyanka},
	month = dec,
	year = {2024},
	keywords = {Accuracy, Analytical models, CNN architectures, data enhancement, Data models, Deep learning, Deepfakes, Face detection, Faces, Fake face discriminator, hyper-parameters optimization, Optimization, Real-time systems, Security},
	pages = {1--7},
}

