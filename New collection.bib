	pages = {1--6},
}

@inproceedings{nayak_cnn-driven_2025,
	title = {{CNN}-{Driven} {Adaptive} {Encryption} {Framework} for {Securing} {Surveillance} {Videos} {Against} {Evolving} {Threats}},
	doi = {10.1109/ICSIT65336.2025.11295214},
	abstract = {This This paper proposes a novel Convolutional Neural Networks (CNN)-based adaptive encryption framework to secure surveillance videos, addressing the rising challenges posed by dynamic security threats such as frame tampering, synthetic content injection, and unauthorized access. The framework integrates CNNs to classify video content into risk categories (normal, sensitive, high-risk), and dynamically adjusts encryption schemes based on these classifications. Lowrisk frames are encrypted using lightweight AES-128 encryption, while high-risk frames are protected with robust RSA encryption, ensuring computational efficiency without compromising security. A frame-linked key management system is also implemented, providing strong, non-predictable keys for each session. The system is evaluated on several datasets, including the VIRAT Aerial Video Dataset and UCSD Anomaly Dataset, demonstrating high performance in terms of encryption/decryption time, classification accuracy, and resistance to various attacks. The proposed framework achieves a high level of adaptability, with significant improvements over conventional encryption methods in realtime surveillance video protection.},
	booktitle = {2025 {International} {Conference} on {Sustainability}, {Innovation} \& {Technology} ({ICSIT})},
	author = {Nayak, Lalita and Ambhaikar, Asha},
	month = aug,
	year = {2025},
	keywords = {Adaptive Encryption, Adaptive systems, Convolutional neural networks, Convolutional Neural Networks (CNN), Dynamic Threat Detection, Encryption, Frame Tampering, Protection, Real-time systems, RSA Encryption, Sensitivity, Surveillance, Surveillance Video Security, System analysis and design, Threat assessment, Videos},
	pages = {1--7},
}

@inproceedings{sharudin_deepfake_2025,
	title = {Deepfake {Face} {Image} {Detection}: {Benchmarking} {CNN} {Models}' {Performance}},
	doi = {10.1109/InECCE64959.2025.11151055},
	abstract = {The Deepfake Face Image Detection System uses Convolutional Neural Networks (CNNs) to address the growing threat of deepfakes, which manipulate images to falsely depict events or actions, threatening privacy, and security. The development began with data collection to understand deepfakes and explore deep learning solutions. A diverse dataset of real and fake faces was used for training, with the system built in Python using VS Code and a user-friendly interface. Various CNN models, including basic CNN, ResNet-50, VGG-19, and XceptionNet, were evaluated, achieving 92 \% accuracy in classifying real and fake images. The system's unique dataset, combining high- and poor-quality images, enhances its ability to detect both clear and blurry deepfakes. The Graphical User Interface (GUI) demonstrated reliable predictions. Future improvements could include real-time detection in audio and video. This system highlights the effectiveness of CNNs in combating deep-fake threats, contributing to privacy and security awareness.},
