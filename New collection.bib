@article{shaaban_audio_2023,
	title = {Audio {Deepfake} {Approaches}},
	volume = {11},
	issn = {2169-3536},
	doi = {10.1109/ACCESS.2023.3333866},
	abstract = {This paper presents a review of techniques involved in the creation and detection of audio deepfakes, the first section provides information about general deep fakes. In the second section, the main methods for audio deepfakes are outlined and subsequently compared. The results discuss various methods for detecting audio deepfakes, including analyzing statistical properties, examining media consistency, and utilizing machine learning and deep learning algorithms. Major methods used to detect fake audio in these studies included Support Vector Machines (SVMs), Decision Trees (DTs), Convolutional Neural Networks (CNNs), Siamese CNNs, Deep Neural Networks (DNNs), and a combination of CNNs and Recurrent Neural Networks (RNNs). The accuracy of these methods varied, with the highest accuracy being 99\% for SVM and the lowest being 73.33\% for DT. The Equal Error Rate (EER) was reported in a few of the studies, with the lowest being 2\% for Deep-Sonar and the highest being 12.24 for DNN-HLLs. The t-DCF was also reported in some of the studies, with the Siamese CNN performing the best with a 55\% improvement in min-t-DCF and EER compared to other methods.},
	journal = {IEEE Access},
	author = {Shaaban, Ousama A. and Yildirim, Remzi and Alguttar, Abubaker A.},
	year = {2023},
	keywords = {artificial intelligence, Artificial intelligence, audio deepfakes, datasets, deep learning, Deep learning, Deepfakes, Face recognition, Facial features, forensics, Forensics, Forgery, Recurrent neural networks, Social networking (online), survey, Surveys, Videos},
	pages = {132652--132682},
}

@inproceedings{vayadande_enhanced_2024,
	title = {Enhanced {Detection} of {Deep} {Fakes}: {Exploring} {Advanced} {Approaches}},
	doi = {10.1109/ICSCNA63714.2024.10864123},
	abstract = {A sophisticated form of deepfake technology called synthetic media challenges the researcher to differentiate genuine content from falsified media. While advances in artificial intelligence have led to some very positive applications in entertainment and creative industries, they also give rise to serious concerns regarding misinformation dissemination, privacy invasion, and further cybersecurity issues. Thus, the development of strong and trusted deepfake detection techniques becomes a priority. This research study outlines state-of-the-art hybrid techniques for deepfake detection by merging CNN architectures, attention mechanisms, and GAN-based method into deepfake detection methods that exceed other state-of-the-art algorithms based on their accuracy, precision, and recall values on current datasets, including DF-PIatter and FaceForensics++. This research study examines different methods of deep learning such as convolutional neural networks and long short-term memory networks, along with forensic technique that help to detect anomalies in reflectance characteristics (like inconsistent lighting) and artifacts injected during the making of deepfakes. The methods will be compared with respect to their adversarial defense ability, generalization to unseen data, and efficacy in real-time scenarios. The study addresses the shortcomings of current detectors, identifies critical challenges, and proposes numerous ways for future advancements, thus providing major contributions toward the preservation of media authenticity and combating the misuse of synthetic media.},
	booktitle = {2024 {International} {Conference} on {Sustainable} {Communication} {Networks} and {Application} ({ICSCNA})},
	author = {Vayadande, Kuldeep and Sawant, Avantika and Pawar, Aditya and Rajurkar, Shantanu and Shendre, Rahul and Waghmode, Jagdish},
	month = dec,
	year = {2024},
	keywords = {Accuracy, Analytical models, Attention mechanisms, Computational efficiency, Computational modeling, Computer architecture, Convolutional neural networks, Convolutional Neural Networks (CNNs), Deep fake detection, Deepfakes, Generative Adversarial Networks (GANs), Multi-modal analysis, Neural networks, Transformer models, Transformers},
	pages = {1613--1620},
}

@article{kashyap_clarity_2026,
	title = {{CLARITY}: {A} {Lightweight} {Multimodal} {Transformer} for {Harmful} {Content} {Detection}},
	volume = {7},
	issn = {2691-4581},
	doi = {10.1109/TAI.2025.3591585},
	abstract = {Social media platforms are vital to modern communication, but they also enable the spread of harmful content, such as hate speech and misinformation. Current detection models, while accurate, are often resource-intensive and unsuitable for real-time or resource-constrained environments. Moreover, even models that incorporate multilingual capabilities often fail to generalize effectively across different languages. To address this challenge, we propose CLARITY, a novel lightweight cross-modal transformer architecture designed for efficient and scalable harmful content detection. Unlike traditional models, CLARITY achieves faster processing while maintaining accuracy, making it accessible to a wider range of platforms and devices. CLARITY integrates text, image, and audio modalities to capture complex, multimodal interactions that enhance detection across diverse content types. By employing contrastive learning, CLARITY accurately distinguishes between reclaimed language and genuinely harmful content, significantly reducing false positives and promoting inclusivity, particularly for marginalized communities. Additionally, CLARITY incorporates a domain adaptation module with cross-lingual and multilingual, enabling it to generalize effectively across various platforms and ensuring robust performance even in dynamic online environments. We evaluate CLARITY across multiple benchmark datasets and GPUs, including Kaggle’s Tesla P100, Colab Pro’s NVIDIA T4, and NVIDIA A100. The results demonstrate a significant reduction in inference time, with the A100 achieving an average inference time of 0.85 s per instance—over 30\% faster than traditional models—while maintaining competitive accuracy.},
	number = {2},
	journal = {IEEE Transactions on Artificial Intelligence},
	author = {Kashyap, Gautam Siddharth and Jain, Niharika and Shabbir, Ebad and Joshi, Harsh and Naseem, Usman and Gao, Jiechao},
	month = feb,
	year = {2026},
	keywords = {Adaptation models, CLARITY, Computational modeling, Context modeling, Data models, Fake news, harmful, Hate speech, lightweight model, Multilingual, social media, Training, Transformers, Visualization},
	pages = {1073--1083},
}

@inproceedings{chittam_deep_2024,
	title = {Deep {Fake} {Video} {Classification} with {Sequential} {Input} {Frames} {Using} {Hybrid} {Deep} {Learning} {Model} and {Bayesian} {Optimization}},
	issn = {1946-0759},
	doi = {10.1109/ICMLA61862.2024.00222},
	abstract = {With the advancement of Artificial Intelligence, creating synthetic content has become effortless. Manipulated content, such as synthesized images and videos known as Deep-fakes, is now prevalent on the internet and social media platforms. These deepfakes are generated using deep learning techniques, such as Generative Adversarial Networks (GANs) or Autoen-coders (AEs). They have the potential to spread false information and are particularly concerning in cases involving identity theft, especially when involving well-known celebrities. Distinguishing these fake videos with the human eye is challenging, as they closely resemble real ones. This research utilizes popular deep learning (DL) models, such as CNN (VGG19) combined with stacked LSTM, for the classification of real and fake videos. Sequences of input frames are stacked and fed into the hybrid model, which is developed using the TensorFlow framework for this study. Our approach applies video-level classification rather than frame-level classification, and it utilizes Bayesian Optimization (BO) for hyperparameter tuning, distinguishing it from other recent methods. The VGG19-LSTM model is trained and tested against FaceForensics dataset(FF++) to determine the best parameters and achieved the highest test accuracy of 95.6\% for deepfakes dataset.},
	booktitle = {2024 {International} {Conference} on {Machine} {Learning} and {Applications} ({ICMLA})},
	author = {Chittam, Swetha and Johnson, David and Roy, Kaushik and Yuan, Xiaohong},
	month = dec,
	year = {2024},
	keywords = {Accuracy, Bayes methods, Bayesian Optimization, Deep learning, Deepfakes, Hybrid Deep Learning, Optimization methods, Real-time systems, Sequential Input Frames, Social networking (online), Training, Transfer learning, Tuning, Video Deepfakes},
	pages = {1432--1438},
}

@inproceedings{m_ai-powered_2025,
	title = {{AI}-{Powered} {DeepFake} {Defense}},
	doi = {10.1109/IITCEE64140.2025.10915329},
	abstract = {Deepfake technology, known for its ability to produce convincingly face-swapped videos, presents significant risks to privacy, security, and public trust. Misuse of this technology for spreading misinformation, defamation, and influencing politics is on the rise, creating a pressing need for more effective detection mechanisms. As deepfake generation methods continue to advance, conventional detection techniques are increasingly unable to keep up, often falling short in accuracy and adaptability. This project aims to create an AI-driven detection system specialized in identifying face-swap deepfakes. The system focuses on subtle irregularities in facial details, movements, and the synchronization between audio and visuals. Employing neural network models such as Convolutional Neural Networks (CNNs), Long Short-Term Memory (LSTM) networks, and Capsule Networks, it pinpoints anomalies like unnatural expressions, atypical skin textures, and lighting inconsistencies. The system achieves high reliability with metrics including accuracy (96\%), precision (95\%), recall (94\%), and F1 score (95\%), showing marked improvement compared to traditional techniques. It outperforms existing methods such as XceptionNet (92\%) on the Celeb-DF dataset, underscoring its superior generalizability and robustness. This scalable solution has broad applications in media, law enforcement, and cybersecurity, reinforcing efforts to combat deepfake threats and fostering improved trust and security across various sectors.},
	booktitle = {2025 {International} {Conference} on {Intelligent} and {Innovative} {Technologies} in {Computing}, {Electrical} and {Electronics} ({IITCEE})},
	author = {M, Chaitra and B, Kushal and H, Likhitha and H R, Priyanka},
	month = jan,
	year = {2025},
	keywords = {Accuracy, Benchmark testing, Computer security, Computer Vision, Convolutional neural networks, Convolutional Neural Networks, Deepfakes, Flask, Law enforcement, Lighting, Long short term memory, Long Short-Term Memory(LSTM), Machine Learning, Measurement, Robustness},
	pages = {1--6},
}

@inproceedings{u_forensicai-net_2025,
	title = {{ForensicAI}-{Net}: {An} {Ensemble} {Model} {Framework} for {Strengthening} {Forensic} {Science} in {India}'s {Criminal} {Justice} {System}},
	doi = {10.1109/ISAECT68904.2025.11318760},
	abstract = {Forensic science is very important whenever investigating a crime, and the development of artificial intelligence (AI) has enhanced the process of analyzing forensic evidence. ResNet-152, Capsule Networks, Transformer-ViT, Graph Neural Networks are ensemble models used to create an ensemble model framework known as ForensicAI-Net, which improves forensic science in the Indian criminal justice system. The model was tested on several types of forensic data, such as fingerprints, image data at the crime scene, biometric scans, legal documents, and crime network data. With the ResNet-152-powered forensic image recognition module, the accuracy of the system in identifying fingerprints and classifying ballistic evidence was 96.8\% and 94.2\% respectively. BERT-RoBERTa model showed accuracy of 94.5\% in detecting tampering in forensic documents and Capsule Networks showed high accuracy of 92.1\% in detecting forging of handwriting. The biometric analysis model, based on Transformer-ViT, recorded 97.8\% on facial recognition, and the Siamese Networks recorded 94.6\% on the matching of latent fingerprints. Crime pattern detection models based on Graph Neural Networks predicted criminal networks with an accuracy of 95.6\% and crime prediction models based on reinforcement learning proposed an accuracy of 93.2\%. The suggested framework can make a great contribution to forensic decision-making, the efficiency of crime investigation, and the validation of legal evidence. Future directions will be in real-time deployment of forensic AI, federated learning to perform privacy-preserving forensic analysis, and improvement of interpretability to enforce legal compliance.},
	booktitle = {2025 7th {International} {Symposium} on {Advanced} {Electrical} and {Communication} {Technologies} ({ISAECT})},
	author = {U, Ragavee and Sriraghavan, K. and Rajan, M. and Raghul, R. and Sudharshan, S. and Sathiyaselvam, S.A.},
	month = dec,
	year = {2025},
	keywords = {Accuracy, Artificial intelligence, Artificial Intelligence, Biological system modeling, Biometric Analysis, Crime Investigation, Crime Pattern Detection, Deep learning, Deep Learning, Ensemble Learning, Fingerprint recognition, Fingerprint Recognition, Forensic AI, Forensics, Graph neural networks, Predictive models, Real-time systems, Transformers},
	pages = {1--6},
}

@inproceedings{lungu_computational_2025,
	title = {Computational {Social} {Engineering} {Attacks} {Mitigation} in {Social} {Media} {Platforms}},
	doi = {10.1109/ICMNWC66779.2025.11354345},
	abstract = {Considerable attacks on the security and privacy of users have been achieved using advanced computational social engineering methods to manipulate the psychological factors in using automated systems by using social media platforms as a primary vehicle to gather intelligence on victims. The measures that are currently being implemented to mitigate cyber-attacks are mainly based on conventional cybersecurity protection and pay little attention to their psychological and behavioral aspects. The study demonstrates an original hybrid design to include deep learning-based behavioral modeling and real-time psychological profiling to identify and reduce the threat of computational social engineering across social media. We use convolutional neural networks to analyse material, recurrent neural networks to simulate time-related behaviour, and attention techniques to grasp context. Experimental validation shows a 94.7\% increase in detection accuracy and {\textbackslash}mathbf9 2. 3 \% increase in precision and recall over existing approaches. The system detects manipulation patterns using multidimensional multi-linguistic characteristics, social network analysis, and temporal interaction patterns, providing substantial defence against increasingly diversified attack vectors.},
	booktitle = {2025 5th {International} {Conference} on {Mobile} {Networks} and {Wireless} {Communications} ({ICMNWC})},
	author = {Lungu, Nelson and Barik, Lalbihari and AlRababah, Ahmad AbdulQuadir and Rout, Suchismita and Saini, Jatinderkumar R. and Patra, Sudhansu Shekhar},
	month = dec,
	year = {2025},
	keywords = {behavioral analysis, computational attack, deep learning, Deep learning, Prevention and mitigation, Privacy, Protection, Psychology, Real-time systems, Recurrent neural networks, social engineering, social media security, Social networking (online), Vectors, Wireless communication},
	pages = {1--5},
}

@inproceedings{putra_comparative_2025,
	title = {A {Comparative} {Analysis} of {Custom} {CNN}, {Inception}-{V3}, {MobileNet}, {RestNet}-50, and {VGG}-19 in {Detecting} {AI}-{Generated} {Images}},
	doi = {10.1109/EECSI67060.2025.11290536},
	abstract = {This research addresses the issue of image classification using convolutional neural networks (CNN) with the objective of distinguishing AI-generated images from real images. This is a significant challenge in fields like digital forensics and media verification due to the realism of synthetic images. This study compares five CNN architectures: Inception-V3, ResNet-50, VGG-19, MobileNet, and a custom model, MBC-Net, which was developed to evaluate whether a simpler model can compete with well-established architectures. A balanced dataset of 20,000 images was constructed, consisting of 10,000 real and 10,000 AI-generated images spanning ten human and animal categories. The evaluation was conducted on the test set using accuracy, precision, and recall, under various learning rate and optimizer settings. The results show that Inception-V3 achieves the highest detection accuracy, reaching 0.984, while MobileNet demonstrated consistent stability across all test scenarios. MBC-Net also showed competitive performance, outperforming some pretrained models in certain cases. While model architecture is the primary factor for peak performance, the findings confirm that hyperparameter tuning is also critical. Although Inception-V3 offers high accuracy, its computational cost limits deployment in real-time systems. These findings provide practical insights that can help developers choose suitable models for building applications that detect AI-generated content under real-world constraints.},
	booktitle = {2025 12th {International} {Conference} on {Electrical} {Engineering}, {Computer} {Science} and {Informatics} ({EECSI})},
	author = {Putra, Verindra Hernanda and Sailendra, Zahra Amiera Putri and Hartakaadi, Marcelia Chintya and Pratama, Rafi Andhika Putra and Corputty, Felix},
	month = sep,
	year = {2025},
	keywords = {Accuracy, AI-Generated, Architecture, Computational efficiency, Computational modeling, Computer architecture, Convolutional neural networks, Inception-V3, MBC-Net, Media, MobileNet, Real-time systems, ResNet-50, Stability analysis, Tuning, VGG-19},
	pages = {619--624},
}

@inproceedings{kumaran_enhancing_2024,
	title = {Enhancing {Healthcare} {Image} {Record} {Security} via {CNN}-based {Tamper} {Detection}, {Watermarking}, and {Digital} {Signatures}},
	doi = {10.1109/ICSSAS64001.2024.10760451},
	abstract = {Computers have been seamlessly integrated into every domain including health care where one of its applications is in the storage of health care records such as medical images. Electronic healtheare records contain a lot of sensitive information about patients, such as the diseases, diagnosis, treatment plans, drugs administered or medicines prescribed and hence this vital information must not be disclosed at any cost as it can have huge repercussions. As each day passes, more vulnerabilities and threats surface and it is important to come up with secure systems and apt security measures to counter these threats and keep the attackers at bay. This study provides a holistic approach to secure and safeguard medical image records by addressing two problems, the first is image tamper detection using medical image deepfake detection to decipher whether the image has been modified or not, and the second is to employ various cryptographic techniques such as hashing, watermarking and digital signatures to protect the images from getting tampered itself.},
	booktitle = {2024 2nd {International} {Conference} on {Self} {Sustainable} {Artificial} {Intelligence} {Systems} ({ICSSAS})},
	author = {Kumaran, U and M, Gurupriya and Thodathara, Harshitha Reddy and {Aryagopal} and Vijjapu, Aditya and Harish, Gattamaneni},
	month = oct,
	year = {2024},
	keywords = {Accuracy, Convolutional Neural Networks, Deep Learning, Deepfakes, Digital Imaging and Communication in Medicine, Digital signatures, Digital Signatures, Electronic Health Records, Medical diagnostic imaging, Predictive models, Real-time systems, Solid modeling, Surface treatment, Tamper Detection, Three-dimensional displays, Watermarking},
	pages = {25--34},
}

@inproceedings{sangolgi_unified_2025,
	title = {A {Unified} {Deep} {Learning} {Framework} for {Lip} {Reading} and {Deep} {Fake} {Audio} {Classification}},
	issn = {2643-8615},
	doi = {10.1109/ISPCC66872.2025.11039390},
	abstract = {This study proposes a multimodal framework designed to enhance deepfake detection by integrating visual lip-reading analysis and audio signal processing for real-time applications. Leveraging LipNet—a deep learning model pre-trained on the GRID dataset—the system employs 3D convolutional neural networks (CNNs) combined with bidirectional long short-term memory (Bi-LSTM) layers to interpret lip movements and decode spoken words from visual inputs. Simultaneously, audio analysis modules evaluate acoustic features to detect synthetic or manipulated speech. By independently training these components and combining their outputs, the framework identifies inconsistencies between visual and auditory modalities, such as mismatched lip-audio synchronization or unnatural speech patterns. Experimental results demonstrate robust performance in both word-level lip-reading accuracy and deepfake detection reliability, achieving high precision in flagging fraudulent content. The system’s effectiveness in detecting audiovisual anomalies positions it as a practical tool for digital forensics and security applications, with potential to foster trust in digital media. Future work will expand the model’s adaptability to diverse datasets, including multilingual contexts, and refine its integration into real-world media authentication and accessibility tools.},
	booktitle = {2025 7th {International} {Conference} on {Signal} {Processing}, {Computing} and {Control} ({ISPCC})},
	author = {Sangolgi, Vijay A and Patil, Mithun B and Bhosale, Omkar Nagnath and Deshmukhe, Anurag Vivek and Jawalgi, Pallavi Bhimrao and Katwe, Srushti Prabhakar},
	month = mar,
	year = {2025},
	keywords = {Accuracy, audio authenticity, bi-lstm, cnn, deep fake audio classification, Deep learning, Deepfakes, Feature extraction, lip – reading, Lips, Long short term memory, Media, mfccs, Reliability, Synchronization, Visualization},
	pages = {34--40},
}

@inproceedings{k_application_2024,
	title = {Application of {Machine} {Learning} for the {Detection} of {Audio} {Deep} {Fake}},
	doi = {10.1109/GCCIT63234.2024.10862652},
	abstract = {Strong detection procedures are crucial for preserving digital safety and reliability in light of the rapid development of deepfaketechnology, especially in the audio domain. Presenting a "Improved Deepfake Audio Detection using Spectro-Temporal Deep Learning Approach," our study attempts to tackle the growing problem of differentiating real audio from advanced deepfake alterations. In order to train and test a new deep learning model, our approach makes use of the extensive ADD2022 dataset. At its heart, our method is based on a painstaking data preparation step that involves resampling, normalizing, and silence removal of audio samples to make them consistent and improve the quality of the model input. An novel combination of Convolutional Neural Networks (CNNs) for spectral feature extraction and Recurrent Neural Networks (RNNs) or Long Short-Term Memory (LSTM) networks for temporal dynamics analysis is used in our deep learning model architecture. The complex irregularities seen in deepfake audios may be easily detected by this hybrid model. This research presents a method for detecting speech spoofing using Convolutional neural networks. The system uses many audio properties to distinguish between human and synthetic voices. In the worst-case scenario, unethical applications of deepfake audios meant to harm third parties might do widespread damage to national assets and reputations. An assailant may create convincing voiceovers by using a tiny audio sample of a real person. A 2D graph may be created using mathematical formulas to represent any audio stream. Converting audio files to pictures of audio features (Spectrogram, MFCC, FFT, STFT) before logging obtaining the array values in a numerical format that is best for feeding into a convolutional neural network (CNN) reduces the amount of computation needed to build a system that can detect deepfake voices. Predictions are made using both standalone and combined methods of entering data into the model.},
	booktitle = {2024 {Global} {Conference} on {Communications} and {Information} {Technologies} ({GCCIT})},
	author = {K, Divya and Chhabra, Gunjan and {Pallavi} and Tiwaskar, S.A. and Hemelatha, S. and Saraswat, Vivek},
	month = oct,
	year = {2024},
	keywords = {Analytical models, Audio Authenticity, Convolutional neural networks, Data models, Deep Fake Audio Detection, Deep learning, Deep Learning Models, Deepfakes, Digital Forensics, Feature extraction, Long short term memory, Reliability, Spectro-Temporal Analysis, Training, Weapons},
	pages = {1--6},
}

