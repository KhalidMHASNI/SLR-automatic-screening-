	doi = {10.1109/ICEC2NT65402.2025.11380131},
	abstract = {The emergence of deepfakes remains a significant concern for information security, digital identity, and public trust. High-parity, high-truth, audio-visual deepfakes not merely are also more frequently weaponized against anti-information and identity theft during acts of cyberterrorism. This work mostly isn't about finding only the visual or audio part of it, but we intend to robust from any potential signals making the deepfakes. The authors thus present a unified AI-based framework for evaluating deepfakes across multiple modalities, involving techniques for facial expression and voice similarity within hybrid rebirth vs. mis-reality detection system. Machine learning neural methods implemented within the ViT (Vision Transformer), CLSTM (Convolutional Long Short-Term Memory) net. 0 work, are set out to achieve very high true positive and very low false positive rates across varied dataset distributions: FaceForensics++, FakeAVCeleb, and Celeb-DF. Experimental results confirm that multi-modal fusion improves results of unimodal techniques only, especially under adverse and low-quality conditions. Real-world attacks are simulated to simulate different cybersecurity environments for evaluating our approach. The possibility for this architecture to grow operationally in actual digital forensics, secure authentication, and automated content verification scenarios is glaringly evident. This work cannot but prove the necessity of multi-modal approaches to repel deepfakes whilst affordably achieving a holistic detection pipeline to the evolving synthetic media worries in the information age.},
	booktitle = {2025 {International} {Conference} on {Electronics} and {Computing}, {Communication} {Networking} {Automation} {Technologies} ({ICEC2NT})},
	author = {Autade, Rahul and Hemalatha Naga Himabindu, Gurajada},
	month = sep,
	year = {2025},
	keywords = {audio-visual forensics, cybersecurity, deep learning, Deepfake detection, Deepfakes, digital forensics, Digital forensics, fake media detection, Information security, Long short term memory, Media, multimodal AI, neural network, Neural networks, Pipelines, synthetic media, Transformers, Visualization, Weapons},
	pages = {1--7},
}

